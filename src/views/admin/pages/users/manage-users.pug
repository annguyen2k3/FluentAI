extends ../../layouts/default.pug

block main-content
  div(class="page-header")
    ul(class="breadcrumbs")
      li(class="nav-home")
        a(href=`${prefixAdmin}/dashboard`)
          i(class="fas fa-home")
      li(class="separator")
        i(class="fas fa-angle-right")
      li(class="nav-item")
        a(href="#") Quản lý người dùng

  div(class="row")
    div(class="col-md-3")
      div(class="card card-stats card-primary")
        div(class="card-body")
          div(class="row")
            div(class="col-5")
              div(class="icon-big text-center")
                i(class="fas fa-users")
            div(class="col-7 col-stats")
              div(class="numbers")
                p(class="card-category") Tổng người dùng
                h4(class="card-title") #{countUsers}
    div(class="col-md-3")
      div(class="card card-stats card-success")
        div(class="card-body")
          div(class="row")
            div(class="col-5")
              div(class="icon-big text-center")
                i(class="fas fa-user-check")
            div(class="col-7 col-stats")
              div(class="numbers")
                p(class="card-category") Đang hoạt động
                h4(class="card-title") #{countActiveUsers}
    div(class="col-md-3")
      div(class="card card-stats card-warning")
        div(class="card-body")
          div(class="row")
            div(class="col-5")
              div(class="icon-big text-center")
                i(class="fas fa-user-lock")
            div(class="col-7 col-stats")
              div(class="numbers")
                p(class="card-category") Bị khóa
                h4(class="card-title") #{countBlockedUsers}
    div(class="col-md-3")
      div(class="card card-stats card-info")
        div(class="card-body")
          div(class="row")
            div(class="col-5")
              div(class="icon-big text-center")
                i(class="fas fa-user-plus")
            div(class="col-7 col-stats")
              div(class="numbers")
                p(class="card-category") Mới hôm nay
                h4(class="card-title") #{countNewUsers}

  div(class="row")
    div(class="col-md-12")
      div(class="card")
        div(class="card-header")
          div(class="d-flex align-items-center")
            h4(class="card-title") Danh sách người dùng
        div(class="card-body")
          div(class="row mb-3")
            div(class="col-md-3")
              div(class="form-group")
                label Tìm kiếm
                div(class="input-group")
                  input(type="text" class="form-control" id="searchInput" placeholder="Tìm theo tên, email, ID...")
                  div(class="input-group-append")
                    button(class="btn btn-primary" type="button" id="searchBtn")
                      i(class="fas fa-search")
            div(class="col-md-2")
              div(class="form-group")
                label Trạng thái
                select(class="form-control" id="statusFilter")
                  option(value="") Tất cả
                  option(value="active") Đang hoạt động
                  option(value="blocked") Bị khóa
            div(class="col-md-2")
              div(class="form-group")
                label Từ ngày
                input(type="date" class="form-control" id="startDateFilter")
            div(class="col-md-2")
              div(class="form-group")
                label Đến ngày
                input(type="date" class="form-control" id="endDateFilter")
            div(class="col-md-2")
              div(class="form-group")
                label Sắp xếp
                select(class="form-control" id="sortFilter")
                  option(value="desc") Mới nhất
                  option(value="asc") Cũ nhất
            div(class="col-md-1")
              div(class="form-group")
                label &nbsp;
                button(class="btn btn-secondary btn-block" id="resetFilter" title="Reset")
                  i(class="fas fa-undo") 

          div(class="table-responsive")
            table(class="table table-striped" id="usersTable")
              thead
                tr
                  th ID
                  th Avatar
                  th Tên
                  th Email
                  th Số điện thoại
                  th Trạng thái
                  th Ngày đăng ký
                  th Thao tác
              tbody(id="usersTableBody")
                tr
                  td(colspan="8" class="text-center py-4")
                    div(class="spinner-border text-primary" role="status")
                      span(class="sr-only") Đang tải...

          div(class="row mt-3")
            div(class="col-md-6")
              div(class="dataTables_info" id="paginationInfo")
                | Đang tải...
            div(class="col-md-6")
              nav(aria-label="Page navigation")
                ul(class="pagination justify-content-end" id="pagination")
                  li(class="page-item disabled")
                    a(class="page-link" href="#" tabindex="-1") Đang tải...

  div(class="modal fade" id="userDetailModal" tabindex="-1" role="dialog" aria-labelledby="userDetailModalLabel" aria-hidden="true")
    div(class="modal-dialog modal-lg" role="document")
      div(class="modal-content")
        div(class="modal-header")
          h5(class="modal-title" id="userDetailModalLabel") Chi tiết người dùng
          button(type="button" class="close" onclick="$('#userDetailModal').modal('hide')" aria-label="Close")
            span(aria-hidden="true") &times;
        div(class="modal-body")
          div(class="row")
            div(class="col-md-4 text-center")
              div(class="avatar-lg mx-auto mb-3")
                img(src="/admin/assets/img/profile.jpg" alt="..." class="avatar-img rounded-circle" id="userAvatar")
              span(class="badge badge-success" id="userStatus") Hoạt động
            div(class="col-md-8")
              div(class="row")
                div(class="col-12 col-md-6")
                  div(class="alert alert-info d-flex align-items-center justify-content-between mb-3")
                    div
                      div(class="small text-uppercase text-muted mb-1") Điểm tháng
                      div(class="h5 mb-0 font-weight-bold" id="userMonthScore") 0
                    a(href="#" class="text-primary font-weight-bold" id="userMonthScoreLink") Chi tiết
                div(class="col-12 col-md-6")
                  div(class="alert alert-primary d-flex align-items-center justify-content-between mb-3")
                    div
                      div(class="small text-uppercase text-muted mb-1") Tài sản
                      div(class="h5 mb-0 font-weight-bold" id="userWalletBalance") 0
                    a(href="/admin/users/wallet" class="text-primary font-weight-bold" id="userWalletLink") Chi tiết
                div(class="col-md-6")
                  div(class="form-group")
                    label(class="form-label") ID người dùng
                    p(class="form-control-plaintext" id="userId") -
                div(class="col-md-6")
                  div(class="form-group")
                    label(class="form-label") Tên người dùng
                    input(type="text" class="form-control" id="userName" placeholder="Nhập tên người dùng" disabled)
                div(class="col-md-6")
                  div(class="form-group")
                    label(class="form-label") Email
                    input(type="email" class="form-control" id="userEmailDetail" placeholder="Nhập email" disabled)
                div(class="col-md-6")
                  div(class="form-group")
                    label(class="form-label") Số điện thoại
                    input(type="tel" class="form-control" id="userPhone" placeholder="Nhập số điện thoại" disabled)
                div(class="col-md-6")
                  div(class="form-group")
                    label(class="form-label") Giới tính
                    select(class="form-control" id="userGender" disabled)
                      option(value="") Chưa cập nhật
                      option(value="male") Nam
                      option(value="female") Nữ
                      option(value="other") Khác
                div(class="col-md-6")
                  div(class="form-group")
                    label(class="form-label") Ngày sinh
                    input(type="date" class="form-control" id="userDateOfBirth" disabled)
                div(class="col-md-6")
                  div(class="form-group")
                    label(class="form-label") Ngày đăng ký
                    p(class="form-control-plaintext" id="userRegisterDate") -
                div(class="col-md-6")
                  div(class="form-group")
                    label(class="form-label") Cập nhật lần cuối
                    p(class="form-control-plaintext" id="userLastLogin") -
        div(class="modal-footer")
          button(type="button" class="btn btn-outline-secondary d-none" id="cancelEditBtn" onclick="cancelEditUser()")
            i(class="fas fa-times")
            |  Hủy chỉnh sửa
          button(type="button" class="btn btn-secondary" data-bs-dismiss="modal") Đóng
          button(type="button" class="btn btn-primary" id="editUserBtn" onclick="editUser()")
            i(class="fas fa-edit")
            |  Chỉnh sửa

  div(class="modal fade" id="confirmModal" tabindex="-1" role="dialog" aria-labelledby="confirmModalLabel" aria-hidden="true")
    div(class="modal-dialog" role="document")
      div(class="modal-content")
        div(class="modal-header")
          h5(class="modal-title" id="confirmModalLabel") Xác nhận
          button(type="button" class="close" data-dismiss="modal" aria-label="Close")
            span(aria-hidden="true") &times;
        div(class="modal-body")
          p(id="confirmMessage") Bạn có chắc chắn muốn thực hiện hành động này?
        div(class="modal-footer")
          button(type="button" class="btn btn-secondary" data-dismiss="modal") Hủy
          button(type="button" class="btn btn-danger" id="confirmAction") Xác nhận

block scripts
  script(type="module").
    import { AdminApiBreakpoint } from '/js/api_breakpoint.js'
    const prefixAdmin = "#{prefixAdmin}"
    let currentPage = 1
    const limit = 10
    let currentFilters = {
      search: '',
      status: '',
      startDate: '',
      endDate: '',
      sort: 'desc'
    }
    let usersList = []
    let selectedUser = null
    let isUserEditMode = false

    async function loadUsers() {
      const tbody = document.getElementById('usersTableBody')
      tbody.innerHTML = '<tr><td colspan="8" class="text-center py-4"><div class="spinner-border text-primary" role="status"><span class="sr-only">Đang tải...</span></div></td></tr>'

      const params = new URLSearchParams({
        page: currentPage.toString(),
        limit: limit.toString(),
        ...(currentFilters.search && { search: currentFilters.search }),
        ...(currentFilters.status && { status: currentFilters.status }),
        ...(currentFilters.startDate && { startDate: currentFilters.startDate }),
        ...(currentFilters.endDate && { endDate: currentFilters.endDate }),
        sort: currentFilters.sort
      })

      try {
        const response = await fetch(`${AdminApiBreakpoint.GET_USERS_LIST}?${params}`)
        
        if (!response.ok) {
          const errorText = await response.text()
          let errorData
          try {
            errorData = JSON.parse(errorText)
          } catch {
            errorData = { message: errorText || `HTTP ${response.status}: ${response.statusText}` }
          }
          throw new Error(errorData.message || `HTTP ${response.status}: ${response.statusText}`)
        }

        const result = await response.json()

        if (result.status === 200 && result.data) {
          usersList = result.data.list
          renderUsers(result.data.list)
          renderPagination(result.data.pagination)
        } else {
          const errorMsg = result.message || 'Có lỗi xảy ra khi tải dữ liệu'
          tbody.innerHTML = `<tr><td colspan="8" class="text-center text-danger">
            <div class="alert alert-danger mb-0">
              <strong>Lỗi:</strong> ${errorMsg}
              ${result.error ? `<br><small>Chi tiết: ${JSON.stringify(result.error)}</small>` : ''}
            </div>
          </td></tr>`
        }
      } catch (error) {
        console.error('Error loading users:', error)
        const errorMsg = error.message || 'Có lỗi xảy ra khi tải dữ liệu'
        tbody.innerHTML = `<tr><td colspan="8" class="text-center text-danger">
          <div class="alert alert-danger mb-0">
            <strong>Lỗi:</strong> ${errorMsg}
            <br><small>Chi tiết: ${error.toString()}</small>
            ${error.stack ? `<br><small style="font-size: 0.8em; color: #666;">Stack: ${error.stack}</small>` : ''}
          </div>
        </td></tr>`
      }
    }

    function renderUsers(users) {
      const tbody = document.getElementById('usersTableBody')
      
      if (!users || users.length === 0) {
        tbody.innerHTML = '<tr><td colspan="8" class="text-center py-4">Không có dữ liệu</td></tr>'
        return
      }

      tbody.innerHTML = users.map(user => {
        const createDate = user.create_at ? new Date(user.create_at).toLocaleDateString('vi-VN') : '-'
        const status = user.status || 'active'
        const statusText = getStatusText(status)
        const statusClass = getStatusClass(status)
        const userId = user._id ? user._id.toString() : ''
        const username = user.username || 'Chưa cập nhật'
        const email = user.email || '-'
        const phone = user.phone_number || '-'
        const avatar = user.avatar || 'https://fluent-ai-bucket.s3.ap-southeast-1.amazonaws.com/avatar_user_default.png'

        return `
          <tr data-user-id="${userId}">
            <td>
              <span class="user-table__id" title="${userId}">${userId.substring(0, 20)}${userId.length > 20 ? '...' : ''}</span>
            </td>
            <td>
              <div class="avatar-sm">
                <img src="${avatar}" alt="${username}" class="avatar-img rounded-circle" onerror="this.src='https://fluent-ai-bucket.s3.ap-southeast-1.amazonaws.com/avatar_user_default.png'">
          </div>
            </td>
            <td>
              <span class="user-table__id" title="${username}" style="display:inline-block; max-width:100px; min-width:100px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">${username}</span>
            </td>
            <td>
              <span class="user-table__id" title="${email}" style="display:inline-block; max-width:150px; min-width:150px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">${email}</span>
            </td>
            <td>${phone}</td>
            <td>
              <span class="badge ${statusClass}">${statusText}</span>
            </td>
            <td>${createDate}</td>
            <td>
              <div class="btn-group">
                <button class="btn btn-sm btn-info" data-action="view" data-user-id="${userId}" title="Xem chi tiết">
                  <i class="fas fa-eye"></i>
                </button>
                <button class="btn btn-sm btn-outline-primary" data-action="logout" data-user-id="${userId}" title="Đăng xuất người dùng">
                  <i class="fas fa-sign-out-alt"></i>
                </button>
                ${status === 'active' 
                  ? `<button class="btn btn-sm btn-warning" data-action="lock" data-user-id="${userId}" title="Khóa tài khoản"><i class="fas fa-lock"></i></button>`
                  : `<button class="btn btn-sm btn-success" data-action="unlock" data-user-id="${userId}" title="Mở khóa"><i class="fas fa-unlock"></i></button>`
                }
                <button class="btn btn-sm btn-danger" data-action="delete" data-user-id="${userId}" title="Xóa">
                  <i class="fas fa-trash"></i>
                </button>
        </div>
            </td>
          </tr>
        `
      }).join('')

      tbody.querySelectorAll('button[data-action]').forEach(button => {
        button.addEventListener('click', function() {
          const action = this.getAttribute('data-action')
          const userId = this.getAttribute('data-user-id')
          switch(action) {
            case 'view':
              viewUser(userId)
              break
            case 'lock':
              lockUser(userId)
              break
            case 'unlock':
              unlockUser(userId)
              break
            case 'logout':
              logoutUser(userId)
              break
            case 'delete':
              deleteUser(userId)
              break
          }
        })
      })
    }

    function renderPagination(pagination) {
      const paginationInfo = document.getElementById('paginationInfo')
      const paginationEl = document.getElementById('pagination')

      const start = (pagination.page - 1) * pagination.limit + 1
      const end = Math.min(pagination.page * pagination.limit, pagination.total)
      paginationInfo.textContent = `Hiển thị ${start} đến ${end} của ${pagination.total} người dùng`

      let paginationHTML = ''
      
      paginationHTML += `<li class="page-item ${!pagination.hasPrevPage ? 'disabled' : ''}">
        <a class="page-link" href="#" data-page="${pagination.page - 1}">Trước</a>
      </li>`

      const maxPages = 5
      let startPage = Math.max(1, pagination.page - Math.floor(maxPages / 2))
      let endPage = Math.min(pagination.totalPages, startPage + maxPages - 1)
      
      if (endPage - startPage < maxPages - 1) {
        startPage = Math.max(1, endPage - maxPages + 1)
      }

      if (startPage > 1) {
        paginationHTML += `<li class="page-item"><a class="page-link" href="#" data-page="1">1</a></li>`
        if (startPage > 2) {
          paginationHTML += `<li class="page-item disabled"><span class="page-link">...</span></li>`
        }
      }

      for (let i = startPage; i <= endPage; i++) {
        paginationHTML += `<li class="page-item ${i === pagination.page ? 'active' : ''}">
          <a class="page-link" href="#" data-page="${i}">${i}</a>
        </li>`
      }

      if (endPage < pagination.totalPages) {
        if (endPage < pagination.totalPages - 1) {
          paginationHTML += `<li class="page-item disabled"><span class="page-link">...</span></li>`
        }
        paginationHTML += `<li class="page-item"><a class="page-link" href="#" data-page="${pagination.totalPages}">${pagination.totalPages}</a></li>`
      }

      paginationHTML += `<li class="page-item ${!pagination.hasNextPage ? 'disabled' : ''}">
        <a class="page-link" href="#" data-page="${pagination.page + 1}">Sau</a>
      </li>`

      paginationEl.innerHTML = paginationHTML

      paginationEl.querySelectorAll('a.page-link[data-page]').forEach(link => {
        link.addEventListener('click', function(e) {
          e.preventDefault()
          const page = parseInt(this.getAttribute('data-page'))
          if (page && !this.closest('.page-item').classList.contains('disabled')) {
            currentPage = page
            loadUsers()
          }
        })
      })
    }

    function viewUser(userId) {
      const user = usersList.find(u => u._id && u._id.toString() === userId)
      
      if (!user) {
        showNotification('error', 'Không tìm thấy thông tin người dùng!')
        return
      }

      console.log(user)

      const avatar = user.avatar || 'https://fluent-ai-bucket.s3.ap-southeast-1.amazonaws.com/avatar_user_default.png'
      const username = user.username || 'Chưa cập nhật'
      const status = user.status || 'active'
      const statusText = getStatusText(status)
      const statusClass = getStatusClass(status)
      const userIdDisplay = user._id ? user._id.toString() : '-'
      const monthScore = Number(user.user_month_score || 0)
      const walletBalance = Number(
        (user.wallet && user.wallet.balance_credit) || 0
      )
      const monthScoreLink = document.getElementById('userMonthScoreLink')
      const walletLink = document.getElementById('userWalletLink')
      
      const createDate = user.create_at ? new Date(user.create_at).toLocaleDateString('vi-VN', {
        year: 'numeric',
        month: '2-digit',
        day: '2-digit',
        hour: '2-digit',
        minute: '2-digit'
      }) : 'Chưa có'
      
      const updateDate = user.update_at ? new Date(user.update_at).toLocaleDateString('vi-VN', {
        year: 'numeric',
        month: '2-digit',
        day: '2-digit',
        hour: '2-digit',
        minute: '2-digit'
      }) : 'Chưa có'
      
      selectedUser = JSON.parse(JSON.stringify(user))
      isUserEditMode = false
      setUserFormDisabled(true)
      updateUserEditControls()
      populateEditableFields(selectedUser)

      document.getElementById('userAvatar').src = avatar
      document.getElementById('userAvatar').alt = username
      document.getElementById('userStatus').textContent = statusText
      document.getElementById('userStatus').className = `badge ${statusClass}`
      document.getElementById('userId').textContent = userIdDisplay
      document.getElementById('userRegisterDate').textContent = createDate
      document.getElementById('userLastLogin').textContent = updateDate
      document.getElementById('userMonthScore').textContent = monthScore.toLocaleString('vi-VN') + '🎯'
      document.getElementById('userWalletBalance').textContent = walletBalance.toLocaleString('vi-VN') + '🪙'
      if (monthScoreLink) monthScoreLink.href = `${prefixAdmin}/users/score/${userId}`
      if (walletLink) walletLink.href = '/admin/users/wallet'
      $('#userDetailModal').modal('show')
    }

    async function lockUser(userId) {
      showConfirmModal(
        'Khóa tài khoản',
        'Bạn có chắc chắn muốn khóa tài khoản này? Người dùng sẽ không thể đăng nhập vào hệ thống.',
        async () => {
          try {
            const response = await fetch(AdminApiBreakpoint.LOCK_USER, {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json'
              },
              body: JSON.stringify({ userId })
            })

            if (!response.ok) {
              const errorText = await response.text()
              let errorData
              try {
                errorData = JSON.parse(errorText)
              } catch {
                errorData = { message: errorText || `HTTP ${response.status}: ${response.statusText}` }
              }
              throw new Error(errorData.message || `HTTP ${response.status}: ${response.statusText}`)
            }

            const result = await response.json()

            if (result.status === 200) {
              showNotification('success', result.message || 'Đã khóa tài khoản thành công!')
              loadUsers()
            } else {
              showNotification('error', result.message || 'Có lỗi xảy ra khi khóa tài khoản!')
            }
          } catch (error) {
            console.error('Error locking user:', error)
            showNotification('error', error.message || 'Có lỗi xảy ra khi khóa tài khoản!')
          }
        }
      )
    }

    async function unlockUser(userId) {
      showConfirmModal(
        'Mở khóa tài khoản',
        'Bạn có chắc chắn muốn mở khóa tài khoản này?',
        async () => {
          try {
            const response = await fetch(AdminApiBreakpoint.UNLOCK_USER, {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json'
              },
              body: JSON.stringify({ userId })
            })

            if (!response.ok) {
              const errorText = await response.text()
              let errorData
              try {
                errorData = JSON.parse(errorText)
              } catch {
                errorData = { message: errorText || `HTTP ${response.status}: ${response.statusText}` }
              }
              throw new Error(errorData.message || `HTTP ${response.status}: ${response.statusText}`)
            }

            const result = await response.json()

            if (result.status === 200) {
              showNotification('success', result.message || 'Đã mở khóa tài khoản thành công!')
              loadUsers()
            } else {
              showNotification('error', result.message || 'Có lỗi xảy ra khi mở khóa tài khoản!')
            }
          } catch (error) {
            console.error('Error unlocking user:', error)
            showNotification('error', error.message || 'Có lỗi xảy ra khi mở khóa tài khoản!')
          }
        }
      )
    }

    async function logoutUser(userId) {
      showConfirmModal(
        'Đăng xuất người dùng',
        'Bạn có chắc chắn muốn đăng xuất người dùng này khỏi tất cả phiên đang hoạt động?',
        async () => {
          try {
            const response = await fetch(AdminApiBreakpoint.LOGOUT_USER, {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json'
              },
              body: JSON.stringify({ userId })
            })

            if (!response.ok) {
              const errorText = await response.text()
              let errorData
              try {
                errorData = JSON.parse(errorText)
              } catch {
                errorData = { message: errorText || `HTTP ${response.status}: ${response.statusText}` }
              }
              throw new Error(errorData.message || `HTTP ${response.status}: ${response.statusText}`)
            }

            const result = await response.json()

            if (result.status === 200) {
              showNotification('success', result.message || 'Đã đăng xuất người dùng thành công!')
            } else {
              showNotification('error', result.message || 'Có lỗi xảy ra khi đăng xuất người dùng!')
            }
          } catch (error) {
            console.error('Error logging out user:', error)
            showNotification('error', error.message || 'Có lỗi xảy ra khi đăng xuất người dùng!')
          }
        }
      )
    }

    async function deleteUser(userId) {
      const user = usersList.find(u => u._id && u._id.toString() === userId)
      
      if (user && user.status === 'active') {
        showNotification('error', 'Không thể xóa tài khoản đang hoạt động. Vui lòng khóa tài khoản trước khi xóa!')
        return
      }

      showConfirmModal(
        'Xóa tài khoản',
        'Bạn có chắc chắn muốn xóa tài khoản này? Hành động này không thể hoàn tác!',
        async () => {
          try {
            const response = await fetch(AdminApiBreakpoint.DELETE_USER, {
              method: 'DELETE',
              headers: {
                'Content-Type': 'application/json'
              },
              body: JSON.stringify({ userId })
            })

            if (!response.ok) {
              const errorText = await response.text()
              let errorData
              try {
                errorData = JSON.parse(errorText)
              } catch {
                errorData = { message: errorText || `HTTP ${response.status}: ${response.statusText}` }
              }
              throw new Error(errorData.message || `HTTP ${response.status}: ${response.statusText}`)
            }

            const result = await response.json()

            if (result.status === 200) {
              showNotification('success', result.message || 'Đã xóa tài khoản thành công!')
              loadUsers()
            } else {
              showNotification('error', result.message || 'Có lỗi xảy ra khi xóa tài khoản!')
            }
          } catch (error) {
            console.error('Error deleting user:', error)
            showNotification('error', error.message || 'Có lỗi xảy ra khi xóa tài khoản!')
          }
        }
      )
    }

    function setUserFormDisabled(isDisabled) {
      const editableFieldIds = ['userName', 'userEmailDetail', 'userPhone', 'userGender', 'userDateOfBirth']
      editableFieldIds.forEach(id => {
        const field = document.getElementById(id)
        if (field) {
          field.disabled = isDisabled
        }
      })
    }

    function populateEditableFields(user) {
      const usernameInput = document.getElementById('userName')
      if (usernameInput) {
        usernameInput.value = user.username || ''
        usernameInput.placeholder = user.username ? '' : 'Chưa cập nhật'
      }

      const emailInput = document.getElementById('userEmailDetail')
      if (emailInput) {
        emailInput.value = user.email || ''
        emailInput.placeholder = user.email ? '' : 'Chưa cập nhật'
      }

      const phoneInput = document.getElementById('userPhone')
      if (phoneInput) {
        phoneInput.value = user.phone_number || ''
        phoneInput.placeholder = user.phone_number ? '' : 'Chưa cập nhật'
      }

      const genderSelect = document.getElementById('userGender')
      if (genderSelect) {
        genderSelect.value = user.gender || ''
      }

      const dateInput = document.getElementById('userDateOfBirth')
      if (dateInput) {
        dateInput.value = user.date_of_birth ? formatDateForInput(user.date_of_birth) : ''
      }

    }

    function formatDateForInput(dateString) {
      const date = new Date(dateString)
      if (Number.isNaN(date.getTime())) {
        return ''
      }
      return date.toISOString().split('T')[0]
    }

    function updateUserEditControls() {
      const editBtn = document.getElementById('editUserBtn')
      const cancelBtn = document.getElementById('cancelEditBtn')
      if (!editBtn || !cancelBtn) return

      if (isUserEditMode) {
        editBtn.innerHTML = '<i class="fas fa-save"></i> Lưu thông tin'
        cancelBtn.classList.remove('d-none')
      } else {
        editBtn.innerHTML = '<i class="fas fa-edit"></i> Chỉnh sửa'
        cancelBtn.classList.add('d-none')
      }
    }

    function editUser() {
      if (!selectedUser) {
        showNotification('error', 'Không có dữ liệu người dùng để chỉnh sửa!')
        return
      }

      if (!isUserEditMode) {
        isUserEditMode = true
        setUserFormDisabled(false)
        updateUserEditControls()
        const usernameInput = document.getElementById('userName')
        if (usernameInput) {
          usernameInput.focus()
        }
        return
      }

      saveUserChanges()
    }

    function cancelEditUser() {
      if (!selectedUser) return
      isUserEditMode = false
      setUserFormDisabled(true)
      populateEditableFields(selectedUser)
      updateUserEditControls()
    }

    async function saveUserChanges() {
      if (!selectedUser) return

      const userId = selectedUser._id.toString()
      const username = document.getElementById('userName').value.trim()
      const email = document.getElementById('userEmailDetail').value.trim()
      const phone = document.getElementById('userPhone').value.trim()
      const gender = document.getElementById('userGender').value
      const dateOfBirth = document.getElementById('userDateOfBirth').value

      if (!username) {
        showNotification('error', 'Tên người dùng không được để trống!')
        return
      }

      if (!email) {
        showNotification('error', 'Email không được để trống!')
        return
      }

      const normalizedData = {
        userId,
        username,
        email,
        phoneNumber: phone || null,
        gender: gender || null,
        dateOfBirth: dateOfBirth || null
      }

      try {
        const response = await fetch(AdminApiBreakpoint.UPDATE_USER_MANAGE, {
          method: 'PUT',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify(normalizedData)
        })

        if (response.status === 422) {
          const payload = await response.json()
          let errMess = 'Lỗi validation:\n'
          for (const key in payload.errors) {
            errMess += `${key}: ${payload.errors[key].msg}\n`
          }
          showNotification('error', errMess.trim())
          return
        }

        if (!response.ok) {
          const errorText = await response.text()
          let errorData
          try {
            errorData = JSON.parse(errorText)
          } catch {
            errorData = { message: errorText || `HTTP ${response.status}: ${response.statusText}` }
          }
          throw new Error(errorData.message || `HTTP ${response.status}: ${response.statusText}`)
        }

        const result = await response.json()
        if (result.status !== 200) {
          throw new Error(result.message || 'Có lỗi xảy ra khi cập nhật người dùng!')
        }

        selectedUser = {
          ...selectedUser,
          username,
          email,
          phone_number: phone || null,
          gender: gender || null,
          date_of_birth: dateOfBirth || null,
        }

        const userIndex = usersList.findIndex(
          u => u._id && selectedUser._id && u._id.toString() === selectedUser._id.toString()
        )
        if (userIndex !== -1) {
          usersList[userIndex] = {
            ...usersList[userIndex],
            username,
            email,
            phone_number: phone || null,
            gender: gender || null,
            date_of_birth: dateOfBirth || null,
          }
        }

        populateEditableFields(selectedUser)
        renderUsers(usersList)
        showNotification('success', result.message || 'Đã cập nhật thông tin người dùng thành công!')
        cancelEditUser()
      } catch (error) {
        console.error('Error updating user:', error)
        showNotification('error', error.message || 'Có lỗi xảy ra khi cập nhật người dùng!')
      }
    }

    window.editUser = editUser
    window.cancelEditUser = cancelEditUser

    function showConfirmModal(title, message, callback) {
      if (typeof swal !== 'undefined') {
        swal({
          title: title,
          text: message,
          icon: 'warning',
          buttons: {
            cancel: 'Hủy',
            confirm: 'Xác nhận'
          },
          dangerMode: true
        }).then((willDelete) => {
          if (willDelete) {
            callback()
          }
        })
      } else {
        document.getElementById('confirmModalLabel').textContent = title
        document.getElementById('confirmMessage').textContent = message

        const confirmBtn = document.getElementById('confirmAction')
        confirmBtn.onclick = () => {
          $('#confirmModal').modal('hide')
          callback()
        }

        $('#confirmModal').modal('show')
      }
    }

    function applyFilters() {
      currentPage = 1
      currentFilters.search = document.getElementById('searchInput').value.trim()
      currentFilters.status = document.getElementById('statusFilter').value
      currentFilters.startDate = document.getElementById('startDateFilter').value
      currentFilters.endDate = document.getElementById('endDateFilter').value
      currentFilters.sort = document.getElementById('sortFilter').value
      loadUsers()
    }

    function resetFilters() {
      document.getElementById('searchInput').value = ''
      document.getElementById('statusFilter').value = ''
      document.getElementById('startDateFilter').value = ''
      document.getElementById('endDateFilter').value = ''
      document.getElementById('sortFilter').value = 'desc'
      applyFilters()
    }

    document.getElementById('searchBtn').addEventListener('click', applyFilters)
    document.getElementById('searchInput').addEventListener('keyup', function (e) {
      if (e.key === 'Enter') {
        applyFilters()
      }
    })
    document.getElementById('statusFilter').addEventListener('change', applyFilters)
    document.getElementById('startDateFilter').addEventListener('change', applyFilters)
    document.getElementById('endDateFilter').addEventListener('change', applyFilters)
    document.getElementById('sortFilter').addEventListener('change', applyFilters)
    document.getElementById('resetFilter').addEventListener('click', resetFilters)

    function getStatusText(status) {
      const statusMap = {
        'active': 'Hoạt động',
        'blocked': 'Bị khóa'
      }
      return statusMap[status] || status
    }

    function getStatusClass(status) {
      const classMap = {
        'active': 'badge-success',
        'blocked': 'badge-warning'
      }
      return classMap[status] || 'badge-secondary'
    }

    function showNotification(type, message) {
      if (typeof swal !== 'undefined') {
        swal({
          title: type === 'success' ? 'Thành công!' : type === 'error' ? 'Lỗi!' : 'Thông báo',
          text: message,
          icon: type,
          button: 'OK'
        })
      } else {
        alert(message)
      }
    }

    document.addEventListener('DOMContentLoaded', function () {
      loadUsers()
    })

