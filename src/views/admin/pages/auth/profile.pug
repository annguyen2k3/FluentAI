extends ../../layouts/default.pug

block head
  style.
    .profile__avatar-container {
      text-align: center;
      margin-bottom: 2rem;
    }

    .profile__avatar-wrapper {
      position: relative;
      display: inline-block;
    }

    .profile__avatar {
      width: 150px;
      height: 150px;
      border-radius: 50%;
      object-fit: cover;
      border: 4px solid #e0e0e0;
      cursor: pointer;
      transition: all 0.3s ease;
    }

    .profile__avatar:hover {
      border-color: #177dff;
      opacity: 0.8;
    }

    .profile__avatar-upload {
      position: absolute;
      bottom: 0;
      right: 0;
      background: #177dff;
      color: white;
      border-radius: 50%;
      width: 40px;
      height: 40px;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      border: 3px solid white;
      transition: all 0.3s ease;
    }

    .profile__avatar-upload:hover {
      background: #0056b3;
      transform: scale(1.1);
    }

    .profile__section {
      margin-bottom: 2rem;
    }

    .profile__section-title {
      font-size: 1.25rem;
      font-weight: 600;
      margin-bottom: 1.5rem;
      padding-bottom: 0.75rem;
      border-bottom: 2px solid #e0e0e0;
    }

    .profile__form-group {
      margin-bottom: 1.5rem;
    }

    .profile__password-toggle {
      position: absolute;
      right: 10px;
      top: 50%;
      transform: translateY(-50%);
      background: none;
      border: none;
      color: #6c757d;
      cursor: pointer;
      padding: 5px;
    }

    .profile__password-toggle:hover {
      color: #177dff;
    }

    .profile__input-wrapper {
      position: relative;
    }

block main-content
  div(class="row")
    div(class="col-md-12")
      div(class="card card-round")
        div(class="card-header")
          div(class="card-head-row")
            div(class="card-title")
              i(class="fas fa-user-edit me-2")
              | Cập nhật thông tin cá nhân
        div(class="card-body")
          div(class="profile__avatar-container")
            div(class="profile__avatar-wrapper")
              img(class="profile__avatar" id="avatarPreview" src=admin.avatar alt="Avatar")
              label(for="avatarInput" class="profile__avatar-upload")
                i(class="fas fa-camera")
              input(type="file" id="avatarInput" accept="image/*" style="display: none")
            p(class="text-muted mt-2") Nhấn vào biểu tượng camera để thay đổi ảnh đại diện

          form(id="profileForm" class="profile__section")
            h5(class="profile__section-title")
              i(class="fas fa-info-circle me-2")
              | Thông tin cá nhân
            div(class="row")
              div(class="col-md-6")
                div(class="form-group profile__form-group")
                  label(for="username" class="form-label")
                    i(class="fas fa-user me-2")
                    | Tên tài khoản
                  input(type="text" class="form-control" id="username" name="username" placeholder="Nhập tên tài khoản" value=admin.username required)
              div(class="col-md-6")
                div(class="form-group profile__form-group")
                  label(for="email" class="form-label")
                    i(class="fas fa-envelope me-2")
                    | Email
                  input(type="email" class="form-control" id="email" name="email" placeholder="Nhập email" value=admin.email required)
            div(class="row")
              div(class="col-md-6")
                div(class="form-group profile__form-group")
                  label(for="role" class="form-label")
                    i(class="fas fa-user-shield me-2")
                    | Vai trò
                  - const roleDisplay = admin.role === 'root_admin' ? 'Root Admin' : admin.role
                  input(type="text" class="form-control" id="role" name="role" value=roleDisplay readonly disabled style="background-color: #e9ecef; cursor: not-allowed")
                  small(class="form-text text-muted") Vai trò không thể thay đổi
            div(class="form-group")
              button(type="submit" class="btn btn-primary")
                i(class="fas fa-save me-2")
                | Cập nhật thông tin
              button(type="reset" class="btn btn-secondary ms-2")
                i(class="fas fa-redo me-2")
                | Đặt lại

          hr(class="my-4")

          form(id="passwordForm" class="profile__section")
            h5(class="profile__section-title")
              i(class="fas fa-lock me-2")
              | Thay đổi mật khẩu
            div(class="row")
              div(class="col-md-12")
                div(class="form-group profile__form-group")
                  label(for="currentPassword" class="form-label")
                    i(class="fas fa-key me-2")
                    | Mật khẩu hiện tại
                  div(class="profile__input-wrapper")
                    input(type="password" class="form-control" id="currentPassword" name="currentPassword" placeholder="Nhập mật khẩu hiện tại" required)
                    button(type="button" class="profile__password-toggle" onclick="togglePassword('currentPassword')")
                      i(class="fas fa-eye" id="currentPasswordIcon")
            div(class="row")
              div(class="col-md-6")
                div(class="form-group profile__form-group")
                  label(for="newPassword" class="form-label")
                    i(class="fas fa-lock me-2")
                    | Mật khẩu mới
                  div(class="profile__input-wrapper")
                    input(type="password" class="form-control" id="newPassword" name="newPassword" placeholder="Nhập mật khẩu mới" required minlength="6")
                    button(type="button" class="profile__password-toggle" onclick="togglePassword('newPassword')")
                      i(class="fas fa-eye" id="newPasswordIcon")
              div(class="col-md-6")
                div(class="form-group profile__form-group")
                  label(for="confirmPassword" class="form-label")
                    i(class="fas fa-lock me-2")
                    | Xác nhận mật khẩu mới
                  div(class="profile__input-wrapper")
                    input(type="password" class="form-control" id="confirmPassword" name="confirmPassword" placeholder="Nhập lại mật khẩu mới" required minlength="6")
                    button(type="button" class="profile__password-toggle" onclick="togglePassword('confirmPassword')")
                      i(class="fas fa-eye" id="confirmPasswordIcon")
            div(class="form-group")
              button(type="submit" class="btn btn-warning")
                i(class="fas fa-key me-2")
                | Thay đổi mật khẩu

block scripts
  script.
    const originalAvatar = !{JSON.stringify(admin.avatar)}

    function togglePassword(inputId) {
      const input = document.getElementById(inputId)
      const icon = document.getElementById(inputId + 'Icon')
      if (input.type === 'password') {
        input.type = 'text'
        icon.classList.remove('fa-eye')
        icon.classList.add('fa-eye-slash')
      } else {
        input.type = 'password'
        icon.classList.remove('fa-eye-slash')
        icon.classList.add('fa-eye')
      }
    }

    document.getElementById('avatarInput').addEventListener('change', function (e) {
      const file = e.target.files[0]
      if (file) {
        if (!file.type.startsWith('image/')) {
          swal({
            title: 'Lỗi',
            text: 'Vui lòng chọn một file ảnh hợp lệ',
            icon: 'error',
            button: 'Đóng'
          })
          document.getElementById('avatarInput').value = ''
          return
        }

        if (file.size > 5 * 1024 * 1024) {
          swal({
            title: 'Lỗi',
            text: 'Kích thước file không được vượt quá 5MB',
            icon: 'error',
            button: 'Đóng'
          })
          document.getElementById('avatarInput').value = ''
          return
        }

        const reader = new FileReader()
        reader.onload = function (e) {
          document.getElementById('avatarPreview').src = e.target.result
        }
        reader.readAsDataURL(file)

        const formData = new FormData()
        formData.append('images', file)

        swal({
          title: 'Đang tải lên...',
          text: 'Vui lòng chờ',
          icon: 'info',
          button: false,
          closeOnClickOutside: false
        })

        fetch('/admin/auth/profile/avatar', {
          method: 'PATCH',
          body: formData
        })
          .then((response) => response.json())
          .then((data) => {
            if (data.status === 200) {
              document.getElementById('avatarPreview').src = data.avatar_url
              swal({
                title: 'Thành công!',
                text: data.message || 'Cập nhật ảnh đại diện thành công',
                icon: 'success',
                button: 'Đóng',
                timer: 2000
              })
            } else {
              swal({
                title: 'Lỗi',
                text: data.message || 'Có lỗi xảy ra khi cập nhật ảnh đại diện',
                icon: 'error',
                button: 'Đóng'
              })
              document.getElementById('avatarInput').value = ''
              document.getElementById('avatarPreview').src = originalAvatar
            }
          })
          .catch((error) => {
            swal({
              title: 'Lỗi Server',
              text: 'Có lỗi xảy ra: ' + error.message,
              icon: 'error',
              button: 'Đóng'
            })
            document.getElementById('avatarInput').value = ''
            document.getElementById('avatarPreview').src = originalAvatar
          })
      }
    })

    document.getElementById('profileForm').addEventListener('submit', function (e) {
      e.preventDefault()
      const formData = {
        username: document.getElementById('username').value,
        email: document.getElementById('email').value
      }
      submitProfileUpdate(formData)
    })

    function submitProfileUpdate(formData) {
      swal({
        title: 'Đang cập nhật...',
        text: 'Vui lòng chờ',
        icon: 'info',
        button: false,
        closeOnClickOutside: false
      })

      setTimeout(function () {
        swal({
          title: 'Thành công!',
          text: 'Thông tin đã được cập nhật',
          icon: 'success',
          button: 'Đóng'
        })
      }, 1500)
    }

    document.getElementById('passwordForm').addEventListener('submit', function (e) {
      e.preventDefault()
      const currentPassword = document.getElementById('currentPassword').value
      const newPassword = document.getElementById('newPassword').value
      const confirmPassword = document.getElementById('confirmPassword').value

      if (newPassword.length < 6) {
        swal({
          title: 'Lỗi',
          text: 'Mật khẩu mới phải có ít nhất 6 ký tự',
          icon: 'error',
          button: 'Đóng'
        })
        return
      }

      if (newPassword !== confirmPassword) {
        swal({
          title: 'Lỗi',
          text: 'Mật khẩu mới và xác nhận mật khẩu không khớp',
          icon: 'error',
          button: 'Đóng'
        })
        return
      }

      if (currentPassword === newPassword) {
        swal({
          title: 'Lỗi',
          text: 'Mật khẩu mới phải khác mật khẩu hiện tại',
          icon: 'error',
          button: 'Đóng'
        })
        return
      }

      swal({
        title: 'Đang thay đổi mật khẩu...',
        text: 'Vui lòng chờ',
        icon: 'info',
        button: false,
        closeOnClickOutside: false
      })

      setTimeout(function () {
        swal({
          title: 'Thành công!',
          text: 'Mật khẩu đã được thay đổi',
          icon: 'success',
          button: 'Đóng'
        })
        document.getElementById('passwordForm').reset()
      }, 1500)
    })

