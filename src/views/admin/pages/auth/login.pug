doctype html
html(lang="vi")
  head
    meta(http-equiv="X-UA-Compatible" content="IE=edge")
    title Fadmin - Đăng nhập
    meta(content="width=device-width, initial-scale=1.0" name="viewport")
    link(rel="icon" href="/admin/assets/img/kaiadmin/favicon.ico" type="image/x-icon")
    script(src="/admin/assets/js/plugin/webfont/webfont.min.js")
    script.
      WebFont.load({
        google: { families: ['Public Sans:300,400,500,600,700'] },
        custom: {
          families: [
            'Font Awesome 5 Solid',
            'Font Awesome 5 Regular',
            'Font Awesome 5 Brands',
            'simple-line-icons'
          ],
          urls: ['/admin/assets/css/fonts.min.css']
        },
        active: function () {
          sessionStorage.fonts = true
        }
      })
    link(rel="stylesheet" href="/admin/assets/css/bootstrap.min.css")
    link(rel="stylesheet" href="/admin/assets/css/plugins.min.css")
    link(rel="stylesheet" href="/admin/assets/css/kaiadmin.min.css")
    link(rel="stylesheet" href="/admin/assets/css/demo.css")
    link(rel="stylesheet" href="/admin/assets/css/my-custom.css")
  body(class="login-page__body")
    div(class="login-page__container")
      div(class="login-page__wrapper")
        div(class="login-page__card card card-round")
          div(class="login-page__header")
            div(class="login-page__logo")
              span(class="navbar-brand fw-bold") Fadmin
            h2(class="login-page__title") Đăng nhập Admin
            p(class="login-page__subtitle") Vui lòng nhập thông tin đăng nhập của bạn
          div(class="login-page__body")
            form(id="loginForm" class="login-page__form")
              div(class="form-group login-page__form-group")
                label(class="form-label login-page__label" for="username")
                  i(class="fas fa-user me-2")
                  | Tên tài khoản
                div(class="input-icon")
                  span(class="input-icon-addon")
                    i(class="fa fa-user")
                  input(id="username" class="form-control login-page__input" type="text" name="username" placeholder="Nhập tên tài khoản" required autocomplete="username")
              div(class="form-group login-page__form-group")
                label(class="form-label login-page__label" for="password")
                  i(class="fas fa-lock me-2")
                  | Mật khẩu
                div(class="input-icon")
                  span(class="input-icon-addon")
                    i(class="fa fa-lock")
                  input(id="password" class="form-control login-page__input" type="password" name="password" placeholder="Nhập mật khẩu" required autocomplete="current-password")
              div(class="form-group login-page__form-group")
                button(class="btn btn-primary btn-block login-page__button" type="submit")
                  i(class="fas fa-sign-in-alt me-2")
                  | Đăng nhập
    script(src="/admin/assets/js/core/jquery-3.7.1.min.js")
    script(src="/admin/assets/js/core/popper.min.js")
    script(src="/admin/assets/js/core/bootstrap.min.js")
    script(src="/admin/assets/js/plugin/sweetalert/sweetalert.min.js")
    script(src="/admin/assets/js/kaiadmin.min.js")
    script(type="module").
      import { AdminApiBreakpoint } from '/js/api_breakpoint.js'
      document.getElementById('loginForm').addEventListener('submit', function (e) {
        e.preventDefault()
        const username = document.getElementById('username').value
        const password = document.getElementById('password').value

        console.log(username, password)
        if (!username || !password) {
          swal({
            title: 'Lỗi',
            text: 'Vui lòng nhập đầy đủ thông tin',
            icon: 'error',
            button: 'Đóng'
          })
          return
        }

        fetch(AdminApiBreakpoint.LOGIN, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            Accept: 'application/json'
          },
          body: JSON.stringify({ username, password })
        })
          .then(response => response.json())
          .then(data => {
            if (data.status === 200) {
             swal({
                title: 'Đang đăng nhập...',
                text: 'Vui lòng chờ',
                icon: 'info',
                button: false,
                closeOnClickOutside: false
                })
                setTimeout(function () {
                    window.location.href = `#{prefixAdmin}/dashboard`
                }, 1000)
            } else {
              swal({
                title: 'Lỗi',
                text: data.message,
                icon: 'error',
                button: 'Đóng'
              })
            }
          })
          .catch(error => console.error('Error:', error))
        
      })

