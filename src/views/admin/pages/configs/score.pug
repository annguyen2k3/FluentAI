extends ../../layouts/default.pug

block main-content
  div(class="page-header")
    ul(class="breadcrumbs")
      li(class="nav-home")
        a(href=`${prefixAdmin}/dashboard`)
          i(class="fas fa-home")
      li(class="separator")
        i(class="fas fa-angle-right")
      li(class="nav-item")
        a(href="#") Cấu hình hệ thống
      li(class="separator")
        i(class="fas fa-angle-right")
      li(class="nav-item")
        a(href="#") Điểm số học tập

  div(class="row")
    div(class="col-md-12")
      div(class="card")
        div(class="card-header d-flex align-items-center justify-content-between")
          div
            h4(class="card-title mb-0") Cấu hình điểm thưởng theo hoạt động tháng
            small(class="text-muted") Điểm được cộng cho từng loại bài luyện tập
          div(class="btn-group")
            button(type="button" class="btn btn-outline-secondary" id="scoreRefreshBtn")
              i(class="fas fa-sync-alt me-1")
              |  Tải lại
            button(type="button" class="btn btn-primary" id="scoreEditBtn")
              i(class="fas fa-edit me-1")
              |  Chỉnh sửa
            button(type="button" class="btn btn-success d-none" id="scoreSaveBtn")
              i(class="fas fa-save me-1")
              |  Lưu
            button(type="button" class="btn btn-outline-secondary d-none" id="scoreCancelBtn")
              i(class="fas fa-times me-1")
              |  Hủy
        div(class="card-body")
          div(class="table-responsive mt-3")
            table(class="table table-striped align-middle")
              thead
                tr
                  th(style="width: 60px;") #
                  th Hoạt động
                  th(style="width: 160px;") Điểm thưởng
                  th Mô tả
              tbody(id="scoreTableBody")
                tr
                  td(colspan="4" class="text-center py-4 text-muted") Đang tải cấu hình...
          div(class="d-flex justify-content-start align-items-center mt-3 flex-wrap gap-4")
            div(class="text-muted small d-flex align-items-center gap-2")
              span ID cấu hình: 
              span(id="scoreConfigId" class="fw-semibold") -
            div(class="text-muted small d-flex align-items-center gap-2")
              i(class="far fa-clock text-info")
              span Lần cập nhật:
              span(class="fw-semibold" id="scoreUpdatedAt") -
            div(class="text-muted small d-flex align-items-center gap-2")
              i(class="fas fa-user-shield text-success")
              span Người cập nhật:
              span(class="fw-semibold" id="scoreUpdatedBy") -

  // Note: thông tin cập nhật đã được đưa lên cùng khu vực ID cấu hình phía trên

block head
  style.
    .score-config__info-item {
      padding: 0.75rem 0;
      border-bottom: 1px solid #e9ecef;
    }

block scripts
  script(type="module").
    import { AdminApiBreakpoint } from '/js/api_breakpoint.js'

    const prefixAdmin = '#{prefixAdmin}'
    const configData = !{JSON.stringify(config || null)}
    const adminUpdateConfigScore = !{JSON.stringify(adminUpdateConfigScore || null)}
    const scoreTypeLabels = {
      writing_sentence: 'Viết câu',
      writing_paragraph: 'Viết đoạn',
      speaking_sentence: 'Nói câu',
      speaking_shadowing: 'Nói shadowing',
      listening_video: 'Nghe video'
    }
    const state = {
      parameters: [],
      original: [],
      isEditing: false,
      meta: {
        create_at: null,
        update_at: null,
        updated_by: null,
        _id: null
      }
    }

    function initState() {
      const parameters = Array.isArray(configData?.config?.parameters) ? configData.config.parameters : []
      state.parameters = parameters.map(item => ({
        _id: item._id,
        type: item.type,
        score: Number(item.score) || 0,
        description: item.description || ''
      }))
      state.original = JSON.parse(JSON.stringify(state.parameters))
      state.meta = {
        create_at: configData?.config?.create_at || configData?.create_at || null,
        update_at: configData?.config?.update_at || configData?.update_at || null,
        updated_by: configData?.config?.updated_by || configData?.updated_by || null,
        _id: configData?._id || null
      }
    }

    function formatDate(value) {
      if (!value) return '-'
      const date = new Date(value)
      if (Number.isNaN(date.getTime())) return '-'
      return date.toLocaleString('vi-VN')
    }

    function renderMeta() {
      const updatedAtEl = document.getElementById('scoreUpdatedAt')
      if (updatedAtEl) {
        updatedAtEl.textContent = formatDate(state.meta.update_at)
      }

      let updatedByText = 'Mặc định'
      if (adminUpdateConfigScore && adminUpdateConfigScore.username) {
        const username = adminUpdateConfigScore.username
        const role = adminUpdateConfigScore.role || 'root_admin'
        updatedByText = `${username} - ${role}`
      }
      const updatedByEl = document.getElementById('scoreUpdatedBy')
      if (updatedByEl) {
        updatedByEl.textContent = updatedByText
      }

      const configIdEl = document.getElementById('scoreConfigId')
      if (configIdEl) {
        configIdEl.textContent = state.meta._id || '-'
      }
    }

    function renderTable() {
      const tbody = document.getElementById('scoreTableBody')
      if (!tbody) return
      if (!state.parameters.length) {
        tbody.innerHTML = '<tr><td colspan="4" class="text-center py-4 text-muted">Không có cấu hình nào</td></tr>'
        return
      }
      const rows = state.parameters
        .map((item, index) => {
          const typeLabel = scoreTypeLabels[item.type] || item.type
          return `
            <tr data-id="${item._id}">
              <td>${index + 1}</td>
              <td>
                <div class="d-flex flex-column">
                  <span class="fw-semibold">${typeLabel}</span>
                  <span class="text-muted small">${item.type}</span>
                </div>
              </td>
              <td>
                <input 
                  type="number" 
                  class="form-control form-control-sm score-config__score-input" 
                  value="${item.score}" 
                  min="0" 
                  data-index="${index}" 
                  ${state.isEditing ? '' : 'disabled'}
                >
              </td>
              <td>
                <input 
                  type="text" 
                  class="form-control form-control-sm score-config__description-input" 
                  value="${item.description || ''}" 
                  placeholder="Mô tả (không bắt buộc)" 
                  data-index="${index}" 
                  ${state.isEditing ? '' : 'disabled'}
                >
              </td>
            </tr>
          `
        })
        .join('')
      tbody.innerHTML = rows
    }

    function setEditingMode(isEditing) {
      state.isEditing = isEditing
      const editBtn = document.getElementById('scoreEditBtn')
      const saveBtn = document.getElementById('scoreSaveBtn')
      const cancelBtn = document.getElementById('scoreCancelBtn')
      if (editBtn) editBtn.classList.toggle('d-none', isEditing)
      if (saveBtn) saveBtn.classList.toggle('d-none', !isEditing)
      if (cancelBtn) cancelBtn.classList.toggle('d-none', !isEditing)
      renderTable()
    }

    function handleInputChange(event) {
      const target = event.target
      if (!target.dataset.index) return
      const index = Number(target.dataset.index)
      if (Number.isNaN(index) || !state.parameters[index]) return
      if (target.classList.contains('score-config__score-input')) {
        state.parameters[index].score = Number(target.value) || 0
      }
      if (target.classList.contains('score-config__description-input')) {
        state.parameters[index].description = target.value
      }
    }

    function attachEvents() {
      const editBtn = document.getElementById('scoreEditBtn')
      const saveBtn = document.getElementById('scoreSaveBtn')
      const cancelBtn = document.getElementById('scoreCancelBtn')
      const refreshBtn = document.getElementById('scoreRefreshBtn')
      const table = document.getElementById('scoreTableBody')

      if (editBtn) {
        editBtn.addEventListener('click', () => setEditingMode(true))
      }
      if (cancelBtn) {
        cancelBtn.addEventListener('click', () => {
          state.parameters = JSON.parse(JSON.stringify(state.original))
          setEditingMode(false)
          renderMeta()
        })
      }
      if (saveBtn) {
        saveBtn.addEventListener('click', async () => {
          const scoreData = {}
          state.parameters.forEach(item => {
            scoreData[item.type] = Number(item.score) || 0
          })

          const saveBtnEl = document.getElementById('scoreSaveBtn')
          const originalText = saveBtnEl.innerHTML
          saveBtnEl.disabled = true
          saveBtnEl.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i> Đang lưu...'

          try {
            const response = await fetch(AdminApiBreakpoint.UPDATE_SCORE, {
              method: 'PUT',
              headers: {
                'Content-Type': 'application/json'
              },
              credentials: 'same-origin',
              body: JSON.stringify(scoreData)
            })

            let result
            try {
              result = await response.json()
            } catch (e) {
              const text = await response.text()
              throw new Error(text || `HTTP ${response.status}: ${response.statusText}`)
            }

            if (!response.ok) {
              throw new Error(result.message || 'Có lỗi xảy ra khi cập nhật cấu hình')
            }

            showNotification('success', result.message || 'Cập nhật cấu hình điểm số thành công!')
            setEditingMode(false)
            state.original = JSON.parse(JSON.stringify(state.parameters))
            setTimeout(() => {
              window.location.reload()
            }, 1500)
          } catch (error) {
            console.error('Error updating config:', error)
            showNotification('error', error.message || 'Có lỗi xảy ra khi cập nhật cấu hình')
            saveBtnEl.disabled = false
            saveBtnEl.innerHTML = originalText
          }
        })
      }
      if (refreshBtn) {
        refreshBtn.addEventListener('click', () => {
          window.location.reload()
        })
      }
      if (table) {
        table.addEventListener('input', handleInputChange)
      }
    }

    function showNotification(type, message) {
      if (typeof swal !== 'undefined') {
        swal({
          title: type === 'success' ? 'Thành công!' : type === 'error' ? 'Lỗi!' : 'Thông báo',
          text: message,
          icon: type,
          button: 'OK'
        })
      } else {
        alert(message)
      }
    }

    document.addEventListener('DOMContentLoaded', () => {
      initState()
      renderMeta()
      renderTable()
      attachEvents()
    })

