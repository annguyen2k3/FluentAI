extends ../../layouts/default.pug

block main-content
  div(class="page-header")
    ul(class="breadcrumbs")
      li(class="nav-home")
        a(href=`${prefixAdmin}/dashboard`)
          i(class="fas fa-home")
      li(class="separator")
        i(class="fas fa-angle-right")
      li(class="nav-item")
        a(href="#") Cấu hình hệ thống
      li(class="separator")
        i(class="fas fa-angle-right")
      li(class="nav-item")
        a(href="#") Thông tin website

  div(class="row")
    div(class="col-md-12")
      div(class="card")
        div(class="card-header d-flex align-items-center justify-content-between")
          div
            h4(class="card-title mb-0") Cấu hình thông tin website
            small(class="text-muted") Quản lý thông tin cá nhân của website
          div(class="btn-group")
            button(type="button" class="btn btn-outline-secondary" id="infoWebsiteRefreshBtn")
              i(class="fas fa-sync-alt me-1")
              |  Tải lại
            button(type="button" class="btn btn-primary" id="infoWebsiteEditBtn")
              i(class="fas fa-edit me-1")
              |  Chỉnh sửa
            button(type="button" class="btn btn-success d-none" id="infoWebsiteSaveBtn")
              i(class="fas fa-save me-1")
              |  Lưu thay đổi
            button(type="button" class="btn btn-outline-secondary d-none" id="infoWebsiteCancelBtn")
              i(class="fas fa-times me-1")
              |  Hủy
        div(class="card-body")
          form(id="infoWebsiteForm")
            div(class="row mb-3")
              div(class="col-md-3")
                label(class="form-label fw-semibold") Tên website
              div(class="col-md-9")
                input(type="text" class="form-control" id="infoWebsiteName" name="name" placeholder="Nhập tên website" required disabled)
            
            div(class="row mb-3")
              div(class="col-md-3")
                label(class="form-label fw-semibold") Mô tả
              div(class="col-md-9")
                textarea(class="form-control" id="infoWebsiteDescription" name="description" rows="4" placeholder="Nhập mô tả website" required disabled)
            
            div(class="row mb-3")
              div(class="col-md-3")
                label(class="form-label fw-semibold") URL Logo
              div(class="col-md-9")
                div(class="info-website__logo-container")
                  div(class="mb-2")
                    input(type="text" class="form-control" id="infoWebsiteLogoUrl" name="url_logo" placeholder="/img/logo_rmbg.png" required disabled)
                  div(class="info-website__logo-preview")
                    img(id="infoWebsiteLogoPreview" src="" alt="Logo preview" class="info-website__logo-img")
                    div(id="infoWebsiteLogoPlaceholder" class="info-website__logo-placeholder")
                      i(class="fas fa-image")
                      span(class="ms-2") Chưa có ảnh
            
            div(class="row mb-3")
              div(class="col-md-3")
                label(class="form-label fw-semibold") Số điện thoại
              div(class="col-md-9")
                input(type="text" class="form-control" id="infoWebsitePhone" name="phone_number" placeholder="Nhập số điện thoại" required disabled)
            
            div(class="row mb-3")
              div(class="col-md-3")
                label(class="form-label fw-semibold") Email
              div(class="col-md-9")
                input(type="email" class="form-control" id="infoWebsiteEmail" name="email" placeholder="Nhập email" required disabled)
            
            div(class="row mb-3")
              div(class="col-md-3")
                label(class="form-label fw-semibold") Địa chỉ
              div(class="col-md-9")
                input(type="text" class="form-control" id="infoWebsiteAddress" name="address" placeholder="Nhập địa chỉ" required disabled)
          
          div(class="card-footer")
            div(class="d-flex justify-content-start align-items-center flex-wrap gap-4")
              div(class="text-muted small d-flex align-items-center gap-2")
                i(class="far fa-clock text-info")
                span Lần cập nhật:
                span(class="fw-semibold" id="infoWebsiteUpdatedAt") -

block head
  style.
    .info-website__logo-container {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }
    .info-website__logo-preview {
      width: 100%;
      max-width: 300px;
      height: 200px;
      border: 2px dashed #dee2e6;
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      background-color: #f8f9fa;
      overflow: hidden;
      position: relative;
    }
    .info-website__logo-img {
      max-width: 100%;
      max-height: 100%;
      object-fit: contain;
      display: none;
    }
    .info-website__logo-img.info-website__logo-img--visible {
      display: block;
    }
    .info-website__logo-placeholder {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      color: #6c757d;
      font-size: 0.9rem;
    }
    .info-website__logo-placeholder i {
      font-size: 2rem;
      margin-bottom: 0.5rem;
    }
    .info-website__logo-placeholder.info-website__logo-placeholder--hidden {
      display: none;
    }

block scripts
  script(type="module").
    import { AdminApiBreakpoint } from '/js/api_breakpoint.js'

    const prefixAdmin = '#{prefixAdmin}'
    const infoWebsiteData = !{JSON.stringify(infoWebsite || null)}

    const state = {
      original: null,
      current: {
        name: '',
        description: '',
        url_logo: '',
        phone_number: '',
        email: '',
        address: ''
      },
      isEditing: false
    }

    function initState() {
      if (infoWebsiteData) {
        state.original = {
          name: infoWebsiteData.name || '',
          description: infoWebsiteData.description || '',
          url_logo: infoWebsiteData.url_logo || '',
          phone_number: infoWebsiteData.phone_number || '',
          email: infoWebsiteData.email || '',
          address: infoWebsiteData.address || ''
        }
        state.current = JSON.parse(JSON.stringify(state.original))
      }
      populateForm()
      updateLogoPreview()
      updateTimestamp()
    }

    function formatDate(value) {
      if (!value) return '-'
      const date = new Date(value)
      if (Number.isNaN(date.getTime())) return '-'
      return date.toLocaleString('vi-VN', {
        year: 'numeric',
        month: '2-digit',
        day: '2-digit',
        hour: '2-digit',
        minute: '2-digit',
        second: '2-digit'
      })
    }

    function updateTimestamp() {
      const updatedAtEl = document.getElementById('infoWebsiteUpdatedAt')
      if (updatedAtEl && infoWebsiteData && infoWebsiteData.update_at) {
        updatedAtEl.textContent = formatDate(infoWebsiteData.update_at)
      }
    }

    function populateForm() {
      document.getElementById('infoWebsiteName').value = state.current.name
      document.getElementById('infoWebsiteDescription').value = state.current.description
      document.getElementById('infoWebsiteLogoUrl').value = state.current.url_logo
      document.getElementById('infoWebsitePhone').value = state.current.phone_number
      document.getElementById('infoWebsiteEmail').value = state.current.email
      document.getElementById('infoWebsiteAddress').value = state.current.address
    }

    function updateLogoPreview() {
      const logoUrl = document.getElementById('infoWebsiteLogoUrl').value.trim()
      const previewImg = document.getElementById('infoWebsiteLogoPreview')
      const placeholder = document.getElementById('infoWebsiteLogoPlaceholder')

      if (logoUrl) {
        previewImg.src = logoUrl
        previewImg.onload = function() {
          previewImg.classList.add('info-website__logo-img--visible')
          placeholder.classList.add('info-website__logo-placeholder--hidden')
        }
        previewImg.onerror = function() {
          previewImg.classList.remove('info-website__logo-img--visible')
          placeholder.classList.remove('info-website__logo-placeholder--hidden')
        }
      } else {
        previewImg.classList.remove('info-website__logo-img--visible')
        placeholder.classList.remove('info-website__logo-placeholder--hidden')
      }
    }

    function setEditingMode(isEditing) {
      state.isEditing = isEditing
      const editBtn = document.getElementById('infoWebsiteEditBtn')
      const saveBtn = document.getElementById('infoWebsiteSaveBtn')
      const cancelBtn = document.getElementById('infoWebsiteCancelBtn')
      const inputs = [
        'infoWebsiteName',
        'infoWebsiteDescription',
        'infoWebsiteLogoUrl',
        'infoWebsitePhone',
        'infoWebsiteEmail',
        'infoWebsiteAddress'
      ]

      inputs.forEach(id => {
        const input = document.getElementById(id)
        if (input) {
          input.disabled = !isEditing
        }
      })

      if (editBtn) editBtn.classList.toggle('d-none', isEditing)
      if (saveBtn) saveBtn.classList.toggle('d-none', !isEditing)
      if (cancelBtn) cancelBtn.classList.toggle('d-none', !isEditing)
    }

    function attachEvents() {
      const form = document.getElementById('infoWebsiteForm')
      const editBtn = document.getElementById('infoWebsiteEditBtn')
      const saveBtn = document.getElementById('infoWebsiteSaveBtn')
      const cancelBtn = document.getElementById('infoWebsiteCancelBtn')
      const refreshBtn = document.getElementById('infoWebsiteRefreshBtn')
      const logoUrlInput = document.getElementById('infoWebsiteLogoUrl')

      if (logoUrlInput) {
        logoUrlInput.addEventListener('input', updateLogoPreview)
        logoUrlInput.addEventListener('change', updateLogoPreview)
      }

      if (form) {
        form.addEventListener('submit', async (e) => {
          e.preventDefault()
          if (state.isEditing) {
            await saveInfoWebsite()
          }
        })
      }

      if (editBtn) {
        editBtn.addEventListener('click', () => {
          setEditingMode(true)
        })
      }

      if (cancelBtn) {
        cancelBtn.addEventListener('click', () => {
          if (state.original) {
            state.current = JSON.parse(JSON.stringify(state.original))
            populateForm()
            updateLogoPreview()
          }
          setEditingMode(false)
        })
      }

      if (saveBtn) {
        saveBtn.addEventListener('click', async () => {
          await saveInfoWebsite()
        })
      }

      if (refreshBtn) {
        refreshBtn.addEventListener('click', () => {
          window.location.reload()
        })
      }
    }

    async function saveInfoWebsite() {
      const name = document.getElementById('infoWebsiteName').value.trim()
      const description = document.getElementById('infoWebsiteDescription').value.trim()
      const url_logo = document.getElementById('infoWebsiteLogoUrl').value.trim()
      const phone_number = document.getElementById('infoWebsitePhone').value.trim()
      const email = document.getElementById('infoWebsiteEmail').value.trim()
      const address = document.getElementById('infoWebsiteAddress').value.trim()

      if (!name || !description || !url_logo || !phone_number || !email || !address) {
        showNotification('error', 'Vui lòng điền đầy đủ thông tin!')
        return
      }

      const confirmed = await showConfirmDialog(
        'Xác nhận lưu',
        'Bạn có chắc chắn muốn lưu các thay đổi này?'
      )

      if (!confirmed) {
        return
      }

      const saveBtn = document.getElementById('infoWebsiteSaveBtn')
      const originalText = saveBtn.innerHTML
      saveBtn.disabled = true
      saveBtn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i> Đang lưu...'

      try {
        const response = await fetch(AdminApiBreakpoint.UPDATE_INFO_WEBSITE, {
          method: 'PUT',
          headers: {
            'Content-Type': 'application/json'
          },
          credentials: 'same-origin',
          body: JSON.stringify({
            name,
            description,
            url_logo,
            phone_number,
            email,
            address
          })
        })

        let result
        try {
          result = await response.json()
        } catch (e) {
          const text = await response.text()
          throw new Error(text || `HTTP ${response.status}: ${response.statusText}`)
        }

        if (!response.ok) {
          throw new Error(result.message || 'Có lỗi xảy ra khi cập nhật thông tin website')
        }

        showNotification('success', result.message || 'Cập nhật thông tin website thành công!')
        state.original = {
          name,
          description,
          url_logo,
          phone_number,
          email,
          address
        }
        state.current = JSON.parse(JSON.stringify(state.original))
        setEditingMode(false)
        const updatedAtEl = document.getElementById('infoWebsiteUpdatedAt')
        if (updatedAtEl) {
          updatedAtEl.textContent = formatDate(new Date())
        }
        setTimeout(() => {
          window.location.reload()
        }, 1500)
      } catch (error) {
        console.error('Error updating info website:', error)
        showNotification('error', error.message || 'Có lỗi xảy ra khi cập nhật thông tin website')
        saveBtn.disabled = false
        saveBtn.innerHTML = originalText
      }
    }

    function showConfirmDialog(title, message) {
      return new Promise((resolve) => {
        if (typeof swal !== 'undefined') {
          swal({
            title: title,
            text: message,
            icon: 'warning',
            buttons: {
              cancel: 'Hủy',
              confirm: 'Xác nhận'
            },
            dangerMode: true
          }).then((willConfirm) => {
            resolve(willConfirm || false)
          })
        } else {
          const confirmed = confirm(`${title}\n${message}`)
          resolve(confirmed)
        }
      })
    }

    function showNotification(type, message) {
      if (typeof swal !== 'undefined') {
        swal({
          title: type === 'success' ? 'Thành công!' : type === 'error' ? 'Lỗi!' : 'Thông báo',
          text: message,
          icon: type,
          button: 'OK'
        })
      } else {
        alert(message)
      }
    }

    document.addEventListener('DOMContentLoaded', () => {
      initState()
      setEditingMode(false)
      attachEvents()
    })

