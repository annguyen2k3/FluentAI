extends ../layouts/default.pug

block main-content
  div(class="row mb-4 dashboard__row")
    div(class="col-md-3 dashboard__col dashboard__col--quarter")
      a(class="dashboard-summary__badge-link" href=`${prefixAdmin}/statistics-reporting/users-overview`)
        div(class="card card-stats card-round dashboard__card")
          div(class="card-body dashboard__card-body")
            div(class="row align-items-center dashboard__stats-row")
              div(class="col-icon dashboard__stats-icon")
                div(class="icon-big text-center icon-primary bubble-shadow-small")
                  i(class="fas fa-user-plus")
              div(class="col col-stats ms-3 dashboard__stats-content")
                div(class="numbers")
                  p(class="card-category") Người dùng mới hôm nay
                  h4(class="card-title") #{(dashboardSummary && dashboardSummary.newUsersToday) || 0}
    div(class="col-md-3 dashboard__col dashboard__col--quarter")
      a(class="dashboard-summary__badge-link" href=`${prefixAdmin}/statistics-reporting/users-score`)
        div(class="card card-stats card-round dashboard__card")
          div(class="card-body dashboard__card-body")
            div(class="row align-items-center dashboard__stats-row")
              div(class="col-icon dashboard__stats-icon")
                div(class="icon-big text-center icon-success bubble-shadow-small")
                  i(class="fas fa-chart-line")
              div(class="col col-stats ms-3 dashboard__stats-content")
                div(class="numbers")
                  p(class="card-category") Điểm luyện tập hôm nay
                  h4(class="card-title") #{(dashboardSummary && dashboardSummary.usersScoreToday) || 0}
    div(class="col-md-3 dashboard__col dashboard__col--quarter")
      a(class="dashboard-summary__badge-link" href=`${prefixAdmin}/statistics-reporting/revenue`)
        div(class="card card-stats card-round dashboard__card")
          div(class="card-body dashboard__card-body")
            div(class="row align-items-center dashboard__stats-row")
              div(class="col-icon dashboard__stats-icon")
                div(class="icon-big text-center icon-warning bubble-shadow-small")
                  i(class="fas fa-dollar-sign")
              div(class="col col-stats ms-3 dashboard__stats-content")
                div(class="numbers")
                  p(class="card-category") Doanh thu hôm nay
                  h4(class="card-title") #{(dashboardSummary && dashboardSummary.revenueToday) || 0}
    div(class="col-md-3 dashboard__col dashboard__col--quarter")
      a(class="dashboard-summary__badge-link" href=`${prefixAdmin}/statistics-reporting/google-api`)
        div(class="card card-stats card-round dashboard__card")
          div(class="card-body dashboard__card-body")
            div(class="row align-items-center dashboard__stats-row")
              div(class="col-icon dashboard__stats-icon")
                div(class="icon-big text-center icon-info bubble-shadow-small")
                  i(class="fas fa-robot")
              div(class="col col-stats ms-3 dashboard__stats-content")
                div(class="numbers")
                  p(class="card-category") Lượt sử dụng API hôm nay (200)
                  h4(class="card-title") #{(dashboardSummary && dashboardSummary.apiSuccessToday) || 0}

  div(class="row")
    div(class="col-md-6")
      div(class="card card-round")
        div(class="card-header")
          div(class="card-head-row align-items-center")
            div(class="card-title") Người dùng mới 7 ngày gần nhất
            div(class="card-tools")
              a(class="btn btn-sm btn-primary" href=`${prefixAdmin}/statistics-reporting/users-overview`)
                span Xem chi tiết
        div(class="card-body")
          div(class="chart-container" style="min-height: 300px")
            canvas(id="dashboardNewUsersChart")
    div(class="col-md-6")
      div(class="card card-round")
        div(class="card-header")
          div(class="card-head-row align-items-center")
            div(class="card-title") Lượt sử dụng API (200) 7 ngày gần nhất
            div(class="card-tools")
              a(class="btn btn-sm btn-primary" href=`${prefixAdmin}/statistics-reporting/google-api`)
                span Xem chi tiết
        div(class="card-body")
          div(class="chart-container" style="min-height: 300px")
            canvas(id="dashboardApiUsageChart")

block scripts
  script.
    const dashboardNewUsersData = !{JSON.stringify(newUsersChart || { labels: [], data: [] })}
    const dashboardApiUsageData = !{JSON.stringify(apiUsageChart || { labels: [], data: [] })}

    const newUsersCanvas = document.getElementById('dashboardNewUsersChart')
    if (newUsersCanvas && typeof Chart !== 'undefined') {
      const ctx = newUsersCanvas.getContext('2d')
      new Chart(ctx, {
        type: 'bar',
        data: {
          labels: dashboardNewUsersData.labels || [],
          datasets: [
            {
              label: 'Người dùng mới',
              data: dashboardNewUsersData.data || [],
              borderColor: '#177dff',
              backgroundColor: 'rgba(23, 125, 255, 0.8)'
            }
          ]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: {
              display: false
            }
          },
          scales: {
            y: {
              beginAtZero: true
            }
          }
        }
      })
    }

    const apiUsageCanvas = document.getElementById('dashboardApiUsageChart')
    if (apiUsageCanvas && typeof Chart !== 'undefined') {
      const ctx = apiUsageCanvas.getContext('2d')
      new Chart(ctx, {
        type: 'line',
        data: {
          labels: dashboardApiUsageData.labels || [],
          datasets: [
            {
              label: 'Số request thành công (200)',
              data: dashboardApiUsageData.data || [],
              backgroundColor: 'transparent',
              borderColor: '#59d05d',
              borderWidth: 2,
              pointBackgroundColor: '#59d05d',
              pointBorderColor: '#ffffff',
              pointRadius: 3,
              tension: 0.3,
              fill: false
            }
          ]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: {
              display: false
            }
          },
          scales: {
            y: {
              beginAtZero: true
            }
          }
        }
      })
    }


