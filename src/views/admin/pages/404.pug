extends ../layouts/default.pug

block main-content
  div(class="row justify-content-center")
    div(class="col-lg-8 col-md-10")
      div(class="card card-round shadow-sm")
        div(class="card-body text-center py-5")
          div(class="mb-3")
            span(class="badge bg-warning text-dark px-3 py-2 mb-2") Lỗi hệ thống
            h1(class="display-1 fw-bold text-primary mb-0") 404
            p(class="text-muted fs-5 mb-0") Trang bạn tìm không tồn tại hoặc đã được di chuyển.
          p(class="text-muted mt-4 mb-5") Vui lòng kiểm tra lại đường dẫn hoặc quay về trang tổng quan để tiếp tục sử dụng hệ thống.
          div(class="d-flex flex-wrap justify-content-center gap-2")
            a(href=`${prefixAdmin}/dashboard` class="btn btn-primary")
              i(class="fas fa-home me-2")
              | Về trang Dashboard
            button(type="button" class="btn btn-outline-secondary" onclick="window.history.back()")
              i(class="fas fa-arrow-left me-2")
              | Quay lại trang trước
