    function deleteListeningVideo(id) {
      showConfirmModal(
        'Xóa bài nghe video',
        'Bạn có chắc chắn muốn xóa bài này? Hành động này không thể hoàn tác!',
        () => {
          fetch(AdminApiBreakpoint.DELETE_LV_LIST, {
            method: 'DELETE',
            headers: {
              'Content-Type': 'application/json'
            },
            credentials: 'same-origin',
            body: JSON.stringify({ id })
          })
            .then(async response => {
              if (!response.ok) {
                const error = await response.json()
                error.status = response.status
                return Promise.reject(error)
              }
              return response.json()
            })
            .then(data => {
              showNotification('success', data.message || 'Đã xóa bài thành công!')
              fetchListeningVideos()
            })
            .catch(error => {
              let errorMessage = 'Có lỗi xảy ra khi xóa bài'
              if (error.status === 422 && error.errors) {
                errorMessage = 'Lỗi validation:\n' + Object.values(error.errors)
                  .map(err => `- ${err.msg || err}`)
                  .join('\n')
              } else if (error.errors) {
                const errorMessages = Object.values(error.errors).map(err => err.msg || err).join(', ')
                errorMessage = errorMessages || error.message || errorMessage
              } else if (error.message) {
                errorMessage = error.message
              }
              showNotification('error', errorMessage)
            })
        }
      )
    }

    function saveListeningVideo() {
      const form = document.getElementById('listeningVideoForm')
      if (!form.checkValidity()) {
        form.reportValidity()
        return
      }

      const id = document.getElementById('listeningVideoId').value
      const title = document.getElementById('listeningVideoTitle').value
      const level = document.getElementById('listeningVideoLevel').value
      const time = parseFloat(document.getElementById('listeningVideoTime').value) || undefined
      const description = document.getElementById('listeningVideoDescription').value.trim() || undefined
      let slug = document.getElementById('listeningVideoSlug').value.trim()
      const pos = parseInt(document.getElementById('listeningVideoPos').value) || 1
      const isActive = document.getElementById('listeningVideoIsActive').value === 'true'
      const videoUrl = document.getElementById('listeningVideoVideoUrl').value.trim()
      const thumbnailUrl = document.getElementById('listeningVideoThumbnailUrl').value.trim()
      
      if (selectedTopics.length === 0) {
        showNotification('error', 'Vui lòng chọn ít nhất một chủ đề!')
        return
      }

      const transcript = []
      const transcriptItems = document.querySelectorAll('.listening-video__transcript-item')

      transcriptItems.forEach(transcriptEl => {
        const pos = parseInt(transcriptEl.querySelector('.listening-video__transcript-pos').value) || 1
        const startTime = parseFloat(transcriptEl.querySelector('.listening-video__transcript-start-time').value) || 0
        const endTime = parseFloat(transcriptEl.querySelector('.listening-video__transcript-end-time').value) || 0
        const enText = transcriptEl.querySelector('.listening-video__transcript-en-text').value.trim()
        const viText = transcriptEl.querySelector('.listening-video__transcript-vi-text').value.trim()
        if (!enText) return

        transcript.push({
          pos: pos,
          startTime: startTime,
          endTime: endTime,
          enText: enText,
          viText: viText || undefined
        })
      })

      if (transcript.length === 0) {
        showNotification('error', 'Vui lòng thêm ít nhất một câu transcript!')
        return
      }

      const questions = []
      const questionItems = document.querySelectorAll('.listening-video__question-item')

      questionItems.forEach(questionEl => {
        const pos = parseInt(questionEl.querySelector('.listening-video__question-pos').value) || 1
        const question = questionEl.querySelector('.listening-video__question-text').value.trim()
        const optionA = questionEl.querySelector('.listening-video__question-option-a').value.trim()
        const optionB = questionEl.querySelector('.listening-video__question-option-b').value.trim()
        const optionC = questionEl.querySelector('.listening-video__question-option-c').value.trim()
        const optionD = questionEl.querySelector('.listening-video__question-option-d').value.trim()
        const answer = questionEl.querySelector('.listening-video__question-answer').value
        const explanation = questionEl.querySelector('.listening-video__question-explanation').value.trim()
        
        if (!question || !optionA || !optionB || !optionC || !optionD || !answer) return

        questions.push({
          pos: pos,
          question: question,
          options: {
            A: optionA,
            B: optionB,
            C: optionC,
            D: optionD
          },
          answer: answer,
          explanation: explanation || undefined
        })
      })

      if (questions.length === 0) {
        showNotification('error', 'Vui lòng thêm ít nhất một câu hỏi!')
        return
      }

      const lvData = {
        title,
        level,
        topics: selectedTopics,
        videoUrl,
        thumbnailUrl: thumbnailUrl || undefined,
        transcript,
        questions,
        time,
        description,
        slug,
        pos,
        isActive
      }

      if (id) {
        lvData.id = id
        fetch(AdminApiBreakpoint.UPDATE_LV_LIST, {
          method: 'PUT',
          headers: {
            'Content-Type': 'application/json'
          },
          credentials: 'same-origin',
          body: JSON.stringify(lvData)
        })
          .then(async response => {
            if (!response.ok) {
              const error = await response.json()
              error.status = response.status
              return Promise.reject(error)
            }
            return response.json()
          })
          .then(data => {
            showNotification('success', data.message || 'Đã cập nhật bài thành công!')
            bootstrap.Modal.getInstance(document.getElementById('listeningVideoModal')).hide()
            fetchListeningVideos()
          })
          .catch(error => {
            let errorMessage = 'Có lỗi xảy ra khi cập nhật bài'
            if (error.status === 422 && error.errors) {
              errorMessage = 'Lỗi validation:\n' + Object.values(error.errors)
                .map(err => `- ${err.msg || err}`)
                .join('\n')
            } else if (error.errors) {
              const errorMessages = Object.values(error.errors).map(err => err.msg || err).join(', ')
              errorMessage = errorMessages || error.message || errorMessage
            } else if (error.message) {
              errorMessage = error.message
            }
            showNotification('error', errorMessage)
          })
      } else {
        fetch(AdminApiBreakpoint.CREATE_LV_LIST, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          credentials: 'same-origin',
          body: JSON.stringify(lvData)
        })
          .then(async response => {
            if (!response.ok) {
              const error = await response.json()
              error.status = response.status
              return Promise.reject(error)
            }
            return response.json()
          })
          .then(data => {
            showNotification('success', data.message || 'Đã thêm bài mới thành công!')
            bootstrap.Modal.getInstance(document.getElementById('listeningVideoModal')).hide()
            fetchListeningVideos()
          })
          .catch(error => {
            let errorMessage = 'Có lỗi xảy ra khi thêm bài'
            if (error.status === 422 && error.errors) {
              errorMessage = 'Lỗi validation:\n' + Object.values(error.errors)
                .map(err => `- ${err.msg || err}`)
                .join('\n')
            } else if (error.errors) {
              const errorMessages = Object.values(error.errors).map(err => err.msg || err).join(', ')
              errorMessage = errorMessages || error.message || errorMessage
            } else if (error.message) {
              errorMessage = error.message
            }
            showNotification('error', errorMessage)
          })
      }
    }

    function showConfirmModal(title, message, callback) {
      if (typeof swal !== 'undefined') {
        swal({
          title: title,
          text: message,
          icon: 'warning',
          buttons: {
            cancel: 'Hủy',
            confirm: 'Xác nhận'
          },
          dangerMode: true
        }).then((willDelete) => {
          if (willDelete) {
            callback()
          }
        })
      } else {
        document.getElementById('confirmModalLabel').textContent = title
        document.getElementById('confirmMessage').textContent = message

        const confirmBtn = document.getElementById('confirmAction')
        confirmBtn.onclick = () => {
          bootstrap.Modal.getInstance(document.getElementById('confirmModal')).hide()
          callback()
        }

        new bootstrap.Modal(document.getElementById('confirmModal')).show()
      }
    }

    function showNotification(type, message) {
      if (typeof swal !== 'undefined') {
        swal({
          title: type === 'success' ? 'Thành công!' : type === 'error' ? 'Lỗi!' : 'Thông báo',
          text: message,
          icon: type,
          button: 'OK'
        })
      } else {
        alert(message)
      }
    }

    function extractYouTubeVideoId(url) {
      if (!url) return null
      const regExp = /^.*(youtu.be\/|v\/|u\/\w\/|embed\/|watch\?v=|&v=)([^#&?]*).*/
      const match = url.match(regExp)
      return match && match[2].length === 11 ? match[2] : null
    }

    function updateVideoPreview() {
      const videoUrl = document.getElementById('listeningVideoVideoUrl').value.trim()
      const previewContainer = document.getElementById('videoPreviewContainer')
      const previewIframe = document.getElementById('videoPreview')
      
      if (!videoUrl) {
        previewContainer.style.display = 'none'
        return
      }

      const videoId = extractYouTubeVideoId(videoUrl)
      if (videoId) {
        const embedUrl = `https://www.youtube.com/embed/${videoId}`
        previewIframe.src = embedUrl
        previewContainer.style.display = 'block'
      } else {
        previewContainer.style.display = 'none'
      }
    }

    function updateThumbnailPreview() {
      const thumbnailUrl = document.getElementById('listeningVideoThumbnailUrl').value.trim()
      const previewContainer = document.getElementById('thumbnailPreviewContainer')
      const previewImg = document.getElementById('thumbnailPreview')
      
      if (!thumbnailUrl) {
        previewContainer.style.display = 'none'
        return
      }

      previewImg.src = thumbnailUrl
      previewImg.onload = () => {
        previewContainer.style.display = 'block'
      }
      previewImg.onerror = () => {
        previewContainer.style.display = 'none'
      }
    }

    function autoGenerateThumbnailFromVideo() {
      const videoUrl = document.getElementById('listeningVideoVideoUrl').value.trim()
      const thumbnailInput = document.getElementById('listeningVideoThumbnailUrl')
      
      if (!thumbnailInput.value.trim() && videoUrl) {
        const videoId = extractYouTubeVideoId(videoUrl)
        if (videoId) {
          thumbnailInput.value = `https://img.youtube.com/vi/${videoId}/maxresdefault.jpg`
          updateThumbnailPreview()
        }
      }
    }

    document.addEventListener('DOMContentLoaded', function () {
      cacheElements()
      populateSelectOptions()
      handleFilterEvents()
      fetchListeningVideos()

      const currentPath = window.location.pathname
      document.querySelectorAll('.nav-item').forEach(item => {
        item.classList.remove('active')
      })

      if (currentPath.includes('/listening-video')) {
        const lvLink = document.querySelector(`a[href="${prefixAdmin}/listening-video"]`)
        if (lvLink && lvLink.parentElement) {
          lvLink.parentElement.classList.add('active')
          const parentCollapse = lvLink.closest('.collapse')
          if (parentCollapse) {
            parentCollapse.classList.add('show')
            const parentLink = parentCollapse.previousElementSibling
            if (parentLink) {
              parentLink.classList.remove('collapsed')
              parentLink.setAttribute('aria-expanded', 'true')
            }
          }
        }
      }
    })

