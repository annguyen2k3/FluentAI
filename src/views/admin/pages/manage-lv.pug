extends ../layouts/default.pug

block main-content
  div(class="page-header")
    ul(class="breadcrumbs")
      li(class="nav-home")
        a(href=`${prefixAdmin}/dashboard`)
          i(class="fas fa-home")
      li(class="separator")
        i(class="fas fa-angle-right")
      li(class="nav-item")
        a(href="#") Quản lý nội dung
      li(class="separator")
        i(class="fas fa-angle-right")
      li(class="nav-item")
        a(href="#") Luyện nghe (video)

  div(class="row")
    div(class="col-md-12")
      div(class="card")
        div(class="card-header")
          div(class="d-flex align-items-center justify-content-between")
            h4(class="card-title") Danh sách bài nghe video
            div(class="d-flex gap-2")
              a(class="btn btn-success" href=`${prefixAdmin}/listening-video/import`)
                i(class="fas fa-file-excel")
                |  Import file Excel
              button(class="btn btn-primary" type="button" data-bs-toggle="modal" data-bs-target="#listeningVideoModal" onclick="openAddModal()")
                i(class="fas fa-plus")
                |  Thêm bài mới
        div(class="card-body")
          div(class="listening-video__filters row g-3 mb-3 align-items-end")
            div(class="col-lg-2 col-md-4 col-sm-6")
              label(for="filterTopic" class="form-label mb-1") Lọc theo chủ đề
              select(id="filterTopic" class="form-select listening-video__filter-control")
                option(value="") Tất cả chủ đề
            div(class="col-lg-2 col-md-4 col-sm-6")
              label(for="filterLevel" class="form-label mb-1") Lọc theo cấp độ
              select(id="filterLevel" class="form-select listening-video__filter-control")
                option(value="") Tất cả cấp độ
            div(class="col-lg-2 col-md-4 col-sm-6")
              label(for="filterIsActive" class="form-label mb-1") Trạng thái hoạt động
              select(id="filterIsActive" class="form-select listening-video__filter-control")
                option(value="") Tất cả trạng thái
                option(value="true") Đang hoạt động
                option(value="false") Ngưng hoạt động
            div(class="col-lg-2 col-md-4 col-sm-6")
              label(for="filterLimit" class="form-label mb-1") Số mục mỗi trang
              select(id="filterLimit" class="form-select listening-video__filter-control")
                option(value="6") 6 mục
                option(value="12") 12 mục
                option(value="24") 24 mục
            div(class="col-lg-4 col-md-8 col-sm-12")
              label(for="filterSearch" class="form-label mb-1") Tìm kiếm theo tiêu đề
              input(type="text" id="filterSearch" class="form-control listening-video__filter-control" placeholder="Nhập từ khóa tiêu đề")
          div(class="listening-video__filters row g-3 mb-4 listening-video__filters--advanced")
            div(class="col-lg-3 col-md-4 col-sm-6")
              label(for="filterSortKey" class="form-label mb-1") Sắp xếp theo
              select(id="filterSortKey" class="form-select listening-video__filter-control")
                option(value="pos") Vị trí
                option(value="create_at") Ngày tạo
                option(value="update_at") Ngày cập nhật
            div(class="col-lg-3 col-md-4 col-sm-6")
              label(for="filterSortOrder" class="form-label mb-1") Thứ tự
              select(id="filterSortOrder" class="form-select listening-video__filter-control")
                option(value="asc") Tăng dần
                option(value="desc") Giảm dần
            div(class="col-lg-3 col-md-4 col-sm-6 d-flex align-items-end justify-content-center listening-video__result-badge")
              span(id="filterResultCount" class="badge bg-light text-dark px-3 py-2 w-100 text-center") 0 nội dung
            div(class="col-lg-3 col-md-4 col-sm-12 d-flex align-items-end justify-content-end listening-video__filter-actions")
              button(type="button" class="btn btn-outline-secondary me-2" id="filterResetBtn")
                i(class="fas fa-undo me-1")
                |  Đặt lại
              button(type="button" class="btn btn-primary" id="filterApplyBtn")
                i(class="fas fa-filter me-1")
                |  Áp dụng
          div(id="listeningVideosLoading" class="listening-video__loading text-center py-5 d-none")
            div(class="spinner-border text-primary" role="status")
              span(class="visually-hidden") Đang tải
            p(class="text-muted mt-3") Đang tải dữ liệu, vui lòng chờ...
          div(id="listeningVideosEmpty" class="listening-video__empty text-center py-5 d-none")
            i(class="far fa-folder-open fa-3x text-muted mb-3")
            p(class="text-muted mb-0") Không tìm thấy nội dung nào
          div(class="row" id="listeningVideosList")
          div(class="listening-video__pagination d-flex justify-content-between align-items-center mt-4")
            span(id="listeningVideoPaginationInfo" class="text-muted") Đang tải dữ liệu...
            div(class="d-flex gap-2")
              button(type="button" class="btn btn-outline-secondary listening-video__pagination-btn" id="listeningVideoPaginationPrev")
                i(class="fas fa-chevron-left me-1")
                |  Trước
              button(type="button" class="btn btn-outline-secondary listening-video__pagination-btn" id="listeningVideoPaginationNext")
                | Sau
                i(class="fas fa-chevron-right ms-1")

  div(class="modal fade" id="listeningVideoModal" tabindex="-1" role="dialog" aria-labelledby="listeningVideoModalLabel" aria-hidden="true")
    div(class="modal-dialog modal-xl" role="document")
      div(class="modal-content")
        div(class="modal-header")
          h5(class="modal-title" id="listeningVideoModalLabel") Thêm bài nghe video mới
          button(type="button" class="close" data-bs-dismiss="modal" aria-label="Close")
            span(aria-hidden="true") &times;
        div(class="modal-body")
          form(id="listeningVideoForm")
            input(type="hidden" id="listeningVideoId" name="id")
            div(class="row")
              div(class="col-md-6")
                div(class="form-group")
                  label(for="listeningVideoTitle" class="form-label") Tiêu đề 
                    span(class="text-danger") *
                  input(type="text" class="form-control" id="listeningVideoTitle" name="title" required placeholder="Ví dụ: Bài nghe về chào hỏi")
              div(class="col-md-3")
                div(class="form-group")
                  label(for="listeningVideoLevel" class="form-label") Cấp độ 
                    span(class="text-danger") *
                  select(class="form-control" id="listeningVideoLevel" name="level" required)
                    option(value="") Chọn cấp độ
              div(class="col-md-3")
                div(class="form-group")
                  label(for="listeningVideoTime" class="form-label") Thời lượng (phút)
                  input(type="number" class="form-control" id="listeningVideoTime" name="time" min="0" step="0.1" placeholder="0")
            div(class="row")
              div(class="col-md-12")
                div(class="form-group")
                  label(for="listeningVideoDescription" class="form-label") Mô tả
                  textarea(class="form-control" id="listeningVideoDescription" name="description" rows="3" placeholder="Nhập mô tả bài nghe")
            div(class="row")
              div(class="col-md-6")
                div(class="form-group")
                  label(for="listeningVideoSlug" class="form-label") Slug
                  input(type="text" class="form-control" id="listeningVideoSlug" name="slug" placeholder="Ví dụ: bai-nghe-ve-chao-hoi")
                  small(class="form-text text-muted") Slug sẽ được tự động tạo từ tiêu đề nếu để trống
              div(class="col-md-3")
                div(class="form-group")
                  label(for="listeningVideoPos" class="form-label") Vị trí 
                  input(type="number" class="form-control" id="listeningVideoPos" name="pos" value="1" min="1")
              div(class="col-md-3")
                div(class="form-group")
                  label(for="listeningVideoIsActive" class="form-label") Trạng thái hoạt động
                  select(class="form-control" id="listeningVideoIsActive" name="isActive")
                    option(value="true") Đang hoạt động
                    option(value="false") Ngưng hoạt động
            div(class="row")
              div(class="col-md-12")
                div(class="form-group position-relative")
                  label(class="form-label") Chủ đề 
                    span(class="text-danger") *
                  div(id="listeningVideoTopicsContainer" class="listening-video__topics-container d-flex flex-wrap gap-2 p-2 border rounded position-relative")
                    div(id="listeningVideoTopicsBadges" class="d-flex flex-wrap gap-2")
                    button(type="button" class="btn btn-sm btn-outline-primary listening-video__add-topic-btn" onclick="openTopicSelector()")
                      i(class="fas fa-plus")
                      |  Thêm chủ đề
                  input(type="hidden" id="listeningVideoTopics" name="topics")
                  div(id="topicSelectorDropdown" class="listening-video__topic-selector dropdown-menu" style="display: none; max-height: 300px; overflow-y: auto; z-index: 1050;")
            div(class="row")
              div(class="col-md-6")
                div(class="form-group")
                  label(for="listeningVideoVideoUrl" class="form-label") URL Video 
                    span(class="text-danger") *
                  input(type="text" class="form-control" id="listeningVideoVideoUrl" name="videoUrl" required placeholder="Nhập URL video YouTube" oninput="updateVideoPreview(); autoGenerateThumbnailFromVideo();")
                  small(class="form-text text-muted") Ví dụ: https://www.youtube.com/watch?v=VIDEO_ID
                  div(id="videoPreviewContainer" class="mt-3 listening-video__video-preview" style="display: none;")
                    div(class="ratio ratio-16x9")
                      iframe(id="videoPreview" class="listening-video__video-iframe" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen)
              div(class="col-md-6")
                div(class="form-group")
                  label(for="listeningVideoThumbnailUrl" class="form-label") URL Thumbnail
                  input(type="text" class="form-control" id="listeningVideoThumbnailUrl" name="thumbnailUrl" placeholder="URL thumbnail (tự động tạo từ YouTube nếu để trống)" oninput="updateThumbnailPreview()")
                  div(id="thumbnailPreviewContainer" class="mt-3 listening-video__thumbnail-preview" style="display: none;")
                    img(id="thumbnailPreview" class="img-fluid rounded listening-video__thumbnail-img" alt="Thumbnail preview" style="max-height: 200px; width: 100%; object-fit: contain;")
            div(class="form-group")
              label(class="form-label") Transcript 
                span(class="text-danger") *
              div(id="transcriptList" class="listening-video__transcript-list")
              button(type="button" class="btn btn-sm btn-outline-primary mt-2" onclick="addTranscriptItem()")
                i(class="fas fa-plus")
                |  Thêm câu transcript
            div(class="form-group mt-3")
              label(class="form-label") Câu hỏi 
                span(class="text-danger") *
              div(id="questionsList" class="listening-video__questions-list")
              button(type="button" class="btn btn-sm btn-outline-primary mt-2" onclick="addQuestionItem()")
                i(class="fas fa-plus")
                |  Thêm câu hỏi
        div(class="modal-footer")
          button(type="button" class="btn btn-secondary" data-bs-dismiss="modal") Hủy
          button(type="button" class="btn btn-primary" onclick="saveListeningVideo()") Lưu

  div(class="modal fade" id="confirmModal" tabindex="-1" role="dialog" aria-labelledby="confirmModalLabel" aria-hidden="true")
    div(class="modal-dialog" role="document")
      div(class="modal-content")
        div(class="modal-header")
          h5(class="modal-title" id="confirmModalLabel") Xác nhận
          button(type="button" class="close" data-bs-dismiss="modal" aria-label="Close")
            span(aria-hidden="true") &times;
        div(class="modal-body")
          p(id="confirmMessage") Bạn có chắc chắn muốn thực hiện hành động này?
        div(class="modal-footer")
          button(type="button" class="btn btn-secondary" data-bs-dismiss="modal") Hủy
          button(type="button" class="btn btn-danger" id="confirmAction") Xác nhận

block scripts
  style.
    .listening-video__topics-container {
      min-height: 50px;
    }
    .listening-video__topic-badge {
      padding: 0.5rem 0.75rem;
      font-size: 0.875rem;
      display: inline-flex;
      align-items: center;
      cursor: default;
    }
    .listening-video__topic-badge:hover .listening-video__topic-remove {
      opacity: 1 !important;
    }
    .listening-video__topic-remove {
      margin-left: 0.5rem;
      cursor: pointer;
      opacity: 0;
      transition: opacity 0.2s;
    }
    .listening-video__topic-remove:hover {
      opacity: 1 !important;
    }
    .listening-video__add-topic-btn {
      border-style: dashed;
    }
    .listening-video__topic-selector {
      min-width: 250px;
    }
  script(type="module").
    import { AdminApiBreakpoint } from '/js/api_breakpoint.js'

    const prefixAdmin = '#{prefixAdmin}'
    const topicsData = !{JSON.stringify(topics || [])}
    const levelsData = !{JSON.stringify(levels || [])}

    const topicTitles = {}
    topicsData.forEach(topic => {
      topicTitles[topic._id] = topic.title
    })

    const levelTitles = {}
    levelsData.forEach(level => {
      levelTitles[level._id] = level.title
    })

    let listeningVideosData = []
    let pagination = { page: 1, limit: 6, total: 0, totalPages: 0, hasNextPage: false, hasPrevPage: false }
    let transcriptCounter = 0
    let questionCounter = 0
    let selectedTopics = []

    const state = {
      page: 1,
      limit: 6,
      topic: '',
      level: '',
      isActive: '',
      search: '',
      sortKey: 'pos',
      sortOrder: 'asc'
    }

    const elements = {
      list: null,
      loading: null,
      empty: null,
      paginationInfo: null,
      paginationPrev: null,
      paginationNext: null,
      filterTopic: null,
      filterLevel: null,
      filterIsActive: null,
      filterLimit: null,
      filterSearch: null,
      filterSortKey: null,
      filterSortOrder: null
    }

    function cacheElements() {
      elements.list = document.getElementById('listeningVideosList')
      elements.loading = document.getElementById('listeningVideosLoading')
      elements.empty = document.getElementById('listeningVideosEmpty')
      elements.paginationInfo = document.getElementById('listeningVideoPaginationInfo')
      elements.paginationPrev = document.getElementById('listeningVideoPaginationPrev')
      elements.paginationNext = document.getElementById('listeningVideoPaginationNext')
      elements.filterTopic = document.getElementById('filterTopic')
      elements.filterLevel = document.getElementById('filterLevel')
      elements.filterIsActive = document.getElementById('filterIsActive')
      elements.filterLimit = document.getElementById('filterLimit')
      elements.filterSearch = document.getElementById('filterSearch')
      elements.filterSortKey = document.getElementById('filterSortKey')
      elements.filterSortOrder = document.getElementById('filterSortOrder')
    }

    async function fetchListeningVideos() {
      toggleLoading(true)
      const params = new URLSearchParams()
      params.set('page', state.page.toString())
      params.set('limit', state.limit.toString())
      if (state.topic) params.set('topic', state.topic)
      if (state.level) params.set('level', state.level)
      if (state.isActive !== '') params.set('isActive', state.isActive)
      if (state.search) params.set('search', state.search)
      if (state.sortKey) params.set('sortKey', state.sortKey)
      if (state.sortOrder) params.set('sortOrder', state.sortOrder)

      try {
        const response = await fetch(`${AdminApiBreakpoint.GET_LV_LIST}?${params.toString()}`, {
          credentials: 'same-origin'
        })
        const payload = await response.json()
        if (!response.ok) {
          throw payload
        }
        listeningVideosData = payload.data || []
        const totalItems = payload.pagination?.total || listeningVideosData.length || 0
        const resultCountEl = document.getElementById('filterResultCount')
        if (resultCountEl) {
          resultCountEl.textContent = `${totalItems} nội dung`
        }
        pagination = {
          page: payload.pagination?.page || state.page,
          limit: payload.pagination?.limit || state.limit,
          total: payload.pagination?.total || 0,
          totalPages: payload.pagination?.totalPages || 0,
          hasNextPage: payload.pagination?.hasNextPage || false,
          hasPrevPage: payload.pagination?.hasPrevPage || false
        }
        renderListeningVideos()
        updatePaginationUI()
      } catch (error) {
        const message = error?.message || 'Không thể tải danh sách nội dung'
        showNotification('error', message)
        listeningVideosData = []
        renderListeningVideos()
        updatePaginationUI()
      } finally {
        toggleLoading(false)
      }
    }

    function renderListeningVideos() {
      const container = elements.list || document.getElementById('listeningVideosList')
      if (!container) return
      if (!elements.list) elements.list = container
      container.innerHTML = ''

      if (!listeningVideosData.length) {
        container.classList.add('d-none')
        toggleEmpty(true)
        return
      }

      container.classList.remove('d-none')
      toggleEmpty(false)

      listeningVideosData.forEach(item => {
        const levelId = typeof item.level === 'string' ? item.level : item.level?._id
        const levelTitle = item.level?.title || levelTitles[levelId] || 'N/A'
        const topicsArray = Array.isArray(item.topics) ? item.topics : (item.topic || [])
        const topicsTitles = topicsArray.map(t => {
          const topicId = typeof t === 'string' ? t : t._id
          return typeof t === 'object' && t.title ? t.title : (topicTitles[topicId] || 'N/A')
        }).join(', ')
        const transcriptCount = item.transcript ? item.transcript.length : 0
        const questionsCount = item.questions ? item.questions.length : 0

        const createDate = item.create_at ? new Date(item.create_at).toLocaleString('vi-VN') : 'N/A'
        const updateDate = item.update_at ? new Date(item.update_at).toLocaleString('vi-VN') : 'N/A'

        const thumbnailUrl = item.thumbnailUrl || ''

        const card = `
          <div class="col-md-6 mb-4">
            <div class="card listening-video__card position-relative">
              ${thumbnailUrl ? `
                <img src="${thumbnailUrl}" class="card-img-top listening-video__thumbnail" alt="${item.title}" style="height: 200px; object-fit: cover;">
              ` : ''}
              <div class="card-body">
                <div class="listening-video__timestamps text-muted small mb-2">
                  ⌚ <span title="Ngày tạo">${createDate}</span> · ⟳ <span title="Ngày cập nhật">${updateDate}</span>
                </div>
                <div class="d-flex justify-content-between align-items-start mb-3 gap-2 position-relative">
                  <div class="flex-grow-1 pe-4" style="min-width: 0;">
                    <h5 class="card-title mb-1 listening-video__title" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; text-overflow: ellipsis; word-wrap: break-word; overflow-wrap: break-word; line-height: 1.4; min-height: 2.8em; max-height: 2.8em;" title="${item.title}">${item.title}</h5>
                    <div class="listening-video__meta">
                      <span class="badge badge-info me-2">${levelTitle}</span>
                      <span class="badge badge-primary me-2">${topicsTitles || 'N/A'}</span>
                      ${item.time ? `<span class="badge badge-secondary me-2">${item.time} phút</span>` : ''}
                      <span class="badge badge-secondary me-2">${transcriptCount} transcript</span>
                      <span class="badge badge-secondary me-2">${questionsCount} câu hỏi</span>
                      <span class="badge ${item.isActive !== false ? 'badge-success' : 'badge-danger'}">${item.isActive !== false ? 'Đang hoạt động' : 'Ngưng hoạt động'}</span>
                    </div>
                  </div>
                  <div class="listening-video__actions flex-shrink-0" style="white-space: nowrap;">
                    <button class="btn btn-sm btn-info" onclick="editListeningVideo('${item._id}')" title="Chỉnh sửa">
                      <i class="fas fa-edit"></i>
                    </button>
                    <button class="btn btn-sm btn-secondary" onclick="copyListeningVideo('${item._id}')" title="Sao chép">
                      <i class="fas fa-copy"></i>
                    </button>
                    <button class="btn btn-sm btn-danger" onclick="deleteListeningVideo('${item._id}')" title="Xóa">
                      <i class="fas fa-trash"></i>
                    </button>
                  </div>
                </div>
                ${item.description ? `<p class="text-muted mb-1"><strong>Mô tả:</strong> ${item.description.substring(0, 100)}${item.description.length > 100 ? '...' : ''}</p>` : ''}
                <p class="text-muted mb-1"><strong>Slug:</strong> ${item.slug}</p>
                <p class="text-muted mb-1"><strong>Vị trí:</strong> ${item.pos || '-'}</p>
                <p class="text-muted mb-1"><strong>Video URL:</strong> <a href="${item.videoUrl}" target="_blank" class="text-primary">${item.videoUrl}</a></p>
              </div>
            </div>
          </div>
        `
        container.innerHTML += card
      })
    }

    function updatePaginationUI() {
      if (elements.paginationInfo) {
        if (pagination.total > 0) {
          const totalPages = Math.max(pagination.totalPages, 1)
          elements.paginationInfo.textContent = `Trang ${pagination.page}/${totalPages} • ${pagination.total} nội dung`
        } else {
          elements.paginationInfo.textContent = 'Không có dữ liệu'
        }
      }
      if (elements.paginationPrev) {
        elements.paginationPrev.disabled = !pagination.hasPrevPage
      }
      if (elements.paginationNext) {
        elements.paginationNext.disabled = !pagination.hasNextPage
      }
    }

    function toggleLoading(show) {
      const loadingEl = elements.loading || document.getElementById('listeningVideosLoading')
      const listEl = elements.list || document.getElementById('listeningVideosList')
      if (!loadingEl || !listEl) return
      if (!elements.loading) elements.loading = loadingEl
      if (!elements.list) elements.list = listEl

      if (show) {
        loadingEl.classList.remove('d-none')
        listEl.classList.add('d-none')
        toggleEmpty(false)
      } else {
        loadingEl.classList.add('d-none')
      }
    }

    function toggleEmpty(show) {
      const emptyEl = elements.empty || document.getElementById('listeningVideosEmpty')
      if (!emptyEl) return
      if (!elements.empty) elements.empty = emptyEl
      if (show) {
        emptyEl.classList.remove('d-none')
      } else {
        emptyEl.classList.add('d-none')
      }
    }

    function populateSelectOptions() {
      const levelSelect = document.getElementById('listeningVideoLevel')

      if (levelSelect) {
        levelSelect.innerHTML = '<option value="">Chọn cấp độ</option>'
      }
      if (elements.filterTopic) {
        elements.filterTopic.innerHTML = '<option value="">Tất cả chủ đề</option>'
      }
      if (elements.filterLevel) {
        elements.filterLevel.innerHTML = '<option value="">Tất cả cấp độ</option>'
      }

      topicsData.forEach(topic => {
        if (elements.filterTopic) {
          const filterOption = document.createElement('option')
          filterOption.value = topic._id
          filterOption.textContent = topic.title
          elements.filterTopic.appendChild(filterOption)
        }
      })

      levelsData.forEach(level => {
        if (levelSelect) {
          const option = document.createElement('option')
          option.value = level._id
          option.textContent = level.title
          levelSelect.appendChild(option)
        }
        if (elements.filterLevel) {
          const filterOption = document.createElement('option')
          filterOption.value = level._id
          filterOption.textContent = level.title
          elements.filterLevel.appendChild(filterOption)
        }
      })
    }

    function renderTopicBadges() {
      const badgesContainer = document.getElementById('listeningVideoTopicsBadges')
      if (!badgesContainer) return
      
      badgesContainer.innerHTML = ''
      
      selectedTopics.forEach(topicId => {
        const topic = topicsData.find(t => t._id === topicId)
        if (!topic) return
        
        const badge = document.createElement('span')
        badge.className = 'badge bg-primary listening-video__topic-badge position-relative'
        badge.setAttribute('data-topic-id', topicId)
        badge.innerHTML = `
          ${topic.title}
          <span class="listening-video__topic-remove ms-2" style="cursor: pointer; opacity: 0; transition: opacity 0.2s;">
            <i class="fas fa-times"></i>
          </span>
        `
        
        badge.addEventListener('mouseenter', () => {
          const removeBtn = badge.querySelector('.listening-video__topic-remove')
          if (removeBtn) removeBtn.style.opacity = '1'
        })
        
        badge.addEventListener('mouseleave', () => {
          const removeBtn = badge.querySelector('.listening-video__topic-remove')
          if (removeBtn) removeBtn.style.opacity = '0'
        })
        
        const removeBtn = badge.querySelector('.listening-video__topic-remove')
        if (removeBtn) {
          removeBtn.addEventListener('click', (e) => {
            e.stopPropagation()
            removeTopic(topicId)
          })
        }
        
        badgesContainer.appendChild(badge)
      })
      
      updateTopicsHiddenInput()
    }

    function addTopic(topicId) {
      if (!selectedTopics.includes(topicId)) {
        selectedTopics.push(topicId)
        renderTopicBadges()
        closeTopicSelector()
      }
    }

    function removeTopic(topicId) {
      selectedTopics = selectedTopics.filter(id => id !== topicId)
      renderTopicBadges()
    }

    function updateTopicsHiddenInput() {
      const hiddenInput = document.getElementById('listeningVideoTopics')
      if (hiddenInput) {
        hiddenInput.value = JSON.stringify(selectedTopics)
      }
    }

    function openTopicSelector() {
      const dropdown = document.getElementById('topicSelectorDropdown')
      const addTopicBtn = document.querySelector('.listening-video__add-topic-btn')
      const formGroup = addTopicBtn?.closest('.form-group')
      if (!dropdown || !addTopicBtn || !formGroup) return
      
      dropdown.innerHTML = ''
      
      const availableTopics = topicsData.filter(topic => !selectedTopics.includes(topic._id))
      
      if (availableTopics.length === 0) {
        const noOption = document.createElement('div')
        noOption.className = 'dropdown-item-text text-muted'
        noOption.textContent = 'Không còn chủ đề nào để chọn'
        dropdown.appendChild(noOption)
      } else {
        availableTopics.forEach(topic => {
          const item = document.createElement('a')
          item.className = 'dropdown-item'
          item.href = '#'
          item.textContent = topic.title
          item.addEventListener('click', (e) => {
            e.preventDefault()
            addTopic(topic._id)
          })
          dropdown.appendChild(item)
        })
      }
      
      const btnRect = addTopicBtn.getBoundingClientRect()
      const formGroupRect = formGroup.getBoundingClientRect()
      
      dropdown.style.position = 'absolute'
      dropdown.style.top = `${btnRect.top - formGroupRect.top - 5}px`
      dropdown.style.left = `${btnRect.left - formGroupRect.left}px`
      dropdown.style.transform = 'translateY(-100%)'
      dropdown.style.display = 'block'
      
      const closeHandler = (e) => {
        if (!formGroup.contains(e.target) && !dropdown.contains(e.target)) {
          closeTopicSelector()
          document.removeEventListener('click', closeHandler)
        }
      }
      
      setTimeout(() => {
        document.addEventListener('click', closeHandler)
      }, 100)
    }

    function closeTopicSelector() {
      const dropdown = document.getElementById('topicSelectorDropdown')
      if (dropdown) {
        dropdown.style.display = 'none'
      }
    }

    function handleFilterEvents() {
      const applyBtn = document.getElementById('filterApplyBtn')
      const resetBtn = document.getElementById('filterResetBtn')

      if (applyBtn) {
        applyBtn.addEventListener('click', () => {
          state.topic = elements.filterTopic?.value || ''
          state.level = elements.filterLevel?.value || ''
          state.isActive = elements.filterIsActive?.value || ''
          state.search = elements.filterSearch?.value.trim() || ''
          state.sortKey = elements.filterSortKey?.value || 'pos'
          state.sortOrder = elements.filterSortOrder?.value || 'asc'
          state.page = 1
          fetchListeningVideos()
        })
      }

      if (resetBtn) {
        resetBtn.addEventListener('click', () => {
          state.topic = ''
          state.level = ''
          state.isActive = ''
          state.limit = 6
          state.search = ''
          state.sortKey = 'pos'
          state.sortOrder = 'asc'
          state.page = 1
          if (elements.filterTopic) elements.filterTopic.value = ''
          if (elements.filterLevel) elements.filterLevel.value = ''
          if (elements.filterIsActive) elements.filterIsActive.value = ''
          if (elements.filterLimit) elements.filterLimit.value = '6'
          if (elements.filterSearch) elements.filterSearch.value = ''
          if (elements.filterSortKey) elements.filterSortKey.value = 'pos'
          if (elements.filterSortOrder) elements.filterSortOrder.value = 'asc'
          fetchListeningVideos()
        })
      }

      if (elements.filterLimit) {
        elements.filterLimit.value = state.limit.toString()
        elements.filterLimit.addEventListener('change', event => {
          const value = Number(event.target.value) || 6
          state.limit = value
          state.page = 1
          fetchListeningVideos()
        })
      }

      if (elements.filterSortKey) {
        elements.filterSortKey.value = state.sortKey
      }

      if (elements.filterSortOrder) {
        elements.filterSortOrder.value = state.sortOrder
      }

      if (elements.paginationPrev) {
        elements.paginationPrev.addEventListener('click', () => {
          if (!pagination.hasPrevPage) return
          state.page = Math.max(1, state.page - 1)
          fetchListeningVideos()
        })
      }

      if (elements.paginationNext) {
        elements.paginationNext.addEventListener('click', () => {
          if (!pagination.hasNextPage) return
          state.page += 1
          fetchListeningVideos()
        })
      }
    }

