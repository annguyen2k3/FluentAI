extends ../../layouts/default.pug

block main-content
  div(class="page-header")
    ul(class="breadcrumbs mb-0")
      li(class="nav-home")
        a(href=`${prefixAdmin}/dashboard`)
          i(class="fas fa-home")
      li(class="separator")
        i(class="fas fa-angle-right")
      li(class="nav-item")
        a(href="#") Thống kê báo cáo
      li(class="separator")
        i(class="fas fa-angle-right")
      li(class="nav-item")
        a(href="#") Doanh thu hệ thống

  div(class="row gy-3 revenue-statistics__summary-row")
    div(class="col-md-4")
      div(class="card revenue-statistics__card revenue-statistics__card--wallet bg-primary")
        div(class="card-body")
          div(class="d-flex justify-content-between align-items-center mb-2")
            span(class="text-muted") Ví hệ thống
            span(class="badge bg-primary revenue-statistics__badge")
              i(class="fas fa-wallet")
          div(class="d-flex align-items-center revenue-statistics__wallet-balance-row")
            h1(id="systemBalance" class="mb-0 fw-bold me-2") 0
            i(class="fas fa-coins text-warning revenue-statistics__wallet-balance-icon")
          small(class="text-muted") Tổng credit còn lại trong hệ thống
    div(class="col-md-8")
      div(class="card revenue-statistics__card revenue-statistics__card--filters")
        div(class="card-body")
          div(class="d-flex flex-wrap align-items-center justify-content-between gap-3")
            div
              h4(class="card-title mb-1") Thống kê thu nhập người dùng
              small(class="text-muted") Lọc theo khoảng thời gian giao dịch thành công
            div(class="d-flex flex-wrap align-items-center gap-2 revenue-statistics__filters")
              div(class="d-flex align-items-center gap-2 revenue-statistics__date-range")
                div(class="input-group")
                  span(class="input-group-text") Từ
                  input(type="date" id="revenueStartDate" class="form-control")
                div(class="input-group")
                  span(class="input-group-text") Đến
                  input(type="date" id="revenueEndDate" class="form-control")
                button(type="button" id="revenueApplyFilterBtn" class="btn btn-primary") Áp dụng

          div(class="row mt-3 gx-3 revenue-statistics__income-summary-row")
            div(class="col-md-6")
              div(class="card mb-0 revenue-statistics__sub-card revenue-statistics__sub-card--income")
                div(class="card-body")
                  div(class="d-flex justify-content-between align-items-center mb-2")
                    span(class="text-muted") Tổng thu nhập
                    span(class="badge bg-success revenue-statistics__badge")
                      i(class="fas fa-coins")
                  h4(id="totalIncome" class="mb-0") 0
                  small(class="text-muted") Tổng số tiền từ giao dịch thành công
            div(class="col-md-6")
              div(class="card mb-0 revenue-statistics__sub-card revenue-statistics__sub-card--credit")
                div(class="card-body")
                  div(class="d-flex justify-content-between align-items-center mb-2")
                    span(class="text-muted") Credit đã giao dịch
                    span(class="badge bg-info revenue-statistics__badge")
                      i(class="fas fa-bolt")
                  h4(id="totalCredit" class="mb-0") 0
                  small(class="text-muted") Tổng credit đã giao dịch thành công

  div(class="card mt-4")
    div(class="card-header")
      div(class="d-flex flex-wrap align-items-center justify-content-between gap-3")
        h4(class="card-title mb-0") Chi tiết thu nhập theo ngày
        small(class="text-muted") Chỉ hiển thị các ngày có giao dịch thành công
    div(class="card-body")
      div(class="row gy-3")
        div(class="col-md-6")
          div(class="revenue-statistics__chart-container mb-2")
            div(class="d-flex justify-content-between align-items-center mb-2")
              span(class="fw-semibold") Biểu đồ thu nhập theo ngày
              span(class="badge bg-light text-dark revenue-statistics__badge-label") VND
            div(class="chart-container" style="height: 320px")
              canvas(id="revenueIncomeBarChart")
        div(class="col-md-6")
          div(class="revenue-statistics__chart-container mb-2")
            div(class="d-flex justify-content-between align-items-center mb-2")
              span(class="fw-semibold") Biểu đồ credit giao dịch theo ngày
              span(class="badge bg-light text-dark revenue-statistics__badge-label") Credit
            div(class="chart-container" style="height: 320px")
              canvas(id="revenueCreditBarChart")

      div(class="table-responsive mt-3 revenue-statistics__table")
        table(class="table table-striped table-hover align-middle")
          thead
            tr
              th Ngày
              th Thu nhập (VND)
              th Credit giao dịch
              th Số giao dịch thành công
          tbody(id="revenueTableBody")
            tr
              td(colspan="4" class="text-center text-muted") Đang tải dữ liệu...

block scripts
  style.
    .revenue-statistics__card {
      border: 1px solid #eef0f2;
      box-shadow: 0 1px 2px rgba(0,0,0,0.04);
    }
    .revenue-statistics__card--wallet {
      color: #ffffff;
    }
    .revenue-statistics__card--wallet .text-muted {
      color: rgba(255,255,255,0.8) !important;
    }
    .revenue-statistics__card--wallet h3,
    .revenue-statistics__wallet-balance-row h1 {
      color: #ffffff;
    }
    .revenue-statistics__wallet-balance-row {
      margin-bottom: 0.25rem;
    }
    .revenue-statistics__wallet-balance-icon {
      font-size: 1.8rem;
    }
    .revenue-statistics__card--filters {
      background-color: #ffffff;
    }
    .revenue-statistics__sub-card {
      border: 1px solid #eef0f2;
    }
    .revenue-statistics__sub-card--income {
      background-color: #e6fff3;
    }
    .revenue-statistics__sub-card--credit {
      background-color: #e6f7ff;
    }
    .revenue-statistics__badge {
      font-size: 0.85rem;
    }
    .revenue-statistics__filters .btn {
      min-width: 110px;
    }
    .revenue-statistics__date-range .input-group-text {
      min-width: 48px;
    }
    .revenue-statistics__chart-container {
      position: relative;
      min-height: 320px;
    }
    .revenue-statistics__badge-label {
      font-size: 0.75rem;
    }
  script(type="module").
    import { AdminApiBreakpoint } from '/js/api_breakpoint.js'

    const prefixAdmin = '#{prefixAdmin}'
    const apiRevenue = AdminApiBreakpoint?.ADMIN_STATISTICS_REVENUE || `${prefixAdmin}/statistics-reporting/revenue/data`

    const revenueState = {
      startDate: '',
      endDate: ''
    }

    const revenueElements = {
      systemBalance: null,
      totalIncome: null,
      totalCredit: null,
      startDate: null,
      endDate: null,
      applyBtn: null,
      incomeChartCanvas: null,
      creditChartCanvas: null,
      tableBody: null
    }

    let revenueIncomeChartInstance = null
    let revenueCreditChartInstance = null

    function revenueCacheElements() {
      revenueElements.systemBalance = document.getElementById('systemBalance')
      revenueElements.totalIncome = document.getElementById('totalIncome')
      revenueElements.totalCredit = document.getElementById('totalCredit')
      revenueElements.startDate = document.getElementById('revenueStartDate')
      revenueElements.endDate = document.getElementById('revenueEndDate')
      revenueElements.applyBtn = document.getElementById('revenueApplyFilterBtn')
      revenueElements.incomeChartCanvas = document.getElementById('revenueIncomeBarChart')
      revenueElements.creditChartCanvas = document.getElementById('revenueCreditBarChart')
      revenueElements.tableBody = document.getElementById('revenueTableBody')
    }

    function revenueBindEvents() {
      if (revenueElements.applyBtn) {
        revenueElements.applyBtn.addEventListener('click', () => {
          const startVal = revenueElements.startDate?.value || ''
          const endVal = revenueElements.endDate?.value || ''

          if (startVal && endVal && startVal > endVal) {
            if (typeof swal !== 'undefined') {
              swal({
                title: 'Khoảng thời gian không hợp lệ',
                text: 'Ngày bắt đầu không được lớn hơn ngày kết thúc. Vui lòng kiểm tra lại.',
                icon: 'error',
                button: 'OK'
              })
            } else {
              alert('Ngày bắt đầu không được lớn hơn ngày kết thúc. Vui lòng kiểm tra lại.')
            }
            return
          }

          revenueState.startDate = startVal
          revenueState.endDate = endVal
          revenueFetchStatistics()
        })
      }
    }

    function revenueFormatNumber(value) {
      if (value == null) return '0'
      try {
        return Number(value).toLocaleString('vi-VN')
      } catch (e) {
        return String(value)
      }
    }

    async function revenueFetchStatistics() {
      const params = new URLSearchParams()
      if (revenueState.startDate) params.set('startDate', revenueState.startDate)
      if (revenueState.endDate) params.set('endDate', revenueState.endDate)

      try {
        const response = await fetch(`${apiRevenue}?${params.toString()}`, {
          credentials: 'same-origin'
        })
        if (!response.ok) {
          throw new Error('Không thể tải dữ liệu thống kê doanh thu')
        }
        const payload = await response.json()
        const summary = payload.summary || {}
        const stats = Array.isArray(payload.stats) ? payload.stats : []
        revenueUpdateSummary(summary)
        revenueRenderIncomeChart(stats)
        revenueRenderCreditChart(stats)
        revenueRenderTable(stats)
      } catch (error) {
        revenueUpdateSummary({
          systemBalance: 0,
          totalIncome: 0,
          totalCredit: 0
        })
        revenueRenderIncomeChart([])
        revenueRenderCreditChart([])
        revenueRenderTable([])
      }
    }

    function revenueUpdateSummary(summary) {
      if (!revenueElements.systemBalance) return
      const systemBalance = summary.systemBalance ?? 0
      const totalIncome = summary.totalIncome ?? 0
      const totalCredit = summary.totalCredit ?? 0

      revenueElements.systemBalance.textContent = revenueFormatNumber(systemBalance)
      revenueElements.totalIncome.textContent = revenueFormatNumber(totalIncome)
      revenueElements.totalCredit.textContent = revenueFormatNumber(totalCredit)
    }

    function revenueRenderIncomeChart(stats) {
      if (!revenueElements.incomeChartCanvas || typeof Chart === 'undefined') return
      const ctx = revenueElements.incomeChartCanvas.getContext('2d')
      const labels = stats.map((item) => item.date || '')
      const incomes = stats.map((item) => item.totalIncome || 0)

      if (revenueIncomeChartInstance) {
        revenueIncomeChartInstance.destroy()
      }

      revenueIncomeChartInstance = new Chart(ctx, {
        type: 'bar',
        data: {
          labels,
          datasets: [
            {
              label: 'Thu nhập (VND)',
              backgroundColor: 'rgba(23, 125, 255, 0.8)',
              borderColor: '#177dff',
              borderWidth: 1,
              data: incomes
            }
          ]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          legend: {
            position: 'top'
          },
          tooltips: {
            mode: 'index',
            intersect: false,
            callbacks: {
              label(tooltipItem, data) {
                const value = data.datasets[tooltipItem.datasetIndex].data[tooltipItem.index]
                return `Thu nhập: ${revenueFormatNumber(value)} VND`
              }
            }
          },
          scales: {
            yAxes: [
              {
                ticks: {
                  beginAtZero: true,
                  callback(value) {
                    return revenueFormatNumber(value)
                  }
                }
              }
            ]
          }
        }
      })
    }

    function revenueRenderCreditChart(stats) {
      if (!revenueElements.creditChartCanvas || typeof Chart === 'undefined') return
      const ctx = revenueElements.creditChartCanvas.getContext('2d')
      const labels = stats.map((item) => item.date || '')
      const credits = stats.map((item) => item.totalCredit || 0)

      if (revenueCreditChartInstance) {
        revenueCreditChartInstance.destroy()
      }

      revenueCreditChartInstance = new Chart(ctx, {
        type: 'bar',
        data: {
          labels,
          datasets: [
            {
              label: 'Credit giao dịch',
              backgroundColor: 'rgba(89, 208, 93, 0.8)',
              borderColor: '#59d05d',
              borderWidth: 1,
              data: credits
            }
          ]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          legend: {
            position: 'top'
          },
          tooltips: {
            mode: 'index',
            intersect: false
          },
          scales: {
            yAxes: [
              {
                ticks: {
                  beginAtZero: true,
                  precision: 0
                }
              }
            ]
          }
        }
      })
    }

    function revenueRenderTable(stats) {
      if (!revenueElements.tableBody) return
      revenueElements.tableBody.innerHTML = ''

      if (!stats.length) {
        revenueElements.tableBody.innerHTML = '<tr><td colspan="4" class="text-center text-muted">Không có dữ liệu</td></tr>'
        return
      }

      stats.forEach((item) => {
        const row = document.createElement('tr')
        row.innerHTML = `
          <td>${item.date || ''}</td>
          <td>${revenueFormatNumber(item.totalIncome ?? 0)}</td>
          <td>${revenueFormatNumber(item.totalCredit ?? 0)}</td>
          <td>${item.successTransactions ?? 0}</td>
        `
        revenueElements.tableBody.appendChild(row)
      })
    }

    document.addEventListener('DOMContentLoaded', () => {
      revenueCacheElements()

      const today = new Date()
      const start = new Date(today)
      start.setDate(start.getDate() - 6)

      const toDateInput = (d) => {
        const year = d.getFullYear()
        const month = String(d.getMonth() + 1).padStart(2, '0')
        const day = String(d.getDate()).padStart(2, '0')
        return `${year}-${month}-${day}`
      }

      const startStr = toDateInput(start)
      const endStr = toDateInput(today)

      if (revenueElements.startDate) revenueElements.startDate.value = startStr
      if (revenueElements.endDate) revenueElements.endDate.value = endStr

      revenueState.startDate = startStr
      revenueState.endDate = endStr

      revenueBindEvents()
      revenueFetchStatistics()
    })


