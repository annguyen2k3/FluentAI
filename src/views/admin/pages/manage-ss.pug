extends ../layouts/default.pug

block main-content
  div(class="page-header")
    ul(class="breadcrumbs")
      li(class="nav-home")
        a(href=`${prefixAdmin}/dashboard`)
          i(class="fas fa-home")
      li(class="separator")
        i(class="fas fa-angle-right")
      li(class="nav-item")
        a(href="#") Quản lý nội dung
      li(class="separator")
        i(class="fas fa-angle-right")
      li(class="nav-item")
        a(href="#") Luyện phát âm (danh sách câu)

  div(class="row")
    div(class="col-md-12")
      div(class="card")
        div(class="card-header")
          div(class="d-flex align-items-center justify-content-between")
            h4(class="card-title") Danh sách nội dung phát âm câu
            div(class="d-flex gap-2")
              a(class="btn btn-success" href=`${prefixAdmin}/speaking-sentence/import`)
                i(class="fas fa-file-excel")
                |  Import file Excel
              button(class="btn btn-primary" type="button" data-bs-toggle="modal" data-bs-target="#speakingSentenceModal" onclick="openAddModal()")
                i(class="fas fa-plus")
                |  Thêm nội dung mới
        div(class="card-body")
          div(class="speaking-sentence__filters row g-3 mb-3 align-items-end")
            div(class="col-lg-2 col-md-4 col-sm-6")
              label(for="filterTopic" class="form-label mb-1") Lọc theo chủ đề
              select(id="filterTopic" class="form-select speaking-sentence__filter-control")
                option(value="") Tất cả chủ đề
            div(class="col-lg-2 col-md-4 col-sm-6")
              label(for="filterLevel" class="form-label mb-1") Lọc theo cấp độ
              select(id="filterLevel" class="form-select speaking-sentence__filter-control")
                option(value="") Tất cả cấp độ
            div(class="col-lg-2 col-md-4 col-sm-6")
              label(for="filterIsActive" class="form-label mb-1") Trạng thái hoạt động
              select(id="filterIsActive" class="form-select speaking-sentence__filter-control")
                option(value="") Tất cả trạng thái
                option(value="true") Đang hoạt động
                option(value="false") Ngưng hoạt động
            div(class="col-lg-2 col-md-4 col-sm-6")
              label(for="filterLimit" class="form-label mb-1") Số mục mỗi trang
              select(id="filterLimit" class="form-select speaking-sentence__filter-control")
                option(value="6") 6 mục
                option(value="12") 12 mục
                option(value="24") 24 mục
            div(class="col-lg-4 col-md-8 col-sm-12")
              label(for="filterSearch" class="form-label mb-1") Tìm kiếm theo tiêu đề
              input(type="text" id="filterSearch" class="form-control speaking-sentence__filter-control" placeholder="Nhập từ khóa tiêu đề")
          div(class="speaking-sentence__filters row g-3 mb-4 speaking-sentence__filters--advanced")
            div(class="col-lg-3 col-md-4 col-sm-6")
              label(for="filterSortKey" class="form-label mb-1") Sắp xếp theo
              select(id="filterSortKey" class="form-select speaking-sentence__filter-control")
                option(value="pos") Vị trí
                option(value="create_at") Ngày tạo
                option(value="update_at") Ngày cập nhật
            div(class="col-lg-3 col-md-4 col-sm-6")
              label(for="filterSortOrder" class="form-label mb-1") Thứ tự
              select(id="filterSortOrder" class="form-select speaking-sentence__filter-control")
                option(value="asc") Tăng dần
                option(value="desc") Giảm dần
            div(class="col-lg-3 col-md-4 col-sm-6 d-flex align-items-end justify-content-center speaking-sentence__result-badge")
              span(id="filterResultCount" class="badge bg-light text-dark px-3 py-2 w-100 text-center") 0 nội dung
            div(class="col-lg-3 col-md-4 col-sm-12 d-flex align-items-end justify-content-end speaking-sentence__filter-actions")
              button(type="button" class="btn btn-outline-secondary me-2" id="filterResetBtn")
                i(class="fas fa-undo me-1")
                |  Đặt lại
              button(type="button" class="btn btn-primary" id="filterApplyBtn")
                i(class="fas fa-filter me-1")
                |  Áp dụng
          div(id="speakingSentencesLoading" class="speaking-sentence__loading text-center py-5 d-none")
            div(class="spinner-border text-primary" role="status")
              span(class="visually-hidden") Đang tải
            p(class="text-muted mt-3") Đang tải dữ liệu, vui lòng chờ...
          div(id="speakingSentencesEmpty" class="speaking-sentence__empty text-center py-5 d-none")
            i(class="far fa-folder-open fa-3x text-muted mb-3")
            p(class="text-muted mb-0") Không tìm thấy nội dung nào
          div(class="row" id="speakingSentencesList")
          div(class="speaking-sentence__pagination d-flex justify-content-between align-items-center mt-4")
            span(id="speakingPaginationInfo" class="text-muted") Đang tải dữ liệu...
            div(class="d-flex gap-2")
              button(type="button" class="btn btn-outline-secondary speaking-sentence__pagination-btn" id="speakingPaginationPrev")
                i(class="fas fa-chevron-left me-1")
                |  Trước
              button(type="button" class="btn btn-outline-secondary speaking-sentence__pagination-btn" id="speakingPaginationNext")
                | Sau
                i(class="fas fa-chevron-right ms-1")

  div(class="modal fade" id="speakingSentenceModal" tabindex="-1" role="dialog" aria-labelledby="speakingSentenceModalLabel" aria-hidden="true")
    div(class="modal-dialog modal-xl" role="document")
      div(class="modal-content")
        div(class="modal-header")
          h5(class="modal-title" id="speakingSentenceModalLabel") Thêm nội dung phát âm câu mới
          button(type="button" class="close" data-bs-dismiss="modal" aria-label="Close")
            span(aria-hidden="true") &times;
        div(class="modal-body")
          form(id="speakingSentenceForm")
            input(type="hidden" id="speakingSentenceId" name="id")
            div(class="row")
              div(class="col-md-6")
                div(class="form-group")
                  label(for="speakingSentenceTitle" class="form-label") Tiêu đề 
                    span(class="text-danger") *
                  input(type="text" class="form-control" id="speakingSentenceTitle" name="title" required placeholder="Ví dụ: Chào hỏi cơ bản")
              div(class="col-md-3")
                div(class="form-group")
                  label(for="speakingSentenceTopic" class="form-label") Chủ đề 
                    span(class="text-danger") *
                  select(class="form-control" id="speakingSentenceTopic" name="topic" required)
                    option(value="") Chọn chủ đề
              div(class="col-md-3")
                div(class="form-group")
                  label(for="speakingSentenceLevel" class="form-label") Cấp độ 
                    span(class="text-danger") *
                  select(class="form-control" id="speakingSentenceLevel" name="level" required)
                    option(value="") Chọn cấp độ
            div(class="row")
              div(class="col-md-6")
                div(class="form-group")
                  label(for="speakingSentenceSlug" class="form-label") Slug
                  input(type="text" class="form-control" id="speakingSentenceSlug" name="slug" placeholder="Ví dụ: chao-hoi-co-ban")
                  small(class="form-text text-muted") Slug sẽ được tự động tạo từ tiêu đề nếu để trống
              div(class="col-md-3")
                div(class="form-group")
                  label(for="speakingSentencePos" class="form-label") Vị trí 
                  input(type="number" class="form-control" id="speakingSentencePos" name="pos" value="1" min="1")
              div(class="col-md-3")
                div(class="form-group")
                  label(for="speakingSentenceIsActive" class="form-label") Trạng thái hoạt động
                  select(class="form-control" id="speakingSentenceIsActive" name="isActive")
                    option(value="true") Đang hoạt động
                    option(value="false") Ngưng hoạt động
            div(class="form-group")
              label(class="form-label") Danh sách câu 
                span(class="text-danger") *
              div(id="sentencesList" class="speaking-sentence__list")
              button(type="button" class="btn btn-sm btn-outline-primary mt-2" onclick="addSentence()")
                i(class="fas fa-plus")
                |  Thêm câu
        div(class="modal-footer")
          button(type="button" class="btn btn-secondary" data-bs-dismiss="modal") Hủy
          button(type="button" class="btn btn-primary" onclick="saveSpeakingSentence()") Lưu

  div(class="modal fade" id="confirmModal" tabindex="-1" role="dialog" aria-labelledby="confirmModalLabel" aria-hidden="true")
    div(class="modal-dialog" role="document")
      div(class="modal-content")
        div(class="modal-header")
          h5(class="modal-title" id="confirmModalLabel") Xác nhận
          button(type="button" class="close" data-bs-dismiss="modal" aria-label="Close")
            span(aria-hidden="true") &times;
        div(class="modal-body")
          p(id="confirmMessage") Bạn có chắc chắn muốn thực hiện hành động này?
        div(class="modal-footer")
          button(type="button" class="btn btn-secondary" data-bs-dismiss="modal") Hủy
          button(type="button" class="btn btn-danger" id="confirmAction") Xác nhận

block scripts
  script(type="module").
    import { AdminApiBreakpoint } from '/js/api_breakpoint.js'

    const prefixAdmin = '#{prefixAdmin}'
    const topicsData = !{JSON.stringify(topics || [])}
    const levelsData = !{JSON.stringify(levels || [])}

    const topicTitles = {}
    topicsData.forEach(topic => {
      topicTitles[topic._id] = topic.title
    })

    const levelTitles = {}
    levelsData.forEach(level => {
      levelTitles[level._id] = level.title
    })

    let speakingSentencesData = []
    let pagination = { page: 1, limit: 6, total: 0, totalPages: 0, hasNextPage: false, hasPrevPage: false }
    let sentenceCounter = 0

    const state = {
      page: 1,
      limit: 6,
      topic: '',
      level: '',
      isActive: '',
      search: '',
      sortKey: 'pos',
      sortOrder: 'asc'
    }

    const elements = {
      list: null,
      loading: null,
      empty: null,
      paginationInfo: null,
      paginationPrev: null,
      paginationNext: null,
      filterTopic: null,
      filterLevel: null,
      filterIsActive: null,
      filterLimit: null,
      filterSearch: null,
      filterSortKey: null,
      filterSortOrder: null
    }

    function cacheElements() {
      elements.list = document.getElementById('speakingSentencesList')
      elements.loading = document.getElementById('speakingSentencesLoading')
      elements.empty = document.getElementById('speakingSentencesEmpty')
      elements.paginationInfo = document.getElementById('speakingPaginationInfo')
      elements.paginationPrev = document.getElementById('speakingPaginationPrev')
      elements.paginationNext = document.getElementById('speakingPaginationNext')
      elements.filterTopic = document.getElementById('filterTopic')
      elements.filterLevel = document.getElementById('filterLevel')
      elements.filterIsActive = document.getElementById('filterIsActive')
      elements.filterLimit = document.getElementById('filterLimit')
      elements.filterSearch = document.getElementById('filterSearch')
      elements.filterSortKey = document.getElementById('filterSortKey')
      elements.filterSortOrder = document.getElementById('filterSortOrder')
    }

    async function fetchSpeakingSentences() {
      toggleLoading(true)
      const params = new URLSearchParams()
      params.set('page', state.page.toString())
      params.set('limit', state.limit.toString())
      if (state.topic) params.set('topic', state.topic)
      if (state.level) params.set('level', state.level)
      if (state.isActive !== '') params.set('isActive', state.isActive)
      if (state.search) params.set('search', state.search)
      if (state.sortKey) params.set('sortKey', state.sortKey)
      if (state.sortOrder) params.set('sortOrder', state.sortOrder)

      try {
        const response = await fetch(`${AdminApiBreakpoint.GET_SS_LIST}?${params.toString()}`, {
          credentials: 'same-origin'
        })
        const payload = await response.json()
        if (!response.ok) {
          throw payload
        }
        speakingSentencesData = payload.data || []
        const totalItems = payload.pagination?.total || speakingSentencesData.length || 0
        const resultCountEl = document.getElementById('filterResultCount')
        if (resultCountEl) {
          resultCountEl.textContent = `${totalItems} nội dung`
        }
        pagination = {
          page: payload.pagination?.page || state.page,
          limit: payload.pagination?.limit || state.limit,
          total: payload.pagination?.total || 0,
          totalPages: payload.pagination?.totalPages || 0,
          hasNextPage: payload.pagination?.hasNextPage || false,
          hasPrevPage: payload.pagination?.hasPrevPage || false
        }
        renderSpeakingSentences()
        updatePaginationUI()
      } catch (error) {
        const message = error?.message || 'Không thể tải danh sách nội dung'
        showNotification('error', message)
        speakingSentencesData = []
        renderSpeakingSentences()
        updatePaginationUI()
      } finally {
        toggleLoading(false)
      }
    }

    function renderSpeakingSentences() {
      const container = elements.list || document.getElementById('speakingSentencesList')
      if (!container) return
      if (!elements.list) elements.list = container
      container.innerHTML = ''

      if (!speakingSentencesData.length) {
        container.classList.add('d-none')
        toggleEmpty(true)
        return
      }

      container.classList.remove('d-none')
      toggleEmpty(false)

      speakingSentencesData.forEach(item => {
        const topicId = typeof item.topic === 'string' ? item.topic : item.topic?._id
        const levelId = typeof item.level === 'string' ? item.level : item.level?._id
        const topicTitle = item.topic?.title || topicTitles[topicId] || 'N/A'
        const levelTitle = item.level?.title || levelTitles[levelId] || 'N/A'
        const listCount = item.list ? item.list.length : 0

        const createDate = item.create_at ? new Date(item.create_at).toLocaleString('vi-VN') : 'N/A'
        const updateDate = item.update_at ? new Date(item.update_at).toLocaleString('vi-VN') : 'N/A'

        const card = `
          <div class="col-md-6 mb-4">
            <div class="card speaking-sentence__card position-relative">
              <div class="card-body">
                <div class="speaking-sentence__timestamps text-muted small mb-2">
                  ⌚ <span title="Ngày tạo">${createDate}</span> · ⟳ <span title="Ngày cập nhật">${updateDate}</span>
                </div>
                <div class="d-flex justify-content-between align-items-start mb-3 gap-2 position-relative">
                  <div class="flex-grow-1 pe-4" style="min-width: 0;">
                    <h5 class="card-title mb-1 speaking-sentence__title" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; text-overflow: ellipsis; word-wrap: break-word; overflow-wrap: break-word; line-height: 1.4; min-height: 2.8em; max-height: 2.8em;" title="${item.title}">${item.title}</h5>
                    <div class="speaking-sentence__meta">
                      <span class="badge badge-primary me-2">${topicTitle}</span>
                      <span class="badge badge-info me-2">${levelTitle}</span>
                      <span class="badge badge-secondary me-2">${listCount} câu</span>
                      <span class="badge ${item.isActive !== false ? 'badge-success' : 'badge-danger'}">${item.isActive !== false ? 'Đang hoạt động' : 'Ngưng hoạt động'}</span>
                    </div>
                  </div>
                  <div class="speaking-sentence__actions flex-shrink-0" style="white-space: nowrap;">
                    <button class="btn btn-sm btn-info" onclick="editSpeakingSentence('${item._id}')" title="Chỉnh sửa">
                      <i class="fas fa-edit"></i>
                    </button>
                    <button class="btn btn-sm btn-secondary" onclick="copySpeakingSentence('${item._id}')" title="Sao chép">
                      <i class="fas fa-copy"></i>
                    </button>
                    <button class="btn btn-sm btn-danger" onclick="deleteSpeakingSentence('${item._id}')" title="Xóa">
                      <i class="fas fa-trash"></i>
                    </button>
                  </div>
                </div>
                <p class="text-muted mb-1"><strong>Slug:</strong> ${item.slug}</p>
                <p class="text-muted mb-0"><strong>Vị trí:</strong> ${item.pos || '-'}</p>
                ${item.list && item.list.length > 0 ? `
                  <div class="speaking-sentence__preview mt-3">
                    <strong>Xem trước:</strong>
                    <ul class="mt-2 mb-0">
                      ${item.list.slice(0, 2).map(s => `<li>${s.enSentence || s.enText || ''}</li>`).join('')}
                      ${item.list.length > 2 ? `<li class="text-muted">... và ${item.list.length - 2} câu khác</li>` : ''}
                    </ul>
                  </div>
                ` : ''}
              </div>
            </div>
          </div>
        `
        container.innerHTML += card
      })
    }

    function updatePaginationUI() {
      if (elements.paginationInfo) {
        if (pagination.total > 0) {
          const totalPages = Math.max(pagination.totalPages, 1)
          elements.paginationInfo.textContent = `Trang ${pagination.page}/${totalPages} • ${pagination.total} nội dung`
        } else {
          elements.paginationInfo.textContent = 'Không có dữ liệu'
        }
      }
      if (elements.paginationPrev) {
        elements.paginationPrev.disabled = !pagination.hasPrevPage
      }
      if (elements.paginationNext) {
        elements.paginationNext.disabled = !pagination.hasNextPage
      }
    }

    function toggleLoading(show) {
      const loadingEl = elements.loading || document.getElementById('speakingSentencesLoading')
      const listEl = elements.list || document.getElementById('speakingSentencesList')
      if (!loadingEl || !listEl) return
      if (!elements.loading) elements.loading = loadingEl
      if (!elements.list) elements.list = listEl

      if (show) {
        loadingEl.classList.remove('d-none')
        listEl.classList.add('d-none')
        toggleEmpty(false)
      } else {
        loadingEl.classList.add('d-none')
      }
    }

    function toggleEmpty(show) {
      const emptyEl = elements.empty || document.getElementById('speakingSentencesEmpty')
      if (!emptyEl) return
      if (!elements.empty) elements.empty = emptyEl
      if (show) {
        emptyEl.classList.remove('d-none')
      } else {
        emptyEl.classList.add('d-none')
      }
    }

    function populateSelectOptions() {
      const topicSelect = document.getElementById('speakingSentenceTopic')
      const levelSelect = document.getElementById('speakingSentenceLevel')

      if (topicSelect) {
        topicSelect.innerHTML = '<option value="">Chọn chủ đề</option>'
      }
      if (levelSelect) {
        levelSelect.innerHTML = '<option value="">Chọn cấp độ</option>'
      }
      if (elements.filterTopic) {
        elements.filterTopic.innerHTML = '<option value="">Tất cả chủ đề</option>'
      }
      if (elements.filterLevel) {
        elements.filterLevel.innerHTML = '<option value="">Tất cả cấp độ</option>'
      }

      topicsData.forEach(topic => {
        if (topicSelect) {
          const option = document.createElement('option')
          option.value = topic._id
          option.textContent = topic.title
          topicSelect.appendChild(option)
        }
        if (elements.filterTopic) {
          const filterOption = document.createElement('option')
          filterOption.value = topic._id
          filterOption.textContent = topic.title
          elements.filterTopic.appendChild(filterOption)
        }
      })

      levelsData.forEach(level => {
        if (levelSelect) {
          const option = document.createElement('option')
          option.value = level._id
          option.textContent = level.title
          levelSelect.appendChild(option)
        }
        if (elements.filterLevel) {
          const filterOption = document.createElement('option')
          filterOption.value = level._id
          filterOption.textContent = level.title
          elements.filterLevel.appendChild(filterOption)
        }
      })
    }

    function handleFilterEvents() {
      const applyBtn = document.getElementById('filterApplyBtn')
      const resetBtn = document.getElementById('filterResetBtn')

      if (applyBtn) {
        applyBtn.addEventListener('click', () => {
          state.topic = elements.filterTopic?.value || ''
          state.level = elements.filterLevel?.value || ''
          state.isActive = elements.filterIsActive?.value || ''
          state.search = elements.filterSearch?.value.trim() || ''
          state.sortKey = elements.filterSortKey?.value || 'pos'
          state.sortOrder = elements.filterSortOrder?.value || 'asc'
          state.page = 1
          fetchSpeakingSentences()
        })
      }

      if (resetBtn) {
        resetBtn.addEventListener('click', () => {
          state.topic = ''
          state.level = ''
          state.isActive = ''
          state.limit = 6
          state.search = ''
          state.sortKey = 'pos'
          state.sortOrder = 'asc'
          state.page = 1
          if (elements.filterTopic) elements.filterTopic.value = ''
          if (elements.filterLevel) elements.filterLevel.value = ''
          if (elements.filterIsActive) elements.filterIsActive.value = ''
          if (elements.filterLimit) elements.filterLimit.value = '6'
          if (elements.filterSearch) elements.filterSearch.value = ''
          if (elements.filterSortKey) elements.filterSortKey.value = 'pos'
          if (elements.filterSortOrder) elements.filterSortOrder.value = 'asc'
          fetchSpeakingSentences()
        })
      }

      if (elements.filterLimit) {
        elements.filterLimit.value = state.limit.toString()
        elements.filterLimit.addEventListener('change', event => {
          const value = Number(event.target.value) || 6
          state.limit = value
          state.page = 1
          fetchSpeakingSentences()
        })
      }

      if (elements.filterSortKey) {
        elements.filterSortKey.value = state.sortKey
      }

      if (elements.filterSortOrder) {
        elements.filterSortOrder.value = state.sortOrder
      }

      if (elements.paginationPrev) {
        elements.paginationPrev.addEventListener('click', () => {
          if (!pagination.hasPrevPage) return
          state.page = Math.max(1, state.page - 1)
          fetchSpeakingSentences()
        })
      }

      if (elements.paginationNext) {
        elements.paginationNext.addEventListener('click', () => {
          if (!pagination.hasNextPage) return
          state.page += 1
          fetchSpeakingSentences()
        })
      }
    }

    function addSentence() {
      sentenceCounter++
      const sentenceHtml = `
        <div class="speaking-sentence__item mb-3 p-3 border rounded" data-sentence-id="${sentenceCounter}">
          <div class="d-flex justify-content-between align-items-center mb-2">
            <h6 class="mb-0">Câu ${sentenceCounter}</h6>
            <button type="button" class="btn btn-sm btn-danger" onclick="removeSentence(${sentenceCounter})">
              <i class="fas fa-trash"></i>
            </button>
          </div>
          <div class="row mb-2">
            <div class="col-md-2">
              <label class="form-label">Vị trí</label>
              <input type="number" class="form-control form-control-sm speaking-sentence__pos" value="${sentenceCounter}" min="1">
            </div>
            <div class="col-md-10">
              <label class="form-label">Câu tiếng Anh <span class="text-danger">*</span></label>
              <input type="text" class="form-control speaking-sentence__en-sentence" required placeholder="Nhập câu tiếng Anh">
            </div>
          </div>
          <div class="row mb-2">
            <div class="col-md-6">
              <label class="form-label">Câu tiếng Việt <span class="text-danger">*</span></label>
              <input type="text" class="form-control speaking-sentence__vi-sentence" required placeholder="Nhập câu tiếng Việt">
            </div>
            <div class="col-md-6">
              <label class="form-label">Phát âm</label>
              <input type="text" class="form-control speaking-sentence__phonetics" placeholder="Nhập phiên âm">
            </div>
          </div>
          <div class="row mb-2">
            <div class="col-md-12">
              <label class="form-label">URL Audio</label>
              <input type="text" class="form-control speaking-sentence__audio-url" placeholder="Nhập URL audio">
            </div>
          </div>
        </div>
      `
      document.getElementById('sentencesList').insertAdjacentHTML('beforeend', sentenceHtml)
    }

    function removeSentence(sentenceId) {
      const sentenceEl = document.querySelector(`[data-sentence-id="${sentenceId}"]`)
      if (sentenceEl) {
        sentenceEl.remove()
      }
    }

    function openAddModal() {
      document.getElementById('speakingSentenceForm').reset()
      document.getElementById('speakingSentenceId').value = ''
      document.getElementById('speakingSentenceModalLabel').textContent = 'Thêm nội dung phát âm câu mới'
      document.getElementById('sentencesList').innerHTML = ''
      sentenceCounter = 0
      addSentence()
    }

    function populateFormWithItem(item, { isCopy = false } = {}) {
      if (!item) return
      const topicId = typeof item.topic === 'string' ? item.topic : item.topic?._id
      const levelId = typeof item.level === 'string' ? item.level : item.level?._id

      document.getElementById('speakingSentenceId').value = isCopy ? '' : item._id
      document.getElementById('speakingSentenceTitle').value = isCopy
        ? `${item.title} (Copy)`
        : item.title
      document.getElementById('speakingSentenceTopic').value = topicId || ''
      document.getElementById('speakingSentenceLevel').value = levelId || ''
      document.getElementById('speakingSentenceSlug').value = isCopy ? '' : item.slug || ''
      document.getElementById('speakingSentencePos').value = item.pos || 1
      document.getElementById('speakingSentenceIsActive').value = isCopy ? 'true' : (item.isActive !== false ? 'true' : 'false')
      document.getElementById('speakingSentenceModalLabel').textContent = isCopy
        ? 'Sao chép nội dung phát âm câu'
        : 'Chỉnh sửa nội dung phát âm câu'

      document.getElementById('sentencesList').innerHTML = ''
      sentenceCounter = 0

      if (item.list && item.list.length > 0) {
        item.list.forEach(sentence => {
          sentenceCounter++
          const sentenceHtml = `
            <div class="speaking-sentence__item mb-3 p-3 border rounded" data-sentence-id="${sentenceCounter}">
              <div class="d-flex justify-content-between align-items-center mb-2">
                <h6 class="mb-0">Câu ${sentenceCounter}</h6>
                <button type="button" class="btn btn-sm btn-danger" onclick="removeSentence(${sentenceCounter})">
                  <i class="fas fa-trash"></i>
                </button>
              </div>
              <div class="row mb-2">
                <div class="col-md-2">
                  <label class="form-label">Vị trí</label>
                  <input type="number" class="form-control form-control-sm speaking-sentence__pos" value="${sentence.pos || sentenceCounter}" min="1">
                </div>
                <div class="col-md-10">
                  <label class="form-label">Câu tiếng Anh <span class="text-danger">*</span></label>
                  <input type="text" class="form-control speaking-sentence__en-sentence" required value="${sentence.enSentence || ''}" placeholder="Nhập câu tiếng Anh">
                </div>
              </div>
              <div class="row mb-2">
                <div class="col-md-6">
                  <label class="form-label">Câu tiếng Việt <span class="text-danger">*</span></label>
                  <input type="text" class="form-control speaking-sentence__vi-sentence" required value="${sentence.viSentence || ''}" placeholder="Nhập câu tiếng Việt">
                </div>
                <div class="col-md-6">
                  <label class="form-label">Phát âm</label>
                  <input type="text" class="form-control speaking-sentence__phonetics" value="${sentence.phonetics || ''}" placeholder="Nhập phiên âm">
                </div>
              </div>
              <div class="row mb-2">
                <div class="col-md-12">
                  <label class="form-label">URL Audio</label>
                  <input type="text" class="form-control speaking-sentence__audio-url" value="${sentence.audioUrl || ''}" placeholder="Nhập URL audio">
                </div>
              </div>
            </div>
          `
          document.getElementById('sentencesList').insertAdjacentHTML('beforeend', sentenceHtml)
        })
      } else {
        addSentence()
      }

      new bootstrap.Modal(document.getElementById('speakingSentenceModal')).show()
    }

    function editSpeakingSentence(id) {
      const item = speakingSentencesData.find(s => s._id === id)
      if (!item) return
      populateFormWithItem(item)
    }

    function copySpeakingSentence(id) {
      const item = speakingSentencesData.find(s => s._id === id)
      if (!item) return
      populateFormWithItem(item, { isCopy: true })
    }

    function deleteSpeakingSentence(id) {
      showConfirmModal(
        'Xóa nội dung phát âm câu',
        'Bạn có chắc chắn muốn xóa nội dung này? Hành động này không thể hoàn tác!',
        () => {
          fetch(AdminApiBreakpoint.DELETE_SS_LIST, {
            method: 'DELETE',
            headers: {
              'Content-Type': 'application/json'
            },
            credentials: 'same-origin',
            body: JSON.stringify({ id })
          })
            .then(async response => {
              if (!response.ok) {
                const error = await response.json()
                error.status = response.status
                return Promise.reject(error)
              }
              return response.json()
            })
            .then(data => {
              showNotification('success', data.message || 'Đã xóa nội dung thành công!')
              fetchSpeakingSentences()
            })
            .catch(error => {
              let errorMessage = 'Có lỗi xảy ra khi xóa nội dung'
              if (error.status === 422 && error.errors) {
                errorMessage = 'Lỗi validation:\n' + Object.values(error.errors)
                  .map(err => `- ${err.msg || err}`)
                  .join('\n')
              } else if (error.errors) {
                const errorMessages = Object.values(error.errors).map(err => err.msg || err).join(', ')
                errorMessage = errorMessages || error.message || errorMessage
              } else if (error.message) {
                errorMessage = error.message
              }
              showNotification('error', errorMessage)
            })
        }
      )
    }

    function saveSpeakingSentence() {
      const form = document.getElementById('speakingSentenceForm')
      if (!form.checkValidity()) {
        form.reportValidity()
        return
      }

      const id = document.getElementById('speakingSentenceId').value
      const title = document.getElementById('speakingSentenceTitle').value
      const topic = document.getElementById('speakingSentenceTopic').value
      const level = document.getElementById('speakingSentenceLevel').value
      let slug = document.getElementById('speakingSentenceSlug').value.trim()
      const pos = parseInt(document.getElementById('speakingSentencePos').value) || 1
      const isActive = document.getElementById('speakingSentenceIsActive').value === 'true'

      const sentences = []
      const sentenceItems = document.querySelectorAll('.speaking-sentence__item')

      sentenceItems.forEach(sentenceEl => {
        const enSentence = sentenceEl.querySelector('.speaking-sentence__en-sentence').value.trim()
        const viSentence = sentenceEl.querySelector('.speaking-sentence__vi-sentence').value.trim()
        if (!enSentence || !viSentence) return

        const sentencePos = parseInt(sentenceEl.querySelector('.speaking-sentence__pos').value) || 1
        const phonetics = sentenceEl.querySelector('.speaking-sentence__phonetics').value.trim()
        const audioUrl = sentenceEl.querySelector('.speaking-sentence__audio-url').value.trim()

        sentences.push({
          pos: sentencePos,
          enSentence: enSentence,
          viSentence: viSentence,
          phonetics: phonetics || '',
          audioUrl: audioUrl || ''
        })
      })

      if (sentences.length === 0) {
        showNotification('error', 'Vui lòng thêm ít nhất một câu!')
        return
      }

      const ssData = {
        title,
        topic,
        level,
        slug,
        pos,
        isActive,
        list: sentences
      }

      if (id) {
        ssData.id = id
        fetch(AdminApiBreakpoint.UPDATE_SS_LIST, {
          method: 'PUT',
          headers: {
            'Content-Type': 'application/json'
          },
          credentials: 'same-origin',
          body: JSON.stringify(ssData)
        })
          .then(async response => {
            if (!response.ok) {
              const error = await response.json()
              error.status = response.status
              return Promise.reject(error)
            }
            return response.json()
          })
          .then(data => {
            showNotification('success', data.message || 'Đã cập nhật nội dung thành công!')
            bootstrap.Modal.getInstance(document.getElementById('speakingSentenceModal')).hide()
            fetchSpeakingSentences()
          })
          .catch(error => {
            let errorMessage = 'Có lỗi xảy ra khi cập nhật nội dung'
            if (error.status === 422 && error.errors) {
              errorMessage = 'Lỗi validation:\n' + Object.values(error.errors)
                .map(err => `- ${err.msg || err}`)
                .join('\n')
            } else if (error.errors) {
              const errorMessages = Object.values(error.errors).map(err => err.msg || err).join(', ')
              errorMessage = errorMessages || error.message || errorMessage
            } else if (error.message) {
              errorMessage = error.message
            }
            showNotification('error', errorMessage)
          })
      } else {
        fetch(AdminApiBreakpoint.CREATE_SS_LIST, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          credentials: 'same-origin',
          body: JSON.stringify(ssData)
        })
          .then(async response => {
            if (!response.ok) {
              const error = await response.json()
              error.status = response.status
              return Promise.reject(error)
            }
            return response.json()
          })
          .then(data => {
            showNotification('success', data.message || 'Đã thêm nội dung mới thành công!')
            bootstrap.Modal.getInstance(document.getElementById('speakingSentenceModal')).hide()
            fetchSpeakingSentences()
          })
          .catch(error => {
            let errorMessage = 'Có lỗi xảy ra khi thêm nội dung'
            if (error.status === 422 && error.errors) {
              errorMessage = 'Lỗi validation:\n' + Object.values(error.errors)
                .map(err => `- ${err.msg || err}`)
                .join('\n')
            } else if (error.errors) {
              const errorMessages = Object.values(error.errors).map(err => err.msg || err).join(', ')
              errorMessage = errorMessages || error.message || errorMessage
            } else if (error.message) {
              errorMessage = error.message
            }
            showNotification('error', errorMessage)
          })
      }
    }

    function showConfirmModal(title, message, callback) {
      if (typeof swal !== 'undefined') {
        swal({
          title: title,
          text: message,
          icon: 'warning',
          buttons: {
            cancel: 'Hủy',
            confirm: 'Xác nhận'
          },
          dangerMode: true
        }).then((willDelete) => {
          if (willDelete) {
            callback()
          }
        })
      } else {
        document.getElementById('confirmModalLabel').textContent = title
        document.getElementById('confirmMessage').textContent = message

        const confirmBtn = document.getElementById('confirmAction')
        confirmBtn.onclick = () => {
          bootstrap.Modal.getInstance(document.getElementById('confirmModal')).hide()
          callback()
        }

        new bootstrap.Modal(document.getElementById('confirmModal')).show()
      }
    }

    function showNotification(type, message) {
      if (typeof swal !== 'undefined') {
        swal({
          title: type === 'success' ? 'Thành công!' : type === 'error' ? 'Lỗi!' : 'Thông báo',
          text: message,
          icon: type,
          button: 'OK'
        })
      } else {
        alert(message)
      }
    }

    document.addEventListener('DOMContentLoaded', function () {
      cacheElements()
      populateSelectOptions()
      handleFilterEvents()
      fetchSpeakingSentences()

      const currentPath = window.location.pathname
      document.querySelectorAll('.nav-item').forEach(item => {
        item.classList.remove('active')
      })

      if (currentPath.includes('/speaking-sentence')) {
        const ssLink = document.querySelector(`a[href="${prefixAdmin}/speaking-sentence"]`)
        if (ssLink && ssLink.parentElement) {
          ssLink.parentElement.classList.add('active')
          const parentCollapse = ssLink.closest('.collapse')
          if (parentCollapse) {
            parentCollapse.classList.add('show')
            const parentLink = parentCollapse.previousElementSibling
            if (parentLink) {
              parentLink.classList.remove('collapsed')
              parentLink.setAttribute('aria-expanded', 'true')
            }
          }
        }
      }
    })

    window.openAddModal = openAddModal
    window.saveSpeakingSentence = saveSpeakingSentence
    window.editSpeakingSentence = editSpeakingSentence
    window.copySpeakingSentence = copySpeakingSentence
    window.deleteSpeakingSentence = deleteSpeakingSentence
    window.addSentence = addSentence
    window.removeSentence = removeSentence

