extends ../../layouts/default.pug

block head
  style.
    .config-indicators {
      display: flex;
      flex-direction: column;
      gap: 4px;
      font-size: 0.9em;
    }
    .config-indicators div {
      line-height: 1.4;
    }
    .config-indicators code {
      font-size: 0.85em;
      padding: 2px 6px;
      background: #f8f9fa;
      border-radius: 3px;
    }
    .test-result {
      display: flex;
      flex-direction: column;
      gap: 4px;
      align-items: flex-start;
    }
    .test-result .badge {
      margin-left: 0 !important;
    }
    .test-config-column {
      max-width: 300px;
      min-width: 200px;
    }
    .test-message {
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
      text-overflow: ellipsis;
      word-break: break-word;
      line-height: 1.4;
    }
    .config-warning-alert {
      margin-bottom: 1.5rem;
      border: 3px solid #dc3545;
      border-left: 8px solid #dc3545;
      background: linear-gradient(135deg, #fff5f5 0%, #ffe0e0 100%);
      box-shadow: 0 4px 12px rgba(220, 53, 69, 0.3), 0 0 20px rgba(220, 53, 69, 0.15);
      padding: 1.25rem 1.5rem;
      border-radius: 6px;
      animation: pulse-warning 1.5s infinite, glow-warning 2s infinite;
      font-weight: 600;
      font-size: 1.05rem;
      position: relative;
      overflow: hidden;
    }
    .config-warning-alert::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.4), transparent);
      animation: shimmer 2s infinite;
      pointer-events: none;
    }
    .config-warning-alert i {
      color: #dc3545;
      filter: drop-shadow(0 2px 4px rgba(220, 53, 69, 0.4));
      animation: shake-icon 0.5s infinite;
    }
    @keyframes pulse-warning {
      0%, 100% {
        transform: scale(1);
        box-shadow: 0 4px 12px rgba(220, 53, 69, 0.3), 0 0 20px rgba(220, 53, 69, 0.15);
      }
      50% {
        transform: scale(1.01);
        box-shadow: 0 6px 16px rgba(220, 53, 69, 0.4), 0 0 30px rgba(220, 53, 69, 0.25);
      }
    }
    @keyframes glow-warning {
      0%, 100% {
      }
      50% {
        box-shadow: 0 4px 12px rgba(220, 53, 69, 0.5), 0 0 25px rgba(220, 53, 69, 0.3);
      }
    }
    @keyframes shimmer {
      0% {
        transform: translateX(-100%);
      }
      100% {
        transform: translateX(100%);
      }
    }
    @keyframes shake-icon {
      0%, 100% {
        transform: rotate(0deg);
      }
      25% {
        transform: rotate(-5deg);
      }
      75% {
        transform: rotate(5deg);
      }
    }

block main-content
  div(class="page-header")
    ul(class="breadcrumbs")
      li(class="nav-home")
        a(href=`${prefixAdmin}/dashboard`)
          i(class="fas fa-home")
      li(class="separator")
        i(class="fas fa-angle-right")
      li(class="nav-item")
        a(href="#") Cấu hình AI/LLM
      li(class="separator")
        i(class="fas fa-angle-right")
      li(class="nav-item")
        a(href="#") Cấu hình chung

  div(class="row")
    div(class="col-md-12")
      div(class="card")
        div(class="card-header")
          div(class="d-flex align-items-center justify-content-between")
            h4(class="card-title") Cấu hình Gemini
            div(class="d-flex align-items-center gap-3")
              button(type="button" class="btn btn-primary" id="addConfigBtn")
                i(class="fas fa-plus")
                |  Thêm cấu hình
              div(class="form-group mb-0")
                label(class="mb-1") Config đang sử dụng
                select(class="form-control" id="activeConfigSelect")
                  each config in allConfigs
                    - const configId = config._id ? config._id.toString() : ''
                    option(value=configId selected=(config.isActive === true)) #{config.name}
        div(class="card-body")
          - const activeConfigWithError = allConfigs.find(c => c.isActive === true && c.test_config && c.test_config.test_at && c.test_config.success === false)
          if activeConfigWithError
            div(class="alert alert-danger config-warning-alert" role="alert")
              div(class="d-flex align-items-center")
                i(class="fas fa-exclamation-triangle fa-2x mr-3")
                div
                  strong ĐANG SỬ DỤNG CONFIG VỚI TRẠNG THÁI KHI TEST LÀ LỖI. ĐIỀU NÀY CÓ THỂ ẢNH HƯỞNG NGHIÊM TRỌNG TỚI HỆ THỐNG. HÃY KIỂM TRA LẠI !!!
          div(class="table-responsive")
            table(class="table table-striped" id="configsTable")
              thead
                tr
                  th Tên config
                  th Mô tả
                  th Model
                  th Chỉ số mô hình
                  th(class="test-config-column") Test Config
                  th Thao tác
              tbody
                each config in allConfigs
                  - const configId = config._id ? config._id.toString() : ''
                  - const hasTestResult = config.test_config && config.test_config.test_at
                  tr(data-config-id=configId)
                    td
                      strong #{config.name}
                      if config.isActive
                        div(class="mt-1")
                          span(class="badge badge-success") Đang sử dụng
                    td #{config.description || '-'}
                    td
                      code #{config.model}
                    td
                      div(class="config-indicators")
                        div
                          span(class="text-muted") Response MIME Type: 
                          code #{config.config.responseMimeType}
                        div
                          span(class="text-muted") Temperature: 
                          span #{config.config.temperature}
                        if config.config.maxOutputTokens
                          div
                            span(class="text-muted") Max Output Tokens: 
                            span #{config.config.maxOutputTokens}
                        if config.config.topP
                          div
                            span(class="text-muted") Top P: 
                            span #{config.config.topP}
                    td(class="test-config-column")
                      if hasTestResult
                        - const testConfig = config.test_config
                        div(class="test-result")
                          if testConfig.success
                            span(class="badge badge-success mb-1") Thành công
                          else
                            span(class="badge badge-danger mb-1") Thất bại
                          div(class="small text-muted test-message" title=testConfig.message || '-') #{testConfig.message || '-'}
                          if testConfig.test_at
                            div(class="small text-muted") #{new Date(testConfig.test_at).toLocaleString('vi-VN')}
                      else
                        span(class="text-muted") Chưa test
                    td
                      div(class="btn-group")
                        button(class="btn btn-sm btn-info" data-action="view" data-config-id=configId title="Xem chi tiết")
                          i(class="fas fa-eye")
                        button(class="btn btn-sm btn-primary" data-action="duplicate" data-config-id=configId title="Duplicate")
                          i(class="fas fa-copy")
                        if config.name !== 'default'
                          button(class="btn btn-sm btn-danger" data-action="delete" data-config-id=configId title="Xóa")
                            i(class="fas fa-trash")

  div(class="modal fade" id="configDetailModal" tabindex="-1" role="dialog" aria-labelledby="configDetailModalLabel" aria-hidden="true")
    div(class="modal-dialog modal-lg" role="document")
      div(class="modal-content")
        div(class="modal-header")
          h5(class="modal-title" id="configDetailModalLabel") Chi tiết cấu hình
          button(type="button" class="close" onclick="$('#configDetailModal').modal('hide')" aria-label="Close")
            span(aria-hidden="true") &times;
        div(class="modal-body")
          form(id="configForm")
            input(type="hidden" id="configId")
            div(class="form-group")
              label(class="form-label") Tên config
              input(type="text" class="form-control" id="configName" placeholder="Nhập tên config" required)
            div(class="form-group")
              label(class="form-label") Mô tả
              textarea(class="form-control" id="configDescription" rows="2" placeholder="Nhập mô tả")
            div(class="form-group")
              label(class="form-label") Model
              input(type="text" class="form-control" id="configModel" placeholder="Nhập model" required)
            div(class="row")
              div(class="col-md-6")
                div(class="form-group")
                  label(class="form-label") Response MIME Type
                  input(type="text" class="form-control" id="configResponseMimeType" placeholder="application/json" required)
              div(class="col-md-6")
                div(class="form-group")
                  label(class="form-label") Temperature
                  input(type="number" class="form-control" id="configTemperature" step="0.1" min="0" max="2" placeholder="0.3" required)
            div(class="row")
              div(class="col-md-6")
                div(class="form-group")
                  label(class="form-label") Max Output Tokens
                  input(type="number" class="form-control" id="configMaxOutputTokens" step="1" min="1" placeholder="2000")
              div(class="col-md-6")
                div(class="form-group")
                  label(class="form-label") Top P
                  input(type="number" class="form-control" id="configTopP" step="0.01" min="0" max="1" placeholder="0.95")
        div(class="modal-footer")
          button(type="button" class="btn btn-outline-secondary d-none" id="cancelEditBtn" onclick="cancelEditConfig()")
            i(class="fas fa-times")
            |  Hủy chỉnh sửa
          button(type="button" class="btn btn-secondary" data-bs-dismiss="modal") Đóng
          button(type="button" class="btn btn-primary d-none" id="saveConfigBtn" onclick="saveNewConfig()")
            i(class="fas fa-save")
            |  Lưu
          button(type="button" class="btn btn-primary" id="editConfigBtn" onclick="editConfig()")
            i(class="fas fa-edit")
            |  Chỉnh sửa

  div(class="modal fade" id="confirmModal" tabindex="-1" role="dialog" aria-labelledby="confirmModalLabel" aria-hidden="true")
    div(class="modal-dialog" role="document")
      div(class="modal-content")
        div(class="modal-header")
          h5(class="modal-title" id="confirmModalLabel") Xác nhận
          button(type="button" class="close" data-dismiss="modal" aria-label="Close")
            span(aria-hidden="true") &times;
        div(class="modal-body")
          p(id="confirmMessage") Bạn có chắc chắn muốn thực hiện hành động này?
        div(class="modal-footer")
          button(type="button" class="btn btn-secondary" data-dismiss="modal") Hủy
          button(type="button" class="btn btn-danger" id="confirmAction") Xác nhận

block scripts
  script(type="module").
    import { AdminApiBreakpoint } from '/js/api_breakpoint.js'
    const prefixAdmin = "#{prefixAdmin}"
    const activeConfigId = "#{activeConfig._id ? activeConfig._id.toString() : ''}"
    const allConfigsData = !{JSON.stringify(allConfigs)}

    let selectedConfig = null
    let isConfigEditMode = false
    let isNewConfigMode = false

    const activeConfigSelect = document.getElementById('activeConfigSelect')
    const addConfigBtn = document.getElementById('addConfigBtn')
    
    if (addConfigBtn) {
      addConfigBtn.addEventListener('click', function() {
        addNewConfig()
      })
    }
    
    document.addEventListener('DOMContentLoaded', function() {
      const table = document.getElementById('configsTable')
      if (table) {
        table.querySelectorAll('button[data-action]').forEach(button => {
          button.addEventListener('click', function() {
            const action = this.getAttribute('data-action')
            const configId = this.getAttribute('data-config-id')
            switch(action) {
              case 'view':
                viewConfig(configId)
                break
              case 'duplicate':
                duplicateConfig(configId)
                break
              case 'delete':
                deleteConfig(configId)
                break
            }
          })
        })
      }
    })
    
    if (activeConfigSelect) {
      activeConfigSelect.addEventListener('change', async function() {
        const selectedConfigId = this.value
        
        if (selectedConfigId === activeConfigId) {
          return
        }

        if (typeof swal !== 'undefined') {
          swal({
            title: 'Xác nhận',
            text: 'Bạn có chắc chắn muốn thay đổi config đang sử dụng?',
            icon: 'warning',
            buttons: {
              cancel: 'Hủy',
              confirm: 'Xác nhận'
            },
            dangerMode: true
          }).then(async (willChange) => {
            if (willChange) {
              await setActiveConfig(selectedConfigId)
            } else {
              this.value = activeConfigId
            }
          })
        } else {
          const confirmed = confirm('Bạn có chắc chắn muốn thay đổi config đang sử dụng?')
          if (confirmed) {
            await setActiveConfig(selectedConfigId)
          } else {
            this.value = activeConfigId
          }
        }
      })
    }

    async function setActiveConfig(configId) {
      try {
        const response = await fetch(AdminApiBreakpoint.SET_ACTIVE_CONFIG, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({ configId })
        })

        if (!response.ok) {
          const errorText = await response.text()
          let errorData
          try {
            errorData = JSON.parse(errorText)
          } catch {
            errorData = { message: errorText || `HTTP ${response.status}: ${response.statusText}` }
          }
          throw new Error(errorData.message || `HTTP ${response.status}: ${response.statusText}`)
        }

        const result = await response.json()

        if (result.status === 200) {
          showNotification('success', result.message || 'Đã thay đổi config đang sử dụng thành công!')
          setTimeout(() => {
            window.location.reload()
          }, 1000)
        } else {
          showNotification('error', result.message || 'Có lỗi xảy ra khi thay đổi config!')
          activeConfigSelect.value = activeConfigId
        }
      } catch (error) {
        console.error('Error setting active config:', error)
        showNotification('error', error.message || 'Có lỗi xảy ra khi thay đổi config!')
        activeConfigSelect.value = activeConfigId
      }
    }

    function viewConfig(configId) {
      const config = allConfigsData.find(c => c._id && c._id.toString() === configId)
      
      if (!config) {
        showNotification('error', 'Không tìm thấy thông tin config!')
        return
      }

      selectedConfig = JSON.parse(JSON.stringify(config))
      isConfigEditMode = false
      isNewConfigMode = false
      setConfigFormDisabled(true)
      updateConfigEditControls()
      populateConfigFields(selectedConfig)

      $('#configDetailModal').modal('show')
    }

    function setConfigFormDisabled(isDisabled) {
      const editableFieldIds = ['configName', 'configDescription', 'configModel', 'configResponseMimeType', 'configTemperature', 'configMaxOutputTokens', 'configTopP']
      editableFieldIds.forEach(id => {
        const field = document.getElementById(id)
        if (field) {
          field.disabled = isDisabled
        }
      })
    }

    function populateConfigFields(config) {
      document.getElementById('configId').value = config._id ? config._id.toString() : ''
      document.getElementById('configName').value = config.name || ''
      document.getElementById('configDescription').value = config.description || ''
      document.getElementById('configModel').value = config.model || ''
      document.getElementById('configResponseMimeType').value = config.config?.responseMimeType || ''
      document.getElementById('configTemperature').value = config.config?.temperature || ''
      document.getElementById('configMaxOutputTokens').value = config.config?.maxOutputTokens || ''
      document.getElementById('configTopP').value = config.config?.topP || ''
    }

    function updateConfigEditControls() {
      const editBtn = document.getElementById('editConfigBtn')
      const cancelBtn = document.getElementById('cancelEditBtn')
      const saveBtn = document.getElementById('saveConfigBtn')
      if (!editBtn || !cancelBtn || !saveBtn) return

      if (isNewConfigMode) {
        editBtn.classList.add('d-none')
        saveBtn.classList.remove('d-none')
        cancelBtn.classList.remove('d-none')
        document.getElementById('configDetailModalLabel').textContent = 'Thêm cấu hình mới'
      } else if (isConfigEditMode) {
        editBtn.innerHTML = '<i class="fas fa-save"></i> Lưu thông tin'
        editBtn.classList.remove('d-none')
        saveBtn.classList.add('d-none')
        cancelBtn.classList.remove('d-none')
        document.getElementById('configDetailModalLabel').textContent = 'Chỉnh sửa cấu hình'
      } else {
        editBtn.innerHTML = '<i class="fas fa-edit"></i> Chỉnh sửa'
        editBtn.classList.remove('d-none')
        saveBtn.classList.add('d-none')
        cancelBtn.classList.add('d-none')
        document.getElementById('configDetailModalLabel').textContent = 'Chi tiết cấu hình'
      }
    }

    function addNewConfig() {
      selectedConfig = null
      isNewConfigMode = true
      isConfigEditMode = false
      setConfigFormDisabled(false)
      updateConfigEditControls()
      
      document.getElementById('configId').value = ''
      document.getElementById('configName').value = ''
      document.getElementById('configDescription').value = ''
      document.getElementById('configModel').value = 'gemini-2.5-flash-lite'
      document.getElementById('configResponseMimeType').value = 'application/json'
      document.getElementById('configTemperature').value = '0.3'
      document.getElementById('configMaxOutputTokens').value = '2000'
      document.getElementById('configTopP').value = '0.95'
      
      $('#configDetailModal').modal('show')
      
      const nameInput = document.getElementById('configName')
      if (nameInput) {
        nameInput.focus()
      }
    }

    function editConfig() {
      if (isNewConfigMode) {
        saveNewConfig()
        return
      }

      if (!selectedConfig) {
        showNotification('error', 'Không có dữ liệu config để chỉnh sửa!')
        return
      }

      if (!isConfigEditMode) {
        isConfigEditMode = true
        setConfigFormDisabled(false)
        updateConfigEditControls()
        const nameInput = document.getElementById('configName')
        if (nameInput) {
          nameInput.focus()
        }
        return
      }

      saveConfigChanges()
    }

    async function saveNewConfig() {
      const name = document.getElementById('configName').value.trim()
      const description = document.getElementById('configDescription').value.trim()
      const model = document.getElementById('configModel').value.trim()
      const responseMimeType = document.getElementById('configResponseMimeType').value.trim()
      const temperature = parseFloat(document.getElementById('configTemperature').value)
      const maxOutputTokens = document.getElementById('configMaxOutputTokens').value ? parseInt(document.getElementById('configMaxOutputTokens').value) : undefined
      const topP = document.getElementById('configTopP').value ? parseFloat(document.getElementById('configTopP').value) : undefined

      if (!name) {
        showNotification('error', 'Tên config không được để trống!')
        return
      }

      if (!model) {
        showNotification('error', 'Model không được để trống!')
        return
      }

      if (!responseMimeType) {
        showNotification('error', 'Response MIME Type không được để trống!')
        return
      }

      if (isNaN(temperature)) {
        showNotification('error', 'Temperature phải là số!')
        return
      }

      const configData = {
        name,
        description: description || undefined,
        model,
        config: {
          responseMimeType,
          temperature,
          maxOutputTokens,
          topP
        }
      }

      try {
        const response = await fetch(AdminApiBreakpoint.CREATE_CONFIG, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify(configData)
        })

        if (!response.ok) {
          const errorText = await response.text()
          let errorData
          try {
            errorData = JSON.parse(errorText)
          } catch {
            errorData = { message: errorText || `HTTP ${response.status}: ${response.statusText}` }
          }
          throw new Error(errorData.message || `HTTP ${response.status}: ${response.statusText}`)
        }

        const result = await response.json()

        if (result.status === 200) {
          showNotification('success', result.message || 'Đã tạo config thành công!')
          setTimeout(() => {
            window.location.reload()
          }, 1000)
        } else {
          showNotification('error', result.message || 'Có lỗi xảy ra khi tạo config!')
        }
      } catch (error) {
        console.error('Error creating config:', error)
        showNotification('error', error.message || 'Có lỗi xảy ra khi tạo config!')
      }
    }

    function cancelEditConfig() {
      if (isNewConfigMode) {
        isNewConfigMode = false
        $('#configDetailModal').modal('hide')
        return
      }
      if (!selectedConfig) return
      isConfigEditMode = false
      setConfigFormDisabled(true)
      populateConfigFields(selectedConfig)
      updateConfigEditControls()
    }

    async function saveConfigChanges() {
      if (!selectedConfig) return

      const configId = selectedConfig._id.toString()
      const name = document.getElementById('configName').value.trim()
      const description = document.getElementById('configDescription').value.trim()
      const model = document.getElementById('configModel').value.trim()
      const responseMimeType = document.getElementById('configResponseMimeType').value.trim()
      const temperature = parseFloat(document.getElementById('configTemperature').value)
      const maxOutputTokens = document.getElementById('configMaxOutputTokens').value ? parseInt(document.getElementById('configMaxOutputTokens').value) : undefined
      const topP = document.getElementById('configTopP').value ? parseFloat(document.getElementById('configTopP').value) : undefined

      if (!name) {
        showNotification('error', 'Tên config không được để trống!')
        return
      }

      if (!model) {
        showNotification('error', 'Model không được để trống!')
        return
      }

      if (!responseMimeType) {
        showNotification('error', 'Response MIME Type không được để trống!')
        return
      }

      if (isNaN(temperature)) {
        showNotification('error', 'Temperature phải là số!')
        return
      }

      const updateData = {
        configId,
        name,
        description: description || undefined,
        model,
        config: {
          responseMimeType,
          temperature,
          maxOutputTokens,
          topP
        }
      }

      try {
        const response = await fetch(AdminApiBreakpoint.UPDATE_CONFIG, {
          method: 'PUT',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify(updateData)
        })

        if (!response.ok) {
          const errorText = await response.text()
          let errorData
          try {
            errorData = JSON.parse(errorText)
          } catch {
            errorData = { message: errorText || `HTTP ${response.status}: ${response.statusText}` }
          }
          throw new Error(errorData.message || `HTTP ${response.status}: ${response.statusText}`)
        }

        const result = await response.json()

        if (result.status === 200) {
          showNotification('success', result.message || 'Đã cập nhật config thành công!')
          setTimeout(() => {
            window.location.reload()
          }, 1000)
        } else {
          showNotification('error', result.message || 'Có lỗi xảy ra khi cập nhật config!')
        }
      } catch (error) {
        console.error('Error updating config:', error)
        showNotification('error', error.message || 'Có lỗi xảy ra khi cập nhật config!')
      }
    }

    async function duplicateConfig(configId) {
      const config = allConfigsData.find(c => c._id && c._id.toString() === configId)
      
      if (!config) {
        showNotification('error', 'Không tìm thấy config để duplicate!')
        return
      }

      showConfirmModal(
        'Duplicate config',
        `Bạn có chắc chắn muốn duplicate config "${config.name}"?`,
        async () => {
          try {
            const response = await fetch(AdminApiBreakpoint.DUPLICATE_CONFIG, {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json'
              },
              body: JSON.stringify({ configId })
            })

            if (!response.ok) {
              const errorText = await response.text()
              let errorData
              try {
                errorData = JSON.parse(errorText)
              } catch {
                errorData = { message: errorText || `HTTP ${response.status}: ${response.statusText}` }
              }
              throw new Error(errorData.message || `HTTP ${response.status}: ${response.statusText}`)
            }

            const result = await response.json()

            if (result.status === 200) {
              showNotification('success', result.message || 'Đã duplicate config thành công!')
              setTimeout(() => {
                window.location.reload()
              }, 1000)
            } else {
              showNotification('error', result.message || 'Có lỗi xảy ra khi duplicate config!')
            }
          } catch (error) {
            console.error('Error duplicating config:', error)
            showNotification('error', error.message || 'Có lỗi xảy ra khi duplicate config!')
          }
        }
      )
    }

    async function deleteConfig(configId) {
      const config = allConfigsData.find(c => c._id && c._id.toString() === configId)
      
      if (!config) {
        showNotification('error', 'Không tìm thấy config để xóa!')
        return
      }

      if (config.name === 'default') {
        showNotification('error', 'Không thể xóa config mặc định!')
        return
      }

      showConfirmModal(
        'Xóa config',
        `Bạn có chắc chắn muốn xóa config "${config.name}"? Hành động này không thể hoàn tác!`,
        async () => {
          try {
            const response = await fetch(AdminApiBreakpoint.DELETE_CONFIG, {
              method: 'DELETE',
              headers: {
                'Content-Type': 'application/json'
              },
              body: JSON.stringify({ configId })
            })

            if (!response.ok) {
              const errorText = await response.text()
              let errorData
              try {
                errorData = JSON.parse(errorText)
              } catch {
                errorData = { message: errorText || `HTTP ${response.status}: ${response.statusText}` }
              }
              throw new Error(errorData.message || `HTTP ${response.status}: ${response.statusText}`)
            }

            const result = await response.json()

            if (result.status === 200) {
              showNotification('success', result.message || 'Đã xóa config thành công!')
              setTimeout(() => {
                window.location.reload()
              }, 1000)
            } else {
              showNotification('error', result.message || 'Có lỗi xảy ra khi xóa config!')
            }
          } catch (error) {
            console.error('Error deleting config:', error)
            showNotification('error', error.message || 'Có lỗi xảy ra khi xóa config!')
          }
        }
      )
    }

    function showConfirmModal(title, message, callback) {
      if (typeof swal !== 'undefined') {
        swal({
          title: title,
          text: message,
          icon: 'warning',
          buttons: {
            cancel: 'Hủy',
            confirm: 'Xác nhận'
          },
          dangerMode: true
        }).then((willConfirm) => {
          if (willConfirm) {
            callback()
          }
        })
      } else {
        document.getElementById('confirmModalLabel').textContent = title
        document.getElementById('confirmMessage').textContent = message

        const confirmBtn = document.getElementById('confirmAction')
        confirmBtn.onclick = () => {
          $('#confirmModal').modal('hide')
          callback()
        }

        $('#confirmModal').modal('show')
      }
    }

    function showNotification(type, message) {
      if (typeof swal !== 'undefined') {
        swal({
          title: type === 'success' ? 'Thành công!' : type === 'error' ? 'Lỗi!' : 'Thông báo',
          text: message,
          icon: type,
          button: 'OK'
        })
      } else {
        alert(message)
      }
    }

    window.editConfig = editConfig
    window.cancelEditConfig = cancelEditConfig
    window.saveNewConfig = saveNewConfig

