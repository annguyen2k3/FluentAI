              li
                a(href=`${prefixAdmin}/wp`)
                  span(class="sub-item") Luyện viết đoạn văn
              li
                a(href=`${prefixAdmin}/speaking-sentence`)
                  span(class="sub-item") Luyện phát âm (danh sách câu)
              li
                a(href=`${prefixAdmin}/speaking-shadowing`)
                  span(class="sub-item") Luyện phát âm (Shadowing)
              li
                a(href=`${prefixAdmin}/listening-video`)
                  span(class="sub-item") Luyện nghe (video)
        li(class="nav-item")
          a(class="collapsed" data-bs-toggle="collapse" href="#configuration" aria-expanded="false")
            i(class="fas fa-cog")
