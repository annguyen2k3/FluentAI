extends ../layouts/default.pug

block head
    link(rel="stylesheet" href="/css/style.css")

block main-content
    div(class="main-content")
        div(class="row")
            div(class="col-12 col-lg-9")
                // Hero Section
                section(class="hero")
                    div(class="hero__banner")
                        div(class="hero__overlay")
                            h1(class="hero__title") Thông thạo tiếng Anh, sử dụng trôi chảy
                            p(class="hero__description")
                                | Rèn luyện các kỹ năng nền tảng: viết, nghe và phát âm qua các
                                |  tính năng luyện tập với sự hỗ trợ bởi AI
                // Outstanding Features Section
                section(class="features")
                    h2(class="features__title") CHỨC NĂNG NỔI BẬT
                    div(class="row")
                        div(class="col-md-6 col-lg-3 mb-4")
                            div(class="feature-card")
                                span(class="feature-card__badge") Hỗ trợ AI
                                div(class="feature-card__icon feature-card__icon--green")
                                    i(class="fas fa-pencil-alt")
                                h3(class="feature-card__title") Luyện viết câu
                                p(class="feature-card__description")
                                    | Phân tích và đánh giá bài viết của bạn với công nghệ AI tiên tiến, giúp cải thiện ngữ pháp và từ vựng.
                        div(class="col-md-6 col-lg-3 mb-4")
                            div(class="feature-card")
                                div(class="feature-card__icon feature-card__icon--red")
                                    i(class="fas fa-headphones")
                                h3(class="feature-card__title") Luyện nghe
                                p(class="feature-card__description")
                                    | Luyện nghe với audio có transcript và nhiều cấp độ khác nhau, phù hợp với trình độ của bạn.
                        div(class="col-md-6 col-lg-3 mb-4")
                            div(class="feature-card")
                                span(class="feature-card__badge") Hỗ trợ AI
                                div(class="feature-card__icon feature-card__icon--purple")
                                    i(class="fas fa-microphone")
                                h3(class="feature-card__title") Luyện phát âm
                                p(class="feature-card__description")
                                    | Đánh giá phát âm chính xác với AI, giúp bạn cải thiện khả năng nói tiếng Anh một cách hiệu quả.
                        div(class="col-md-6 col-lg-3 mb-4")
                            div(class="feature-card")
                                span(class="feature-card__badge") Hỗ trợ AI
                                div(class="feature-card__icon feature-card__icon--yellow")
                                    i(class="fas fa-font")
                                h3(class="feature-card__title") Từ điển của bạn
                                p(class="feature-card__description")
                                    | Ôn tập từ vựng với giải thích chi tiết từ AI, giúp bạn ghi nhớ và sử dụng từ vựng hiệu quả.
                // Favorite Articles Section
                section(class="articles")
                    h2(class="articles__title") BÀI VIẾT YÊU THÍCH
                    div(class="articles__list")
                        div(class="article-item")
                            h3(class="article-item__title") Các thì cơ bản trong tiếng Anh cho người mới bắt đầu
                        div(class="article-item")
                            h3(class="article-item__title") Từ vựng cho dân IT đi làm thực chiến

            div(class="col-12 col-lg-3")
                // Stats Card
                div(class="stats-card")
                    h3(class="stats-card__title") Biểu đồ chăm chỉ của bạn
                    div(class="stats-card__content")
                        div(class="stats-card__stats")
                            div(class="stat-item")
                                span(class="stat-item__label") Số ngày hoạt động
                                span(class="stat-item__number") 5
                            div(class="stat-item")
                                span(class="stat-item__label") Số điểm tích góp
                                span(class="stat-item__number") 3000
                        div(class="calendar")
                            h4(class="calendar__title") Tháng 10
                            div(class="calendar__grid")
                                // Calendar days will be generated by JavaScript

                // Monthly Ranking
                div(class="ranking-card")
                    h3(class="ranking-card__title")
                        i(class="fas fa-trophy ranking-card__icon")
                        |  XẾP HẠNG THÁNG
                    div(class="ranking-card__content")
                        div(class="ranking-list")
                            div(class="ranking-item ranking-item--first")
                                span(class="ranking-item__position")
                                    i(class="fa-solid fa-medal text-warning")
                                img(src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcTB2dj-B66E69sCgb-EZae-xo5yhQJ4Jr1L-w&s" alt="Avatar" class="ranking-item__avatar")
                                span(class="ranking-item__name") An Nguyễn
                                span(class="ranking-item__points") 300 điểm
                            div(class="ranking-item")
                                span(class="ranking-item__position")
                                    i(class="fa-solid fa-medal text-secondary")
                                img(src="data:image/jpeg;base64,..." alt="Avatar" class="ranking-item__avatar")
                                span(class="ranking-item__name") Chichi
                                span(class="ranking-item__points") 290 điểm
                            div(class="ranking-item")
                                span(class="ranking-item__position")
                                    i(class="fa-solid fa-medal ranking-item__medal--bronze")
                                img(src="data:image/jpeg;base64,..." alt="Avatar" class="ranking-item__avatar")
                                span(class="ranking-item__name") Chichi
                                span(class="ranking-item__points") 290 điểm
                            div(class="ranking-item")
                                span(class="ranking-item__position") #4
                                img(src="data:image/jpeg;base64,..." alt="Avatar" class="ranking-item__avatar")
                                span(class="ranking-item__name") Chichi
                                span(class="ranking-item__points") 290 điểm
                            div(class="ranking-item")
                                span(class="ranking-item__position") #5
                                img(src="data:image/jpeg;base64,..." alt="Avatar" class="ranking-item__avatar")
                                span(class="ranking-item__name") Chichi
                                span(class="ranking-item__points") 290 điểm
                            div(class="ranking-item ranking-item--current")
                                span(class="ranking-item__position") #1774
                                img(src="https://via.placeholder.com/24x24/ff0000/ffffff?text=AN" alt="Avatar" class="ranking-item__avatar")
                                span(class="ranking-item__name") Bạn
                                span(class="ranking-item__points") 50 điểm
                        div(class="ranking-card__footer")
                            a(href="#" class="ranking-card__see-more") Xem thêm →
