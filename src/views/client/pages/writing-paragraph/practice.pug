extends ../../layouts/default.pug
include ../../mixins/loading.pug
include ../../mixins/modalConfirm.pug

block head
    link(rel="stylesheet" href="/css/style.css")

block main-content
    - const historyAttr = hisWPUser ? {'wp-data-history': hisWPUser} : {}
    div(class="practice-header mb-1" wp-data-practice=wp)&attributes(historyAttr)
        h1(class="flex-fill mb-0 fs-3 fw-bold") #{wp.title}
        div(class="practice-header__info")
            div(class="practice-header__credits")
                i(class="fas fa-coins practice-header__icon")
                span #{user.wallet.balance_credit || 0} xu
            div(class="practice-header__divider")
            div(class="practice-header__points")
                i(class="fas fa-star practice-header__icon")
                span(class="practice-header__points-value") #{scoreInfo ? scoreInfo.totalScore : 0} điểm
                span(class="practice-header__points-add d-none") +#{scoreInfo ? scoreInfo.scorePractice : 0}
            div(class="practice-header__divider")
            div(class="practice-header__progress")
                span Tiến độ: <span progress-index>1</span>/<span progress-total>20</span>  câu

    div(class="practice-title-section mb-4")
        div(class="practice-progress")
            div(class="practice-progress__bar")
                div(class="practice-progress__fill" progress-fill style="width: 50%")

    div(class="row")
        div(class="col-lg-8")
            div(class="practice-display mb-4")
                div(class="practice-display__frame")
                    div(class="practice-display__content")
                        p(class="practice-display__text" sentences-display)
                            span(class="sentence-complete") Tommy was very excited to sell lemonade.
                            |
                            span(class="sentence-inprogress") Cậu muốn kiếm tiền mua đồ chơi mới.
                            |  Một ngày nóng nực, cậu pha nước chanh với thứ gì đó khác lạ. Đó là một loại thảo mộc ngộ nghĩnh mà cậu tìm thấy trong vườn. "Chuyện gì sẽ xảy ra?" cậu nghĩ. Cậu mời bạn bè uống. Khi họ nhấp một ngụm, họ phá lên cười. "Có gì trong nước chanh này vậy?" Dani hỏi, khúc khích. Tommy nhún vai, ngạc nhiên nhưng vui vẻ. Mọi người không nhịn được cười. Chẳng mấy chốc, mọi người xếp hàng. Họ muốn uống loại nước chanh đặc biệt này. Tommy cảm thấy tự hào nhưng bối rối. Tại sao mọi người lại cười? Là thảo mộc hay nụ cười bí mật của cậu? Cậu muốn biết. Sau một lúc, một người đàn ông đội mũ lớn đã thử. Ông ấy cười lớn đến nỗi làm rơi cả mũ. Tommy vô cùng kinh ngạc! Liệu loại đồ uống này có thể thay đổi cuộc đời cậu không? Đột nhiên, tiếng cười tràn ngập không khí. Mặt trời chiếu sáng rực rỡ và nụ cười lan tỏa khắp nơi. Tommy biết mình đã làm ra một thứ gì đó đặc biệt. Tiếng cười là phép màu, cậu nghĩ. Làm sao một cậu bé với nước chanh có thể mang lại niềm vui cho mọi người? Cậu mỉm cười, cảm thấy rất vui.

            div(class="practice-input mb-4")
                textarea(class="practice-input__field" placeholder="Nhập bản dịch của bạn tại đây (chỉ nhập câu được hightlight)" rows="2" user_translation)

            div(class="practice-actions")
                button(class="practice-actions__btn practice-actions__btn--quit" button-quit)
                    i(class="fas fa-arrow-left")
                    |  Thoát
                div(class="practice-actions__group")
                    button(class="practice-actions__btn practice-actions__btn--hint")
                        i(class="fas fa-lightbulb")
                        |  Gợi ý
                    button(class="practice-actions__btn practice-actions__btn--submit" button-submit cost-practice=practiceCost)
                        |  Nộp bài #{practiceCost}
                        i(class="fa-brands fa-bitcoin" style="color: #FFD43B;")
                    button(class="practice-actions__btn practice-actions__btn--submit d-none" button-next)
                        | Câu tiếp theo
                        i(class="fas fa-arrow-right")
            
            div(class="practice-reset mt-4 pt-3 border-top")
                button(class="practice-sidebar__action-btn practice-sidebar__action-btn--reset" type="button" reset-history-btn)
                    i(class="fas fa-redo-alt")
                    |  Luyện tập lại từ đầu
            
            div(class="practice-shortcuts mt-4 pt-3 border-top d-none d-lg-block")
                p(class="practice-shortcuts__title mb-2 text-muted small fw-semibold d-flex align-items-center" id="practice-shortcuts-toggle" style="cursor: pointer;")
                    i(class="fas fa-keyboard me-2")
                    | Phím tắt
                    i(class="fas fa-chevron-down practice-shortcuts__arrow ms-2" id="practice-shortcuts-arrow")
                div(class="practice-shortcuts__list d-flex flex-wrap gap-3 d-none" id="practice-shortcuts-list")
                    div(class="practice-shortcuts__item")
                        kbd(class="practice-shortcuts__key") Enter
                        span(class="practice-shortcuts__desc text-muted small") Nộp bài / Câu tiếp theo
                    div(class="practice-shortcuts__item")
                        kbd(class="practice-shortcuts__key") Space
                        span(class="practice-shortcuts__desc text-muted small") Focus vào ô nhập
                    div(class="practice-shortcuts__item")
                        kbd(class="practice-shortcuts__key") Ctrl
                        span(class="practice-shortcuts__plus") +
                        kbd(class="practice-shortcuts__key") H
                        span(class="practice-shortcuts__desc text-muted small") Hiển thị gợi ý

        div(class="col-lg-4")
            div(class="practice-sidebar")
                // AI Evaluation Section
                div(class="practice-sidebar__section")
                    div(class="practice-sidebar__evaluation" id="practice-evaluation")
                        h3(class="practice-feedback__title")
                            i(class="fa-solid fa-robot p-2" style="color: #2107e9;")
                            | Đánh giá từ AI
                        div#wp-loading.practice-feedback__loading(style="display: none;")
                            +loadingIndicator('AI đang chấm bài dịch của bạn...')
                        p(class="practice-feedback__description" feedback-description)
                            | Click 
                            span(class="letter-highlight") Submit
                            |  to get feedback from 
                            span(class="letter-highlight") AI
                            | . The system will review your translation and point out its strengths and areas for improvement.

    

    div(class="hint-modal" id="hintModal")
        div(class="hint-modal__overlay")
        div(class="hint-modal__content")
            div(class="hint-modal__header")
                h4(class="hint-modal__title") Gợi ý
                button(class="hint-modal__close" id="hintModalClose")
                    i(class="fas fa-times")
            div(class="hint-modal__body")
                div(class="hint-modal__items")
                    each hint in wp.hint
                        // Hint Item 1
                        div(class="hint-modal__item")
                            div(class="hint-modal__item-content")
                                div(class="hint-modal__hint-text") #{hint.vocabulary_en}
                                div(class="hint-modal__hint-tag") #{hint.type}
                            div(class="hint-modal__item-details")
                                div(class="hint-modal__meaning")
                                    span(class="hint-modal__label") Nghĩa:
                                    span(class="hint-modal__vietnamese") #{hint.translate}
                                div(class="hint-modal__example")
                                    span(class="hint-modal__label") Ví dụ:
                                    br
                                    span(class="hint-modal__example-text") - #{hint.sentence_example.en} <br> - #{hint.sentence_example.vi}
                                    
    +loadingOverlay('practice-complete-loading', 'Đang chuyển đến trang đánh giá tổng quan...')

    +modalConfirmDanger(
        'wp-reset-modal',
        'Xác nhận xoá lịch sử luyện tập?',
        'Xác nhận xoá lịch sử luyện tập của đoạn văn này và luyện tập lại từ đầu.',
        'Đồng ý',
        'Hủy'
    )

    script#score-info-data(type="application/json") !{JSON.stringify(scoreInfo || { totalScore: 0, scorePractice: 0 })}

    script(src="/js/writing-paragraph.js" type="module")