extends ../../layouts/default.pug
include ../../mixins/loading.pug
include ../../mixins/modalConfirm.pug

block head
    link(rel="stylesheet" href="/css/common.css")
    link(rel="stylesheet" href="/css/layout.css")
    link(rel="stylesheet" href="/css/speaking-sentence.css")

block main-content
    - const totalSentences = sv && Array.isArray(sv.transcript) ? sv.transcript.length : 0
    - const firstSentence = totalSentences ? sv.transcript[0] : null
    - const progressPercentage = totalSentences ? Math.round((1 / totalSentences) * 100) : 0
    - const videoUrl = (sv && (sv.videoUrl || sv.mediaUrl)) || ''
    - const thumbnailUrl = (sv && sv.thumbnailUrl) || ''
    - const ytMatch = videoUrl && videoUrl.match(/^.*(youtu.be\/|v\/|u\/\w\/|embed\/|watch\?v=|&v=)([^#&?]*).*/)
    - const ytId = ytMatch && ytMatch[2] && ytMatch[2].length === 11 ? ytMatch[2] : ''
    - const youtubeEmbedUrl = ytId ? `https://www.youtube.com/embed/${ytId}?enablejsapi=1` : videoUrl

    .practice-header.mb-1
        h1.flex-fill.mb-0.fs-3.fw-bold #{(sv && sv.title) || 'Luyện nói Shadowing video'}
        .practice-header__info
            .practice-header__credits
                i.fas.fa-coins.practice-header__icon
                span #{user.wallet.balance_credit || 0} xu
            .practice-header__divider
            .practice-header__points
                i.fas.fa-star.practice-header__icon
                span.practice-header__points-value #{scoreInfo ? scoreInfo.totalScore : 0} điểm
                span.practice-header__points-add.d-none +#{scoreInfo ? scoreInfo.scorePractice : 0}
            .practice-header__divider
            .practice-header__progress
                span
                    | Hoàn thành: 
                    span#sv-progress-completed 0
                    | /
                    span#sv-progress-total #{totalSentences || 0}
                    |  câu

    .practice-title-section.mb-4
        .practice-progress
            .practice-progress__bar
                .practice-progress__fill#sv-progress-fill(style='width: ' + progressPercentage + '%')

    .row
        .col-lg-8
            .practice-content
                if youtubeEmbedUrl
                    .sv-video
                        .sv-video__frame
                            iframe#sv-youtube-player.sv-video__player(
                                src=youtubeEmbedUrl
                                title="Shadowing video player"
                                frameborder="0"
                                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                                allowfullscreen
                            )
                        .sv-video__controls
                            .sv-video__controls-left
                                .sv-video-toggle
                                    label.sv-video-toggle__switch
                                        input#sv-autoplay-toggle(type="checkbox")
                                        span.sv-video-toggle__slider
                                    span.sv-video-toggle__label Tự động phát
                            .sv-video__controls-right
                                button#sv-toggle-media-btn.btn.btn-outline-secondary.btn-sm(type="button") Ẩn video
                else
                    .alert.alert-warning.mb-3
                        | Chưa có video cho bài shadowing này.

                .practice-sentence
                    h2#sv-sentence-text.practice-sentence__text #{(firstSentence && firstSentence.enText) || 'Đang tải câu luyện tập...'}
                    p#sv-sentence-phonetic.practice-sentence__phonetic #{(firstSentence && firstSentence.phonetics) || ''}
                    p#sv-sentence-translation.practice-sentence__translation #{(firstSentence && firstSentence.viText) || ''}

                    .practice-sentence__actions
                        button#sv-listen-btn.practice-sentence__btn.practice-sentence__btn--listen(type="button")
                            i.fas.fa-volume-up.practice-sentence__btn-icon
                            span.practice-sentence__btn-text Nghe mẫu
                            .practice-sentence__btn-playing(style="display: none;")
                                .practice-sentence__btn-playing-dot
                                span Dừng phát
                        button#sv-record-btn.practice-sentence__btn.practice-sentence__btn--record(type="button")
                            i.fas.fa-microphone.practice-sentence__btn-icon
                            span.practice-sentence__btn-text Thu âm
                            .practice-sentence__btn-recording(style="display: none;")
                                .practice-sentence__btn-recording-dot
                                span Dừng thu
                        button#sv-submit-btn.practice-sentence__btn.practice-sentence__btn--submit(type="button" disabled cost-practice=practiceCost)
                            i.fas.fa-paper-plane
                            |  Nộp #{practiceCost}
                            i.fa-brands.fa-bitcoin(style="color: #ffd43b; margin-left: 4px;")

                    .practice-sentence__navigation
                        button#sv-prev-btn.practice-sentence__nav-btn.practice-sentence__nav-btn--prev(type="button")
                            i.fas.fa-arrow-left
                            |  Câu trước
                        .practice-sentence__preview-audio.mb-3
                            audio#sv-preview-audio(style="display: none;")
                            .practice-recording__container
                                .practice-recording__player
                                    button#sv-preview-play.practice-recording__play-btn(type="button")
                                        i.fas.fa-play
                                    .practice-recording__time#sv-preview-time 0:00 / 0:00
                                    input#sv-preview-progress.practice-recording__progress(type="range" min="0" max="100" value="0" step="0.1")
                                    button#sv-preview-volume-btn.practice-recording__volume-btn(type="button")
                                        i.fas.fa-volume-up
                                    .practice-recording__volume-control(style="display: none;")
                                        input#sv-preview-volume.practice-recording__volume-slider(type="range" min="0" max="100" value="75")
                            .practice-sentence__preview-hint
                                em Nghe lại phát âm của bạn trước khi gửi đánh giá
                            button#sv-preview-clear.practice-recording__clear-btn(type="button")
                                i.fas.fa-times
                        button#sv-next-btn.practice-sentence__nav-btn.practice-sentence__nav-btn--next(type="button")
                            | Câu tiếp theo 
                            i.fas.fa-arrow-right

                .practice-feedback#sv-feedback-section
                    h3.practice-feedback__title
                        i.fa-solid.fa-robot.p-2(style="color: #2107e9;")
                        |  Đánh giá từ AI
                    #sv-ai-loading.practice-feedback__loading(style="display: none;")
                        +loadingIndicator('AI đang đánh giá phần luyện nói của bạn...')
                    .practice-feedback__result.practice-feedback__result--hidden#sv-ai-result-badge
                        i#sv-ai-result-icon.fw-bold
                        span#sv-ai-result-text.fw-semibold
                    p.practice-feedback__intro.fw-semibold.text-dark#sv-ai-intro
                        | Nộp bài <span class="letter-highlight">Phát âm của bạn </span>để nhận phản hồi từ <span class="letter-highlight">AI</span>. Hệ thống sẽ xem xét bản dịch của bạn và chỉ ra những điểm mạnh cũng như những lĩnh vực cần cải thiện.
                    .practice-recording.bg-white.border.rounded-3.p-3.mt-2(id="sv-ai-recording" style="display: none;")
                        h4.practice-feedback__subtitle.text-primary.fw-semibold Your Transcript and Phonetics:
                        .practice-recording__container.practice-recording__container--text-only.mt-2
                            .practice-recording__transcript-box
                                p#sv-ai-transcript.practice-recording__transcript
                            .practice-recording__phonetic-box
                                p#sv-ai-phonetic.practice-recording__phonetic
                    .practice-feedback__suggestions#sv-ai-suggestion-section(style="display: none;")
                        h4.practice-feedback__subtitle.mt-3 Suggestion:
                        .practice-feedback__suggestions-list#sv-ai-suggestions
                    .practice-feedback__comment#sv-ai-comment-section(style="display: none;")
                        h4.practice-feedback__comment-title Nhận xét:
                        p#sv-ai-general-feedback

        .col-lg-4
            .practice-sidebar#sv-sentence-sidebar
                .practice-sidebar__header
                    h3.practice-sidebar__title Danh sách câu
                .practice-sidebar__content
                    .practice-sidebar__list#sv-sidebar-list
                        p.mb-0 Chưa có dữ liệu câu luyện tập
                .practice-sidebar__actions
                    button#sv-reset-btn.practice-sidebar__action-btn.practice-sidebar__action-btn--reset(type="button")
                        i.fas.fa-redo-alt
                        |  Luyện tập lại từ đầu
                    button#sv-quit-btn.practice-sidebar__action-btn.practice-sidebar__action-btn--quit(type="button")
                        i.fas.fa-sign-out-alt
                        |  Thoát

    +modalConfirmDanger(
        'sv-reset-modal',
        'Xác nhận xoá lịch sử luyện tập?',
        'Xác nhận xoá lịch sử luyện tập của bài shadowing này và luyện tập lại từ đầu.',
        'Đồng ý',
        'Hủy'
    )

    script#sv-data(type="application/json") !{JSON.stringify(sv || {})}
    script#his-sv-data(type="application/json") !{JSON.stringify(hisSV || {})}
    script#score-info-data(type="application/json") !{JSON.stringify(scoreInfo || { totalScore: 0, scorePractice: 0 })}

block scripts
    script(type="module").
        import { ApiBreakpoint } from '/js/api_breakpoint.js'

        document.addEventListener('DOMContentLoaded', function () {
            const svDataEl = document.getElementById('sv-data');
            const hisDataEl = document.getElementById('his-sv-data');

            const sidebar = document.getElementById('sv-sentence-sidebar');
            const sidebarListEl = document.getElementById('sv-sidebar-list');

            const sentenceTextEl = document.getElementById('sv-sentence-text');
            const sentencePhoneticEl = document.getElementById('sv-sentence-phonetic');
            const sentenceTranslationEl = document.getElementById('sv-sentence-translation');

            const youtubeEl = document.getElementById('sv-youtube-player');
            const toggleMediaBtn = document.getElementById('sv-toggle-media-btn');
            const autoplayToggleEl = document.getElementById('sv-autoplay-toggle');

            const prevBtn = document.getElementById('sv-prev-btn');
            const nextBtn = document.getElementById('sv-next-btn');
            const quitBtn = document.getElementById('sv-quit-btn');
            const resetBtn = document.getElementById('sv-reset-btn');
            const listenBtn = document.getElementById('sv-listen-btn');

            const recordBtn = document.getElementById('sv-record-btn');
            const submitBtn = document.getElementById('sv-submit-btn');
            const previewAudio = document.getElementById('sv-preview-audio');
            const previewPlayBtn = document.getElementById('sv-preview-play');
            const previewTimeEl = document.getElementById('sv-preview-time');
            const previewProgress = document.getElementById('sv-preview-progress');
            const previewVolumeBtn = document.getElementById('sv-preview-volume-btn');
            const previewVolumeControl = document.querySelector(
                '.practice-recording__volume-control'
            );
            const previewVolumeSlider = document.getElementById('sv-preview-volume');
            const previewClearBtn = document.getElementById('sv-preview-clear');

            const progressCompletedEl = document.getElementById('sv-progress-completed');
            const progressTotalEl = document.getElementById('sv-progress-total');
            const progressFillEl = document.getElementById('sv-progress-fill');

            const feedbackSection = document.getElementById('sv-feedback-section');
            const aiIntroEl = document.getElementById('sv-ai-intro');
            const aiLoadingEl = document.getElementById('sv-ai-loading');
            const aiResultBadge = document.getElementById('sv-ai-result-badge');
            const aiResultIcon = document.getElementById('sv-ai-result-icon');
            const aiResultText = document.getElementById('sv-ai-result-text');
            const aiRecordingSection = document.getElementById('sv-ai-recording');
            const aiTranscriptEl = document.getElementById('sv-ai-transcript');
            const aiPhoneticEl = document.getElementById('sv-ai-phonetic');
            const aiSuggestionsSection = document.getElementById('sv-ai-suggestion-section');
            const aiSuggestionsEl = document.getElementById('sv-ai-suggestions');
            const aiCommentSection = document.getElementById('sv-ai-comment-section');
            const aiGeneralFeedbackEl = document.getElementById('sv-ai-general-feedback');
            const resetModalEl = document.getElementById('sv-reset-modal');
            const resetCancelBtn = document.getElementById('sv-reset-modal-cancel');
            const resetConfirmBtn = document.getElementById('sv-reset-modal-confirm');

            const scoreInfoEl = document.getElementById('score-info-data');
            const rawSV = svDataEl ? svDataEl.textContent : '{}';
            const rawHisSV = hisDataEl ? hisDataEl.textContent : '{}';
            const rawScoreInfo = scoreInfoEl ? scoreInfoEl.textContent : '{}';

            let dataSV;
            let dataHisSV;
            let scoreInfo = { totalScore: 0, scorePractice: 0 };

            try {
                dataSV = JSON.parse(rawSV);
            } catch (error) {
                dataSV = {};
            }

            try {
                dataHisSV = JSON.parse(rawHisSV);
            } catch (error) {
                dataHisSV = {};
            }

            try {
                scoreInfo = JSON.parse(rawScoreInfo) || scoreInfo;
            } catch (error) {
                scoreInfo = { totalScore: 0, scorePractice: 0 };
            }

            const historySentences = Array.isArray(dataHisSV?.sentences) ? dataHisSV.sentences : [];
            const practiceSlug = dataSV?.slug || '';

            const wordAudioCache = new Map();
            let wordAudioElement = null;

            const pointsValueEl = document.querySelector('.practice-header__points-value');
            const pointsAddEl = document.querySelector('.practice-header__points-add');
            const creditsEl = document.querySelector('.practice-header__credits span');
            let currentTotalScore = scoreInfo.totalScore || 0;
            const scorePerPractice = scoreInfo.scorePractice || 0;

            let currentBalanceCredit = 0;
            if (creditsEl) {
                const creditText = creditsEl.textContent || '0 xu';
                const match = creditText.match(/(\d+)/);
                currentBalanceCredit = match ? parseInt(match[1], 10) : 0;
            }

            function animateScoreAdd() {
                if (!pointsValueEl || !pointsAddEl || !scorePerPractice) return;

                const newScore = currentTotalScore + scorePerPractice;
                pointsAddEl.textContent = `+${scorePerPractice}`;
                pointsAddEl.classList.remove('d-none');
                pointsAddEl.style.animation = 'none';

                setTimeout(() => {
                    pointsAddEl.style.animation = 'scoreAddAnimation 0.8s ease-out forwards';
                }, 10);

                let startScore = currentTotalScore;
                const endScore = newScore;
                const duration = 600;
                const startTime = Date.now();

                function updateScore() {
                    const elapsed = Date.now() - startTime;
                    const progress = Math.min(elapsed / duration, 1);

                    const easeOutCubic = 1 - Math.pow(1 - progress, 3);
                    const currentScore = Math.floor(startScore + (endScore - startScore) * easeOutCubic);

                    if (pointsValueEl) {
                        pointsValueEl.textContent = `${currentScore} điểm`;
                    }

                    if (progress < 1) {
                        requestAnimationFrame(updateScore);
                    } else {
                        currentTotalScore = endScore;
                        if (pointsValueEl) {
                            pointsValueEl.textContent = `${currentTotalScore} điểm`;
                        }

                        setTimeout(() => {
                            if (pointsAddEl) {
                                pointsAddEl.classList.add('d-none');
                            }
                        }, 800);
                    }
                }

                requestAnimationFrame(updateScore);
            }

            function animateCreditDeduct(cost) {
                if (!creditsEl) return;

                const newBalance = Math.max(0, currentBalanceCredit - cost);

                const deductEl = document.createElement('span');
                deductEl.className = 'practice-header__credits-deduct';
                deductEl.textContent = `-${cost}`;
                deductEl.style.cssText =
                    'position: absolute; color: #dc3545; font-weight: 700; font-size: 0.9rem; animation: creditDeductAnimation 1s ease-out forwards; pointer-events: none; z-index: 10;';
                creditsEl.parentElement.style.position = 'relative';
                creditsEl.parentElement.appendChild(deductEl);

                let startBalance = currentBalanceCredit;
                const endBalance = newBalance;
                const duration = 600;
                const startTime = Date.now();

                function updateCredit() {
                    const elapsed = Date.now() - startTime;
                    const progress = Math.min(elapsed / duration, 1);

                    const easeOutCubic = 1 - Math.pow(1 - progress, 3);
                    const currentCredit = Math.floor(
                        startBalance + (endBalance - startBalance) * easeOutCubic
                    );

                    if (creditsEl) {
                        creditsEl.textContent = `${currentCredit} xu`;
                    }

                    if (progress < 1) {
                        requestAnimationFrame(updateCredit);
                    } else {
                        currentBalanceCredit = endBalance;
                        if (creditsEl) {
                            creditsEl.textContent = `${currentBalanceCredit} xu`;
                        }

                        setTimeout(() => {
                            if (deductEl && deductEl.parentElement) {
                                deductEl.parentElement.removeChild(deductEl);
                            }
                        }, 1000);
                    }
                }

                requestAnimationFrame(updateCredit);
            }

            const bodyScrollState = {
                locked: false,
                overflow: '',
                paddingRight: ''
            };

            const requestPracticeAudio = async (text) => {
                if (!text) return null;
                try {
                    const response = await fetch(ApiBreakpoint.POST_PRACTICE_SS_AUDIO, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({ text })
                    });

                    if (!response.ok) {
                        throw new Error('Failed to generate audio');
                    }

                    const payload = await response.json();
                    if (payload?.audio) {
                        const mimeType = payload.contentType || 'audio/mpeg';
                        return `data:${mimeType};base64,${payload.audio}`;
                    }
                    return null;
                } catch (error) {
                    console.error('Không tạo được audio:', error);
                    if (typeof window.alertError === 'function') {
                        window.alertError('Không tạo được audio mẫu, vui lòng thử lại.');
                    }
                    return null;
                }
            };

            const playWordAudio = async (word) => {
                if (!word || !word.trim()) return;

                const normalizedWord = word.trim().toLowerCase();

                if (!wordAudioElement) {
                    wordAudioElement = document.createElement('audio');
                    wordAudioElement.style.display = 'none';
                    document.body.appendChild(wordAudioElement);
                }

                if (wordAudioCache.has(normalizedWord)) {
                    wordAudioElement.src = wordAudioCache.get(normalizedWord);
                    wordAudioElement.play().catch(error => {
                        console.error('Không thể phát audio:', error);
                    });
                    return;
                }

                try {
                    const generatedAudio = await requestPracticeAudio(normalizedWord);
                    if (!generatedAudio) {
                        if (typeof window.alertError === 'function') {
                            window.alertError('Không tạo được audio cho từ này.');
                        }
                        return;
                    }

                    wordAudioCache.set(normalizedWord, generatedAudio);
                    wordAudioElement.src = generatedAudio;
                    wordAudioElement.play().catch(error => {
                        console.error('Không thể phát audio:', error);
                    });
                } catch (error) {
                    console.error('Lỗi khi phát audio từ:', error);
                    if (typeof window.alertError === 'function') {
                        window.alertError('Không thể phát âm từ này.');
                    }
                }
            };

            const statusConfig = {
                not_started: { label: 'Chưa luyện tập', itemClass: '', statusClass: '' },
                completed: { label: 'Hoàn thành', itemClass: 'practice-sidebar__item--completed', statusClass: 'practice-sidebar__item-status--completed' },
                need_repair: { label: 'Cần chỉnh sửa', itemClass: 'practice-sidebar__item--error', statusClass: 'practice-sidebar__item-status--error' },
                in_progress: { label: 'Đang luyện tập', itemClass: '', statusClass: 'practice-sidebar__item-status--in-progress' }
            };

            let completedCount = 0;

            const mergedSentences = Array.isArray(dataSV?.transcript)
                ? dataSV.transcript.map((sentence) => {
                      const matchedHistory = historySentences.find((hisSentence) => {
                          if (!hisSentence) return false;
                          if (hisSentence.enSentence && sentence.enText) {
                              return hisSentence.enSentence === sentence.enText;
                          }
                          if (hisSentence.enText && sentence.enText) {
                              return hisSentence.enText === sentence.enText;
                          }
                          return false;
                      });

                      if (!matchedHistory) {
                          return {
                              ...sentence,
                              status: 'not_started'
                          };
                      }

                      if (matchedHistory.passed) {
                          completedCount += 1;
                      }

                      return {
                          ...sentence,
                          status: matchedHistory.passed ? 'completed' : 'need_repair',
                          evaluate: {
                              passed: matchedHistory.passed,
                              enSentence: matchedHistory.enSentence || matchedHistory.enText || sentence.enText,
                              user_transcript: matchedHistory.user_transcript || '',
                              user_phonetics: matchedHistory.user_phonetics || '',
                              user_suggestions: Array.isArray(matchedHistory.user_suggestions) ? matchedHistory.user_suggestions : [],
                              general_feedback: matchedHistory.general_feedback || ''
                          }
                      };
                  })
                : [];

            let initialIndex = 0;
            if (mergedSentences.length) {
                const firstNotCompletedIndex = mergedSentences.findIndex((s) => s.status !== 'completed');
                initialIndex = firstNotCompletedIndex !== -1 ? firstNotCompletedIndex : 0;
            }

            const state = {
                sentences: mergedSentences,
                currentIndex: initialIndex
            };

            const AUTOPLAY_STORAGE_KEY = 'autoplay-video';

            const youtubeState = {
                player: null,
                ready: false,
                syncIntervalId: null,
                stopTimeoutId: null
            };

            const autoplayState = {
                enabled: true
            };

            const rawAutoplay = localStorage.getItem(AUTOPLAY_STORAGE_KEY);
            if (rawAutoplay === null) {
                localStorage.setItem(AUTOPLAY_STORAGE_KEY, 'true');
                autoplayState.enabled = true;
            } else {
                autoplayState.enabled = rawAutoplay === 'true';
            }

            if (autoplayToggleEl) {
                autoplayToggleEl.checked = autoplayState.enabled;
                autoplayToggleEl.addEventListener('change', function () {
                    autoplayState.enabled = !!this.checked;
                    localStorage.setItem(AUTOPLAY_STORAGE_KEY, autoplayState.enabled ? 'true' : 'false');
                });
            }

            const getSentenceStart = (sentence) => {
                if (!sentence) return 0;
                if (typeof sentence.startTime === 'number') return sentence.startTime;
                if (typeof sentence.start === 'number') return sentence.start;
                if (typeof sentence.startSecond === 'number') return sentence.startSecond;
                return 0;
            };

            const getSentenceEnd = (sentence) => {
                if (!sentence) return 0;
                if (typeof sentence.endTime === 'number') return sentence.endTime;
                if (typeof sentence.end === 'number') return sentence.end;
                if (typeof sentence.endSecond === 'number') return sentence.endSecond;
                return 0;
            };

            const formatTime = (seconds) => {
                const safeSeconds = Math.max(0, Math.floor(seconds || 0));
                const mins = Math.floor(safeSeconds / 60);
                const secs = safeSeconds % 60;
                return `${mins}:${secs.toString().padStart(2, '0')}`;
            };

            const clearSentenceStopTimer = () => {
                if (youtubeState.stopTimeoutId) {
                    clearTimeout(youtubeState.stopTimeoutId);
                    youtubeState.stopTimeoutId = null;
                }
            };

            const seekVideoToSentence = (sentence) => {
                if (!youtubeState.player || !sentence) return;
                clearSentenceStopTimer();
                const rawStart = getSentenceStart(sentence);
                const rawEnd = getSentenceEnd(sentence);
                const paddedStart = Number.isFinite(rawStart) ? Math.max(rawStart - 1, 0) : 0;
                const paddedEnd =
                    Number.isFinite(rawEnd) && rawEnd > rawStart ? rawEnd + 1 : rawStart + 2;

                if (Number.isFinite(paddedStart)) {
                    youtubeState.player.seekTo(Math.max(paddedStart, 0), true);
                }
                if (autoplayState.enabled) {
                    youtubeState.player.playVideo();
                } else {
                    youtubeState.player.playVideo();
                    if (
                        Number.isFinite(paddedStart) &&
                        Number.isFinite(paddedEnd) &&
                        paddedEnd > paddedStart
                    ) {
                        const durationMs = (paddedEnd - paddedStart) * 1000;
                        youtubeState.stopTimeoutId = window.setTimeout(() => {
                            try {
                                youtubeState.player.pauseVideo();
                            } catch (error) {}
                        }, durationMs);
                    }
                }
            };

            const syncSentenceWithVideo = () => {
                if (!youtubeState.player || !autoplayState.enabled || !state.sentences.length) return;
                let currentTime = 0;
                try {
                    const t = youtubeState.player.getCurrentTime && youtubeState.player.getCurrentTime();
                    if (typeof t === 'number' && !isNaN(t)) {
                        currentTime = t;
                    }
                } catch (error) {
                    return;
                }

                for (let i = 0; i < state.sentences.length; i++) {
                    const s = state.sentences[i];
                    const start = getSentenceStart(s);
                    const end = getSentenceEnd(s) || start;
                    if (currentTime >= start && currentTime < (end || start + 0.1)) {
                        if (state.currentIndex !== i) {
                            state.currentIndex = i;
                            renderSentence();
                            renderSidebar();
                        }
                        break;
                    }
                }
            };

            const startVideoSync = () => {
                if (youtubeState.syncIntervalId) return;
                youtubeState.syncIntervalId = window.setInterval(syncSentenceWithVideo, 500);
            };

            const stopVideoSync = () => {
                if (youtubeState.syncIntervalId) {
                    clearInterval(youtubeState.syncIntervalId);
                    youtubeState.syncIntervalId = null;
                }
            };

            const renderProgress = () => {
                if (!progressCompletedEl || !progressTotalEl || !progressFillEl) return;
                const total = state.sentences.length || 0;
                const completed = state.sentences.filter((s) => s.status === 'completed').length;
                progressCompletedEl.textContent = completed;
                progressTotalEl.textContent = total;
                progressFillEl.style.width = total ? `${(completed / total) * 100}%` : '0%';
            };

            const renderAISuggestions = (evaluate) => {
                if (!aiTranscriptEl || !aiSuggestionsEl || !aiGeneralFeedbackEl) return;

                if (feedbackSection) {
                    feedbackSection.classList.remove('practice-feedback--loading');
                }

                if (aiIntroEl) {
                    aiIntroEl.style.display = 'none';
                }

                if (aiLoadingEl) {
                    aiLoadingEl.style.display = 'none';
                }

                if (aiRecordingSection) {
                    aiRecordingSection.style.display = '';
                }

                if (aiResultBadge && aiResultIcon && aiResultText) {
                    if (typeof evaluate?.passed === 'boolean') {
                        aiResultBadge.classList.remove('practice-feedback__result--hidden');
                        aiResultBadge.classList.remove(
                            'practice-feedback__result--success',
                            'practice-feedback__result--fail'
                        );

                        if (evaluate.passed) {
                            aiResultBadge.classList.add('practice-feedback__result--success');
                            aiResultIcon.className = 'fas fa-check-circle';
                            aiResultText.textContent = 'Tuyệt, phát âm tốt!';
                        } else {
                            aiResultBadge.classList.add('practice-feedback__result--fail');
                            aiResultIcon.className = 'fas fa-times-circle';
                            aiResultText.textContent = 'Cần cải thiện';
                        }
                    } else {
                        aiResultBadge.classList.add('practice-feedback__result--hidden');
                    }
                }

                aiTranscriptEl.textContent = evaluate?.user_transcript || '';

                if (aiPhoneticEl) {
                    aiPhoneticEl.textContent = evaluate?.user_phonetics || '';
                }

                aiSuggestionsEl.innerHTML = '';
                const suggestions = Array.isArray(evaluate?.user_suggestions)
                    ? evaluate.user_suggestions
                    : [];

                if (aiSuggestionsSection) {
                    aiSuggestionsSection.style.display = suggestions.length ? '' : 'none';
                }

                if (suggestions.length) {
                    suggestions.forEach((s) => {
                        const item = document.createElement('div');
                        item.className = 'practice-feedback__item';

                        const word = document.createElement('div');
                        word.className = 'practice-feedback__word';

                        const icon = document.createElement('i');
                        icon.className = 'fas fa-times practice-feedback__icon practice-feedback__icon--error';

                        const wordText = document.createElement('span');
                        wordText.className = 'practice-feedback__word-text';
                        wordText.textContent = s.word || '';

                        const speaker = document.createElement('i');
                        speaker.className = 'fas fa-volume-up practice-feedback__speaker';
                        speaker.style.cursor = 'pointer';
                        speaker.addEventListener('click', async function() {
                            const wordToPlay = s.word || '';
                            if (!wordToPlay.trim()) return;
                            await playWordAudio(wordToPlay.trim());
                        });

                        word.appendChild(icon);
                        word.appendChild(wordText);
                        word.appendChild(speaker);

                        const details = document.createElement('div');
                        details.className = 'practice-feedback__details';

                        if (s.feedback_issue) {
                            const issue = document.createElement('div');
                            issue.className = 'practice-feedback__issue';
                            const warnIcon = document.createElement('i');
                            warnIcon.className = 'fas fa-exclamation-triangle practice-feedback__warning';
                            const p = document.createElement('p');
                            p.textContent = s.feedback_issue;
                            issue.appendChild(warnIcon);
                            issue.appendChild(p);
                            details.appendChild(issue);
                        }

                        if (s.feedback_tip) {
                            const tip = document.createElement('div');
                            tip.className = 'practice-feedback__tip';
                            const checkIcon = document.createElement('i');
                            checkIcon.className = 'fas fa-check practice-feedback__check';
                            const p = document.createElement('p');
                            p.textContent = s.feedback_tip;
                            tip.appendChild(checkIcon);
                            tip.appendChild(p);
                            details.appendChild(tip);
                        }

                        item.appendChild(word);
                        item.appendChild(details);
                        aiSuggestionsEl.appendChild(item);
                    });
                }

                const generalFeedback = (evaluate?.general_feedback || '').trim();
                aiGeneralFeedbackEl.textContent = generalFeedback;

                if (aiCommentSection) {
                    aiCommentSection.classList.remove(
                        'practice-feedback__comment--success',
                        'practice-feedback__comment--fail'
                    );

                    if (generalFeedback) {
                        const isPassed = evaluate?.passed !== false;
                        aiCommentSection.style.display = '';
                        aiCommentSection.classList.add(
                            isPassed
                                ? 'practice-feedback__comment--success'
                                : 'practice-feedback__comment--fail'
                        );
                    } else {
                        aiCommentSection.style.display = 'none';
                    }
                }
            };

            const resetAIFeedback = () => {
                if (feedbackSection) {
                    feedbackSection.classList.remove('practice-feedback--loading');
                }
                if (aiIntroEl) {
                    aiIntroEl.style.display = '';
                }
                if (aiLoadingEl) {
                    aiLoadingEl.style.display = 'none';
                }
                if (aiRecordingSection) {
                    aiRecordingSection.style.display = 'none';
                }
                if (aiResultBadge) {
                    aiResultBadge.classList.add('practice-feedback__result--hidden');
                }
                if (aiSuggestionsSection) {
                    aiSuggestionsSection.style.display = 'none';
                }
                if (aiCommentSection) {
                    aiCommentSection.style.display = 'none';
                }
                if (aiTranscriptEl) {
                    aiTranscriptEl.textContent = '';
                }
                if (aiPhoneticEl) {
                    aiPhoneticEl.textContent = '';
                }
                if (aiSuggestionsEl) {
                    aiSuggestionsEl.innerHTML = '';
                }
                if (aiGeneralFeedbackEl) {
                    aiGeneralFeedbackEl.textContent = '';
                }
            };

            const lockBodyScroll = () => {
                if (!document.body || bodyScrollState.locked) return;
                const scrollBarWidth = window.innerWidth - document.documentElement.clientWidth;
                bodyScrollState.locked = true;
                bodyScrollState.overflow = document.body.style.overflow || '';
                bodyScrollState.paddingRight = document.body.style.paddingRight || '';
                document.body.style.overflow = 'hidden';
                if (scrollBarWidth > 0) {
                    document.body.style.paddingRight = `${scrollBarWidth}px`;
                }
            };

            const unlockBodyScroll = () => {
                if (!document.body || !bodyScrollState.locked) return;
                document.body.style.overflow = bodyScrollState.overflow;
                document.body.style.paddingRight = bodyScrollState.paddingRight;
                bodyScrollState.locked = false;
            };

            const showResetModal = () => {
                if (!resetModalEl) return;
                resetModalEl.classList.add('practice-reset-modal--visible');
                lockBodyScroll();
            };

            const hideResetModal = () => {
                if (!resetModalEl) return;
                resetModalEl.classList.remove('practice-reset-modal--visible');
                unlockBodyScroll();
            };

            const renderSentence = () => {
                clearPreviewRecording();

                if (!state.sentences.length) {
                    if (sentenceTextEl) sentenceTextEl.textContent = 'Chưa có câu luyện tập';
                    if (sentencePhoneticEl) sentencePhoneticEl.textContent = '';
                    if (sentenceTranslationEl) sentenceTranslationEl.textContent = 'Vui lòng quay lại sau.';
                    if (prevBtn) prevBtn.disabled = true;
                    if (nextBtn) nextBtn.disabled = true;
                    resetAIFeedback();
                    return;
                }

                const currentSentence = state.sentences[state.currentIndex];

                if (sentenceTextEl) sentenceTextEl.textContent = currentSentence?.enText || '';
                if (sentencePhoneticEl) sentencePhoneticEl.textContent = currentSentence?.phonetics || '';
                if (sentenceTranslationEl) sentenceTranslationEl.textContent = currentSentence?.viText || '';

                if (prevBtn) prevBtn.disabled = state.currentIndex === 0;
                if (nextBtn) nextBtn.disabled = state.currentIndex === state.sentences.length - 1;

                if (currentSentence.evaluate) {
                    renderAISuggestions(currentSentence.evaluate);
                } else {
                    resetAIFeedback();
                }
            };

            const renderSidebar = () => {
                if (!sidebarListEl) return;
                sidebarListEl.innerHTML = '';

                if (!state.sentences.length) {
                    const emptyMsg = document.createElement('p');
                    emptyMsg.className = 'mb-0';
                    emptyMsg.textContent = 'Chưa có dữ liệu câu luyện tập';
                    sidebarListEl.appendChild(emptyMsg);
                    return;
                }

                state.sentences.forEach((sentence, index) => {
                    const item = document.createElement('div');
                    item.className = 'practice-sidebar__item';

                    const isActive = index === state.currentIndex;
                    const sentenceStatus = isActive ? 'in_progress' : sentence.status || 'not_started';
                    const statusMeta = statusConfig[sentenceStatus] || statusConfig.not_started;

                    if (isActive) {
                        item.classList.add('practice-sidebar__item--active');
                    } else if (statusMeta.itemClass) {
                        item.classList.add(statusMeta.itemClass);
                    }

                    const numberEl = document.createElement('div');
                    numberEl.className = 'practice-sidebar__item-number';
                    numberEl.textContent = index + 1;

                    const contentEl = document.createElement('div');
                    contentEl.className = 'practice-sidebar__item-content';

                    const textEl = document.createElement('p');
                    textEl.className = 'practice-sidebar__item-text';
                    textEl.textContent = sentence.enText || '';

                    const metaRow = document.createElement('div');
                    metaRow.className = 'd-flex justify-content-between align-items-center mt-1';

                    const timeEl = document.createElement('span');
                    timeEl.className = 'practice-sidebar__item-time text-muted';
                    const start = getSentenceStart(sentence);
                    const end = getSentenceEnd(sentence);
                    timeEl.textContent = `${formatTime(start)} - ${formatTime(end)}`;

                    const statusEl = document.createElement('span');
                    statusEl.className = 'practice-sidebar__item-status';
                    if (statusMeta.statusClass) {
                        statusEl.classList.add(statusMeta.statusClass);
                    }
                    statusEl.textContent = statusMeta.label;

                    metaRow.appendChild(timeEl);
                    metaRow.appendChild(statusEl);

                    contentEl.appendChild(textEl);
                    contentEl.appendChild(metaRow);

                    item.appendChild(numberEl);
                    item.appendChild(contentEl);

                    item.addEventListener('click', function () {
                        state.currentIndex = index;
                        renderSentence();
                        renderSidebar();
                        const current = state.sentences[state.currentIndex];
                        seekVideoToSentence(current);
                    });

                    sidebarListEl.appendChild(item);
                });
            };

            const goToPrevious = () => {
                if (!state.sentences.length || state.currentIndex === 0) return;
                state.currentIndex -= 1;
                renderSentence();
                renderSidebar();
                const current = state.sentences[state.currentIndex];
                seekVideoToSentence(current);
            };

            const goToNext = () => {
                if (!state.sentences.length || state.currentIndex >= state.sentences.length - 1) return;
                state.currentIndex += 1;
                renderSentence();
                renderSidebar();
                const current = state.sentences[state.currentIndex];
                seekVideoToSentence(current);
            };

            if (prevBtn) {
                prevBtn.addEventListener('click', goToPrevious);
            }

            if (nextBtn) {
                nextBtn.addEventListener('click', goToNext);
            }

            const updateListenVisual = (playing) => {
                if (!listenBtn) return;
                const icon = listenBtn.querySelector('.practice-sentence__btn-icon');
                const text = listenBtn.querySelector('.practice-sentence__btn-text');
                const playingEl = listenBtn.querySelector(
                    '.practice-sentence__btn-playing'
                );

                if (playing) {
                    if (icon) icon.style.display = 'none';
                    if (text) text.style.display = 'none';
                    if (playingEl) playingEl.style.display = 'flex';
                    listenBtn.classList.add('practice-sentence__btn--playing');
                } else {
                    if (icon) icon.style.display = 'inline-block';
                    if (text) text.style.display = 'inline';
                    if (playingEl) playingEl.style.display = 'none';
                    listenBtn.classList.remove('practice-sentence__btn--playing');
                }
            };

            if (listenBtn) {
                listenBtn.addEventListener('click', function () {
                    if (!state.sentences.length) return;

                    if (youtubeState.player && typeof YT !== 'undefined') {
                        const playerState = youtubeState.player.getPlayerState
                            ? youtubeState.player.getPlayerState()
                            : null;
                        if (playerState === YT.PlayerState.PLAYING) {
                            clearSentenceStopTimer();
                            youtubeState.player.pauseVideo();
                            updateListenVisual(false);
                            return;
                        }
                    }

                    const current = state.sentences[state.currentIndex];
                    seekVideoToSentence(current);
                    updateListenVisual(true);
                });
            }

            // Ghi âm và preview (tương tự SS practice)
            let mediaRecorder = null;
            let audioChunks = [];
            let isRecording = false;
            let recordedAudioBlob = null;
            let recordingStartTime = null;
            let recordingTimer = null;

            const clearPreviewRecording = () => {
                recordedAudioBlob = null;

                if (previewAudio) {
                    previewAudio.pause();
                    previewAudio.currentTime = 0;
                    previewAudio.removeAttribute('src');
                    previewAudio.load();
                }

                if (previewTimeEl) {
                    previewTimeEl.textContent = '0:00 / 0:00';
                }

                if (previewProgress) {
                    previewProgress.value = 0;
                    previewProgress.max = 100;
                }

                if (previewPlayBtn) {
                    const icon = previewPlayBtn.querySelector('i');
                    if (icon) {
                        icon.classList.remove('fa-pause');
                        icon.classList.add('fa-play');
                    }
                }

                if (submitBtn) {
                    submitBtn.disabled = true;
                }
            };

            clearPreviewRecording();

            if (recordBtn) {
                recordBtn.addEventListener('click', async function () {
                    if (!isRecording) {
                        try {
                            const stream = await navigator.mediaDevices.getUserMedia({
                                audio: true
                            });
                            mediaRecorder = new MediaRecorder(stream);
                            audioChunks = [];

                            mediaRecorder.ondataavailable = function (event) {
                                if (event.data.size > 0) {
                                    audioChunks.push(event.data);
                                }
                            };

                            mediaRecorder.onstop = function () {
                                recordedAudioBlob = new Blob(audioChunks, {
                                    type: 'audio/webm'
                                });
                                const audioUrl = URL.createObjectURL(recordedAudioBlob);

                                stream.getTracks().forEach((track) => track.stop());

                                if (previewAudio) {
                                    previewAudio.src = audioUrl;
                                    previewAudio.load();

                                    previewAudio.addEventListener(
                                        'loadedmetadata',
                                        function () {
                                            if (previewTimeEl) {
                                                const duration = Math.floor(
                                                    previewAudio.duration
                                                );
                                                previewTimeEl.textContent = `0:00 / ${formatTime(
                                                    duration
                                                )}`;
                                            }
                                        },
                                        { once: true }
                                    );
                                }
                                if (submitBtn) {
                                    submitBtn.disabled = false;
                                }
                            };

                            mediaRecorder.start();
                            isRecording = true;
                            recordingStartTime = Date.now();

                            const icon = recordBtn.querySelector(
                                '.practice-sentence__btn-icon'
                            );
                            const text = recordBtn.querySelector(
                                '.practice-sentence__btn-text'
                            );
                            const recording = recordBtn.querySelector(
                                '.practice-sentence__btn-recording'
                            );

                            if (icon) icon.style.display = 'none';
                            if (text) text.style.display = 'none';
                            if (recording) recording.style.display = 'flex';
                            recordBtn.classList.add(
                                'practice-sentence__btn--recording'
                            );

                            if (recording) {
                                const timeSpan = recording.querySelector('span');
                                if (timeSpan) {
                                    recordingTimer = setInterval(() => {
                                        const elapsed = Math.floor(
                                            (Date.now() - recordingStartTime) / 1000
                                        );
                                        timeSpan.textContent = `Dừng thu (${formatTime(
                                            elapsed
                                        )})`;
                                    }, 1000);
                                }
                            }
                        } catch (error) {
                            console.error('Lỗi khi truy cập microphone:', error);
                            alert(
                                'Không thể truy cập microphone. Vui lòng kiểm tra quyền truy cập.'
                            );
                        }
                    } else {
                        if (mediaRecorder && mediaRecorder.state !== 'inactive') {
                            mediaRecorder.stop();
                        }

                        if (recordingTimer) {
                            clearInterval(recordingTimer);
                            recordingTimer = null;
                        }

                        isRecording = false;
                        const icon = recordBtn.querySelector(
                            '.practice-sentence__btn-icon'
                        );
                        const text = recordBtn.querySelector(
                            '.practice-sentence__btn-text'
                        );
                        const recording = recordBtn.querySelector(
                            '.practice-sentence__btn-recording'
                        );

                        if (icon) icon.style.display = 'inline-block';
                        if (text) text.style.display = 'inline';
                        if (recording) {
                            recording.style.display = 'none';
                            const timeSpan = recording.querySelector('span');
                            if (timeSpan) timeSpan.textContent = 'Dừng thu';
                        }
                        recordBtn.classList.remove(
                            'practice-sentence__btn--recording'
                        );
                    }
                });
            }

            if (previewAudio && previewPlayBtn) {
                previewPlayBtn.addEventListener('click', function () {
                    if (previewAudio.paused) {
                        previewAudio.play();
                        previewPlayBtn.querySelector('i').classList.remove('fa-play');
                        previewPlayBtn.querySelector('i').classList.add('fa-pause');
                    } else {
                        previewAudio.pause();
                        previewPlayBtn.querySelector('i').classList.remove('fa-pause');
                        previewPlayBtn.querySelector('i').classList.add('fa-play');
                    }
                });

                previewAudio.addEventListener('loadedmetadata', function () {
                    if (previewProgress && previewAudio.duration) {
                        previewProgress.max = previewAudio.duration;
                    }
                });

                previewAudio.addEventListener('timeupdate', function () {
                    if (
                        !previewAudio.src ||
                        !previewAudio.duration ||
                        isNaN(previewAudio.duration)
                    ) {
                        if (previewTimeEl) {
                            previewTimeEl.textContent = '0:00 / 0:00';
                        }
                        if (previewProgress && !previewProgress.isSeeking) {
                            previewProgress.value = 0;
                        }
                        return;
                    }

                    if (previewTimeEl) {
                        const current = Math.floor(previewAudio.currentTime);
                        const duration = Math.floor(previewAudio.duration || 0);
                        previewTimeEl.textContent = `${formatTime(
                            current
                        )} / ${formatTime(duration)}`;
                    }
                    if (
                        previewProgress &&
                        previewAudio.duration &&
                        !previewProgress.isSeeking
                    ) {
                        previewProgress.value = previewAudio.currentTime;
                    }
                });

                previewAudio.addEventListener('ended', function () {
                    previewPlayBtn.querySelector('i').classList.remove('fa-pause');
                    previewPlayBtn.querySelector('i').classList.add('fa-play');
                    previewAudio.currentTime = 0;
                    if (previewProgress) {
                        previewProgress.value = 0;
                    }
                });
            }

            if (previewProgress && previewAudio) {
                previewProgress.isSeeking = false;

                previewProgress.addEventListener('mousedown', function () {
                    this.isSeeking = true;
                });

                previewProgress.addEventListener('mouseup', function () {
                    this.isSeeking = false;
                    if (previewAudio.duration) {
                        previewAudio.currentTime = parseFloat(this.value);
                    }
                });

                previewProgress.addEventListener('input', function () {
                    if (this.isSeeking && previewAudio.duration) {
                        previewAudio.currentTime = parseFloat(this.value);
                    }
                });
            }

            if (previewVolumeBtn && previewVolumeControl) {
                previewVolumeBtn.addEventListener('click', function (e) {
                    e.stopPropagation();
                    const isVisible = previewVolumeControl.style.display === 'flex';
                    previewVolumeControl.style.display = isVisible ? 'none' : 'flex';
                });

                document.addEventListener('click', function (e) {
                    if (previewVolumeControl && previewVolumeBtn) {
                        if (
                            !previewVolumeControl.contains(e.target) &&
                            !previewVolumeBtn.contains(e.target)
                        ) {
                            previewVolumeControl.style.display = 'none';
                        }
                    }
                });
            }

            if (previewVolumeSlider && previewAudio) {
                previewVolumeSlider.addEventListener('input', function () {
                    previewAudio.volume = this.value / 100;
                    const icon = previewVolumeBtn.querySelector('i');
                    if (icon) {
                        if (this.value == 0) {
                            icon.classList.remove('fa-volume-up', 'fa-volume-down');
                            icon.classList.add('fa-volume-mute');
                        } else if (this.value < 50) {
                            icon.classList.remove('fa-volume-up', 'fa-volume-mute');
                            icon.classList.add('fa-volume-down');
                        } else {
                            icon.classList.remove('fa-volume-down', 'fa-volume-mute');
                            icon.classList.add('fa-volume-up');
                        }
                    }
                });
            }

            if (previewClearBtn) {
                previewClearBtn.addEventListener('click', function () {
                    clearPreviewRecording();
                });
            }

            if (submitBtn) {
                submitBtn.disabled = true;
                submitBtn.addEventListener('click', async function () {
                    if (!practiceSlug) {
                        console.warn('Không tìm thấy slug bài luyện tập');
                        return;
                    }
                    if (!recordedAudioBlob) {
                        alert('Vui lòng thu âm trước khi nộp.');
                        return;
                    }
                    const currentSentence = state.sentences[state.currentIndex];
                    if (!currentSentence || !currentSentence.enText) {
                        console.warn('Không xác định được câu hiện tại.');
                        return;
                    }

                    submitBtn.disabled = true;

                    if (aiLoadingEl) {
                        aiLoadingEl.style.display = 'flex';
                    }
                    if (feedbackSection) {
                        feedbackSection.classList.add('practice-feedback--loading');
                        const targetTop =
                            feedbackSection.getBoundingClientRect().top +
                            window.pageYOffset -
                            120;
                        window.scrollTo({
                            top: Math.max(targetTop, 0),
                            behavior: 'smooth'
                        });
                    }

                    try {
                        const endpoint = ApiBreakpoint.POST_EVALUATE_SV.replace(
                            '{slug}',
                            encodeURIComponent(practiceSlug)
                        );
                        const formData = new FormData();
                        formData.append(
                            'audio',
                            recordedAudioBlob,
                            `shadowing-${Date.now()}.webm`
                        );
                        formData.append('enSentence', currentSentence.enText);

                        const response = await fetch(endpoint, {
                            method: 'POST',
                            body: formData
                        });

                        if (!response.ok) {
                            throw new Error('Đánh giá thất bại');
                        }

                        const payload = await response.json();
                        if (!payload || !payload.evaluate) {
                            throw new Error('Dữ liệu đánh giá không hợp lệ');
                        }

                        const evaluate = payload.evaluate;

                        state.sentences = state.sentences.map((sentence, index) => {
                            if (sentence.enText !== currentSentence.enText) {
                                return sentence;
                            }
                            const baseSentence = index === state.currentIndex ? currentSentence : sentence;
                            return {
                                ...baseSentence,
                                status: evaluate.passed ? 'completed' : 'need_repair',
                                evaluate: {
                                    passed: evaluate.passed,
                                    enSentence: evaluate.enSentence || baseSentence.enText,
                                    user_transcript: evaluate.user_transcript || '',
                                    user_phonetics: evaluate.user_phonetics || '',
                                    user_suggestions: Array.isArray(evaluate.user_suggestions)
                                        ? evaluate.user_suggestions
                                        : [],
                                    general_feedback: evaluate.general_feedback || ''
                                }
                            };
                        });

                        renderAISuggestions(evaluate);
                        renderSidebar();
                        renderProgress();
                        
                        const practiceCost = parseInt(
                            submitBtn.getAttribute('cost-practice') || '0',
                            10
                        );
                        if (practiceCost > 0) {
                            animateCreditDeduct(practiceCost);
                        }

                        if (evaluate.passed) {
                            animateScoreAdd();
                        }
                    } catch (error) {
                        console.error('Không thể gửi đánh giá shadowing:', error);
                        if (typeof window.alertError === 'function') {
                            window.alertError('Không thể đánh giá câu phát âm, vui lòng thử lại.');
                        } else {
                            alert('Không thể đánh giá câu phát âm, vui lòng thử lại.');
                        }
                    } finally {
                        submitBtn.disabled = false;
                        if (aiLoadingEl) {
                            aiLoadingEl.style.display = 'none';
                        }
                        if (feedbackSection) {
                            feedbackSection.classList.remove('practice-feedback--loading');
                        }
                    }
                });
            }

            if (resetBtn) {
                resetBtn.addEventListener('click', function () {
                    if (!practiceSlug) {
                        console.warn('Không tìm thấy slug bài luyện tập');
                        return;
                    }
                    showResetModal();
                });
            }

            if (resetCancelBtn) {
                resetCancelBtn.addEventListener('click', function () {
                    hideResetModal();
                });
            }

            if (resetModalEl) {
                resetModalEl.addEventListener('click', function (event) {
                    if (event.target === resetModalEl) {
                        hideResetModal();
                    }
                });
            }

            if (resetConfirmBtn) {
                resetConfirmBtn.addEventListener('click', async function () {
                    if (!practiceSlug) {
                        hideResetModal();
                        return;
                    }

                    resetConfirmBtn.disabled = true;
                    try {
                        const endpoint = ApiBreakpoint.DELETE_SV_HISTORY.replace(
                            '{slug}',
                            encodeURIComponent(practiceSlug)
                        );
                        const response = await fetch(endpoint, {
                            method: 'DELETE'
                        });
                        if (!response.ok) {
                            throw new Error('Không thể xoá lịch sử');
                        }
                        window.location.reload();
                    } catch (error) {
                        console.error('Không thể xoá lịch sử luyện tập shadowing:', error);
                        if (typeof window.alertError === 'function') {
                            window.alertError('Không thể xoá lịch sử luyện tập, vui lòng thử lại.');
                        } else {
                            alert('Không thể xoá lịch sử luyện tập, vui lòng thử lại.');
                        }
                    } finally {
                        resetConfirmBtn.disabled = false;
                        hideResetModal();
                    }
                });
            }

            if (quitBtn) {
                quitBtn.addEventListener('click', function () {
                    window.location.href = '/speaking-shadowing';
                });
            }

            if (toggleMediaBtn && youtubeEl) {
                toggleMediaBtn.addEventListener('click', function () {
                    const wrapper = youtubeEl.closest('.sv-video__frame');
                    if (!wrapper) return;
                    const isHidden = wrapper.style.display === 'none';
                    wrapper.style.display = isHidden ? '' : 'none';
                    this.textContent = isHidden ? 'Ẩn video' : 'Hiện video';
                });
            }

            if (youtubeEl) {
                const tag = document.createElement('script');
                tag.src = 'https://www.youtube.com/iframe_api';
                document.head.appendChild(tag);

                window.onYouTubeIframeAPIReady = function () {
                    if (!youtubeEl) return;
                    youtubeState.player = new YT.Player('sv-youtube-player', {
                        events: {
                            onReady: function () {
                                youtubeState.ready = true;
                                if (autoplayState.enabled) {
                                    youtubeState.player.playVideo();
                                }
                                startVideoSync();
                            },
                            onStateChange: function (event) {
                                if (event.data === YT.PlayerState.PLAYING) {
                                    startVideoSync();
                                    updateListenVisual(true);
                                }
                                if (
                                    event.data === YT.PlayerState.PAUSED ||
                                    event.data === YT.PlayerState.ENDED
                                ) {
                                    stopVideoSync();
                                    updateListenVisual(false);
                                }
                            }
                        }
                    });
                };
            }

            renderSentence();
            renderSidebar();
            renderProgress();
        });


