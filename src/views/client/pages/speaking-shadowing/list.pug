extends ../../layouts/default.pug

block head
    link(rel="stylesheet" href="/css/common.css")
    link(rel="stylesheet" href="/css/layout.css")
    // Reuse speaking-sentence styles with small custom tweaks in the same file
    link(rel="stylesheet" href="/css/speaking-sentence.css")

block main-content
    .speaking-choose__header
        .speaking-choose__title-section
            h1.speaking-choose__title
                i.fas.fa-microphone.speaking-choose__title-icon
                |  Luyện nói Shadowing
            p.speaking-choose__subtitle Luyện nói shadowing theo video với transcript và phát âm chuẩn.

    .speaking-choose__filters
        .speaking-choose__search-section
            label.speaking-choose__filter-label(for="search-input") TÌM KIẾM
            .speaking-choose__search-input-group
                input#search-input.speaking-choose__search-input(type="text" placeholder="Tìm kiếm theo tên video...")
        .speaking-choose__filter-group
            label.speaking-choose__filter-label(for="filter-level") ★ CẤP ĐỘ
            select#filter-level.speaking-choose__filter-select
                option(value="" selected) Tất cả level
                each level in levels
                    option(value=level._id.toString()) #{level.title}
        .speaking-choose__filter-group
            label.speaking-choose__filter-label(for="filter-topic") ≡ CHỦ ĐỀ
            select#filter-topic.speaking-choose__filter-select
                option(value="" selected) Tất cả chủ đề
                each topic in topics
                    option(value=topic._id.toString()) #{topic.title}
        .speaking-choose__filter-group
            label.speaking-choose__filter-label(for="filter-status") ◆ TRẠNG THÁI
            select#filter-status.speaking-choose__filter-select
                option(value="" selected) Tất cả
                option(value="not_started") Mới
                option(value="in_progress") Đang luyện tập
                option(value="completed") Đã hoàn thành
        .speaking-choose__filter-group.speaking-choose__filter-group--actions
            label.speaking-choose__filter-label.speaking-choose__filter-label--hidden Clear
            button#clear-filters-btn.btn.btn-primary.speaking-choose__clear-filters-btn(type="button")
                i.fas.fa-times
                |  Xóa bộ lọc

    .speaking-choose__content
        .row.g-3.speaking-choose__cards#sv-cards-container
            .col-12
                p.text-center.mb-0 Đang tải danh sách video shadowing...
        .speaking-choose__pagination
            .speaking-choose__pagination-info#sv-pagination-info
                | Hiển thị 0 - 0 của 0 video
            .speaking-choose__pagination-controls
                button#sv-prev-page.speaking-choose__pagination-btn(type="button" disabled)
                    i.fas.fa-chevron-left
                button#sv-current-page.speaking-choose__pagination-btn.speaking-choose__pagination-btn--active(type="button" disabled) 1
                button#sv-next-page.speaking-choose__pagination-btn(type="button" disabled)
                    i.fas.fa-chevron-right

block scripts
    script(type="module").
        import { ApiBreakpoint } from '/js/api_breakpoint.js'

        const cardsContainer = document.getElementById('sv-cards-container')
        const searchInput = document.getElementById('search-input')
        const filterLevel = document.getElementById('filter-level')
        const filterTopic = document.getElementById('filter-topic')
        const filterStatus = document.getElementById('filter-status')
        const clearFiltersBtn = document.getElementById('clear-filters-btn')
        const paginationInfo = document.getElementById('sv-pagination-info')
        const prevPageBtn = document.getElementById('sv-prev-page')
        const nextPageBtn = document.getElementById('sv-next-page')
        const currentPageBtn = document.getElementById('sv-current-page')

        const state = {
            page: 1,
            limit: 8,
            search: '',
            level: '',
            topic: '',
            status: ''
        }

        function escapeHTML(text = '') {
            return text
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#39;')
        }

        function mapStatusToBadge(status) {
            if (!status) return { label: 'Mới', key: 'new' }
            if (status === 'completed') return { label: 'Đã hoàn thành', key: 'completed' }
            if (status === 'in_progress') return { label: 'Đang luyện tập', key: 'in-progress' }
            return { label: 'Mới', key: 'new' }
        }

        function buildQuery() {
            const params = new URLSearchParams()
            params.set('page', state.page.toString())
            params.set('limit', state.limit.toString())

            if (state.search) params.set('search', state.search)
            if (state.level) params.set('level', state.level)
            if (state.topic) params.set('topic', state.topic)
            if (state.status) params.set('status', state.status)

            return params.toString()
        }

        function renderCards(items = []) {
            if (!cardsContainer) return

            if (!items.length) {
                cardsContainer.innerHTML = `
                    <div class="col-12">
                        <p class="text-center text-muted mb-0">Không tìm thấy video shadowing phù hợp.</p>
                    </div>
                `
                return
            }

            cardsContainer.innerHTML = items
                .map((item) => {
                    const title = escapeHTML(item.title || '')
                    const topicTitle = item.topic?.title
                        ? escapeHTML(item.topic.title)
                        : 'Chủ đề chung'
                    const topicIcon = item.topic?.fa_class_icon
                        ? item.topic.fa_class_icon
                        : 'far fa-folder-open'
                    const levelTitle = item.level?.title
                        ? escapeHTML(item.level.title)
                        : 'Mọi cấp độ'
                    const levelIcon = item.level?.fa_class_icon
                        ? item.level.fa_class_icon
                        : 'far fa-graduation-cap'
                    const slug = item.slug || ''
                    const thumbnailUrl = item.thumbnailUrl || ''
                    const status = mapStatusToBadge(item.history?.content?.status)
                    const sentenceCount = Array.isArray(item.transcript)
                        ? item.transcript.length
                        : 0

                    const thumb = thumbnailUrl
                        ? `<div class="sv-card__thumb-wrapper">
                               <img class="sv-card__thumb" src="${escapeHTML(thumbnailUrl)}" alt="${title}">
                           </div>`
                        : ''

                    return `
                        <div class="col-12 col-md-6 col-lg-4">
                            <div class="speaking-card sv-card">
                                ${thumb}
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <h5 class="speaking-card__title m-0" title="${title}">${title}</h5>
                                    <span class="speaking-card__badge" data-status="${status.key}">${status.label}</span>
                                </div>
                                <div class="d-flex flex-wrap gap-3 align-items-center speaking-card__meta">
                                    <span><i class="${topicIcon} me-1"></i>${topicTitle}</span>
                                    <span><i class="${levelIcon} me-1"></i>${levelTitle}</span>
                                    <span class="ms-auto speaking-card__attempt">
                                        <i class="far fa-list-alt me-1"></i>${sentenceCount} câu
                                    </span>
                                </div>
                                <div class="text-end mt-2">
                                    <a href="/speaking-shadowing/practice/${slug}" class="btn btn-primary speaking-card__btn">
                                        Bắt đầu luyện tập
                                    </a>
                                </div>
                            </div>
                        </div>
                    `
                })
                .join('')
        }

        function renderPagination(pagination) {
            if (!paginationInfo || !prevPageBtn || !nextPageBtn || !currentPageBtn) return

            const { page, limit, total, totalPages, hasNextPage, hasPrevPage } = pagination
            const start = total === 0 ? 0 : (page - 1) * limit + 1
            const end = Math.min(page * limit, total)

            paginationInfo.textContent = `Hiển thị ${start} - ${end} của ${total} video`

            currentPageBtn.textContent = page.toString()
            prevPageBtn.disabled = !hasPrevPage
            nextPageBtn.disabled = !hasNextPage
        }

        async function fetchList() {
            if (!cardsContainer) return
            cardsContainer.innerHTML = `
                <div class="col-12">
                    <p class="text-center mb-0">Đang tải danh sách video shadowing...</p>
                </div>
            `

            try {
                const query = buildQuery()
                const url = `${ApiBreakpoint.GET_SV_LIST}?${query}`
                const res = await fetch(url)
                const data = await res.json()

                const items = Array.isArray(data.data) ? data.data : []
                renderCards(items)
                if (data.pagination) {
                    renderPagination(data.pagination)
                }
            } catch (error) {
                console.error('Error fetching SV list:', error)
                cardsContainer.innerHTML = `
                    <div class="col-12">
                        <p class="text-center text-danger mb-0">Có lỗi khi tải danh sách video shadowing.</p>
                    </div>
                `
            }
        }

        // Event handlers
        if (searchInput) {
            let searchTimeout = null
            searchInput.addEventListener('input', function () {
                const value = this.value.trim()
                state.search = value
                state.page = 1

                if (searchTimeout) clearTimeout(searchTimeout)
                searchTimeout = setTimeout(fetchList, 400)
            })
        }

        if (filterLevel) {
            filterLevel.addEventListener('change', function () {
                state.level = this.value || ''
                state.page = 1
                fetchList()
            })
        }

        if (filterTopic) {
            filterTopic.addEventListener('change', function () {
                state.topic = this.value || ''
                state.page = 1
                fetchList()
            })
        }

        if (filterStatus) {
            filterStatus.addEventListener('change', function () {
                state.status = this.value || ''
                state.page = 1
                fetchList()
            })
        }

        if (clearFiltersBtn) {
            clearFiltersBtn.addEventListener('click', function () {
                state.page = 1
                state.search = ''
                state.level = ''
                state.topic = ''
                state.status = ''

                if (searchInput) searchInput.value = ''
                if (filterLevel) filterLevel.value = ''
                if (filterTopic) filterTopic.value = ''
                if (filterStatus) filterStatus.value = ''

                fetchList()
            })
        }

        if (prevPageBtn) {
            prevPageBtn.addEventListener('click', function () {
                if (state.page > 1) {
                    state.page -= 1
                    fetchList()
                }
            })
        }

        if (nextPageBtn) {
            nextPageBtn.addEventListener('click', function () {
                state.page += 1
                fetchList()
            })
        }

        // Initial load
        fetchList()

