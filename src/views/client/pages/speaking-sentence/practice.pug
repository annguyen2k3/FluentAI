block head
    link(rel="stylesheet" href="/css/common.css")
    link(rel="stylesheet" href="/css/layout.css")
    link(rel="stylesheet" href="/css/speaking-sentence.css")

block main-content
    - const totalSentences = ss && Array.isArray(ss.list) ? ss.list.length : 0
    - const firstSentence = totalSentences ? ss.list[0] : null
    - const progressPercentage = totalSentences ? Math.round((1 / totalSentences) * 100) : 0

    .practice-header.mb-1
        h1.flex-fill.mb-0.fs-3.fw-bold #{(ss && ss.title) || 'Luyện nói câu'}
        .practice-header__info
            .practice-header__credits
                i.fas.fa-coins.practice-header__icon
                span 71 xu
            .practice-header__divider
            .practice-header__points
                i.fas.fa-star.practice-header__icon
                span 80 điểm
            .practice-header__divider
            .practice-header__progress
                span
                    | Hoàn thành: 
                    span#progress-completed 1
                    | /
                    span#progress-total #{totalSentences || 10}
                    | câu

    .practice-title-section.mb-4
        .practice-progress
            .practice-progress__bar
                .practice-progress__fill#progress-fill(style='width: ' + progressPercentage + '%')

    .row
        .col-lg-8
            .practice-content
                .practice-sentence
                    h2#practice-sentence-text.practice-sentence__text Đang tải câu luyện tập...
                    p#practice-sentence-phonetic.practice-sentence__phonetic
                    p#practice-sentence-translation.practice-sentence__translation

                    .practice-sentence__actions
                        audio#practice-audio-sample(style="display: none;")
                        button#practice-listen-btn.practice-sentence__btn.practice-sentence__btn--listen(type="button")
                            i.fas.fa-volume-up.practice-sentence__btn-icon
                            span.practice-sentence__btn-text Nghe mẫu
                            .practice-sentence__btn-playing(style="display: none;")
                                .practice-sentence__btn-playing-dot
                                span Dừng phát
                        button#practice-record-btn.practice-sentence__btn.practice-sentence__btn--record(type="button")
                            i.fas.fa-microphone.practice-sentence__btn-icon
                            span.practice-sentence__btn-text Thu âm
                            .practice-sentence__btn-recording(style="display: none;")
                                .practice-sentence__btn-recording-dot
                                span Dừng thu
                        button.practice-sentence__btn.practice-sentence__btn--submit(type="button")
                            i.fas.fa-paper-plane
                            |  Nộp
                            span.practice-sentence__attempt
                                | 1 
                                i.fa-brands.fa-bitcoin(style="color: #ffd43b")

                    .practice-sentence__preview-audio.mb-3
                        audio#practice-preview-audio(style="display: none;")
                        .practice-recording__container
                            .practice-recording__player
                                button#practice-preview-play.practice-recording__play-btn(type="button")
                                    i.fas.fa-play
                                .practice-recording__time#practice-preview-time 0:00 / 0:00
                                input#practice-preview-progress.practice-recording__progress(type="range" min="0" max="100" value="0" step="0.1")
                                button#practice-preview-volume-btn.practice-recording__volume-btn(type="button")
                                    i.fas.fa-volume-up
                                .practice-recording__volume-control(style="display: none;")
                                    input#practice-preview-volume.practice-recording__volume-slider(type="range" min="0" max="100" value="75")

                    .practice-sentence__navigation
                        button#practice-prev.practice-sentence__nav-btn.practice-sentence__nav-btn--prev(type="button")
                            i.fas.fa-arrow-left
                            |  Câu trước
                        button#practice-next.practice-sentence__nav-btn.practice-sentence__nav-btn--next(type="button")
                            | Câu tiếp theo 
                            i.fas.fa-arrow-right

                .practice-feedback
                    h3.practice-feedback__title
                        i.fa-solid.fa-robot.p-2(style="color: #2107e9;")
                        |  Đánh giá từ AI
                    .practice-recording
                        h4.practice-feedback__subtitle Your Recording And Transcript:
                        .practice-recording__container
                            .practice-recording__player
                                button.practice-recording__play-btn(type="button")
                                    i.fas.fa-play
                                .practice-recording__time 0:00 / 0:02
                                .practice-recording__volume-control
                                    input.practice-recording__volume-slider(type="range" min="0" max="100" value="30")
                                    i.fas.fa-volume-up.practice-recording__volume
                                i.fas.fa-ellipsis-v.practice-recording__menu
