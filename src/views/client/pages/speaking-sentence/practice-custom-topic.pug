extends ../../layouts/default.pug
include ../../mixins/loading.pug

block head
    link(rel="stylesheet" href="/css/common.css")
    link(rel="stylesheet" href="/css/layout.css")
    link(rel="stylesheet" href="/css/speaking-sentence.css")

block main-content
    .practice-header.mb-1
        h1.flex-fill.mb-0.fs-3.fw-bold#practice-title Luyện nói câu - Chủ đề tùy chỉnh
        .practice-header__info
            .practice-header__credits
                i.fas.fa-coins.practice-header__icon
                span 0 xu
            .practice-header__divider
            .practice-header__points
                i.fas.fa-star.practice-header__icon
                span 0 điểm
            .practice-header__divider
            .practice-header__progress
                span
                    | Hoàn thành: 
                    span#progress-completed 0
                    | /
                    span#progress-total 0
                    | câu

    .practice-title-section.mb-4
        .practice-progress
            .practice-progress__bar
                .practice-progress__fill#progress-fill(style='width: 0%')

    .row
        .col-lg-8
            .practice-content
                .practice-sentence
                    h2#practice-sentence-text.practice-sentence__text Đang tải câu luyện tập...
                    p#practice-sentence-phonetic.practice-sentence__phonetic
                    p#practice-sentence-translation.practice-sentence__translation

                    .practice-sentence__actions
                        audio#practice-audio-sample(style="display: none;")
                        button#practice-listen-btn.practice-sentence__btn.practice-sentence__btn--listen(type="button")
                            i.fas.fa-volume-up.practice-sentence__btn-icon
                            span.practice-sentence__btn-text Nghe mẫu
                            .practice-sentence__btn-playing(style="display: none;")
                                .practice-sentence__btn-playing-dot
                                span Dừng phát
                        button#practice-record-btn.practice-sentence__btn.practice-sentence__btn--record(type="button")
                            i.fas.fa-microphone.practice-sentence__btn-icon
                            span.practice-sentence__btn-text Thu âm
                            .practice-sentence__btn-recording(style="display: none;")
                                .practice-sentence__btn-recording-dot
                                span Dừng thu
                        button#practice-submit-btn.practice-sentence__btn.practice-sentence__btn--submit(type="button")
                            i.fas.fa-paper-plane
                            |  Nộp
                            span.practice-sentence__attempt
                                | 1 
                                i.fa-brands.fa-bitcoin(style="color: #ffd43b")

                    .practice-sentence__preview-audio.mb-3
                        audio#practice-preview-audio(style="display: none;")
                        .practice-recording__container
                            .practice-recording__player
                                button#practice-preview-play.practice-recording__play-btn(type="button")
                                    i.fas.fa-play
                                .practice-recording__time#practice-preview-time 0:00 / 0:00
                                input#practice-preview-progress.practice-recording__progress(type="range" min="0" max="100" value="0" step="0.1")
                                button#practice-preview-volume-btn.practice-recording__volume-btn(type="button")
                                    i.fas.fa-volume-up
                                .practice-recording__volume-control(style="display: none;")
                                    input#practice-preview-volume.practice-recording__volume-slider(type="range" min="0" max="100" value="75")
                        button#practice-preview-clear.practice-recording__clear-btn(type="button")
                            i.fas.fa-times

                    .practice-sentence__navigation
                        button#practice-prev.practice-sentence__nav-btn.practice-sentence__nav-btn--prev(type="button")
                            i.fas.fa-arrow-left
                            |  Câu trước
                        button#practice-next.practice-sentence__nav-btn.practice-sentence__nav-btn--next(type="button")
                            | Câu tiếp theo 
                            i.fas.fa-arrow-right

                .practice-feedback#feedback-section
                    h3.practice-feedback__title
                        i.fa-solid.fa-robot.p-2(style="color: #2107e9;")
                        |  Đánh giá từ AI
                    #ai-loading.practice-feedback__loading
                        +loadingIndicator('AI đang đánh giá phần luyện nói của bạn...')
                    .practice-feedback__result.practice-feedback__result--hidden#ai-result-badge
                        i#ai-result-icon.fw-bold
                        span#ai-result-text.fw-semibold
                    p#ai-intro.practice-feedback__intro.fw-semibold.text-dark
                        | Nộp bài <span class="letter-highlight">Phát âm của bạn </span>để nhận phản hồi từ <span class="letter-highlight">AI</span>. Hệ thống sẽ xem xét bản dịch của bạn và chỉ ra những điểm mạnh cũng như những lĩnh vực cần cải thiện.
                    .practice-recording.bg-white.border.rounded-3.p-3.mt-2(style="display: none;")
                        h4.practice-feedback__subtitle.text-primary.fw-semibold Your Transcript and Phonetics:
                        .practice-recording__container.practice-recording__container--text-only.mt-2
                            .practice-recording__transcript-box
                                p#ai-transcript.practice-recording__transcript
                            .practice-recording__phonetic-box
                                p#ai-phonetic.practice-recording__phonetic
                    .practice-feedback__suggestions#ai-suggestion-section(style="display: none;")
                        h4.practice-feedback__subtitle.mt-3 Suggestion:
                        .practice-feedback__suggestions-list#ai-suggestions
                    .practice-feedback__comment(style="display: none;")
                        h4.practice-feedback__comment-title Nhận xét:
                        p#ai-general-feedback

        .col-lg-4
            .practice-sidebar#sentence-sidebar
                .practice-sidebar__header
                    h3.practice-sidebar__title Danh sách câu
                    button.practice-sidebar__toggle#sidebar-toggle(type="button")
                        i.fas.fa-chevron-down
                .practice-sidebar__content
                    .practice-sidebar__list#practice-sidebar-list
                        p.mb-0 Chưa có dữ liệu câu luyện tập
                .practice-sidebar__actions
                    button#practice-quit-btn.practice-sidebar__action-btn.practice-sidebar__action-btn--quit(type="button")
                        i.fas.fa-sign-out-alt
                        |  Thoát
                    button.practice-sidebar__action-btn.practice-sidebar__action-btn--reset(type="button" id="practice-reset-btn")
                        i.fas.fa-redo-alt
                        |  Luyện tập lại từ đầu

    .practice-finish-modal#practice-finish-modal
        .practice-finish-modal__dialog
            button.practice-finish-modal__close.btn-close(type="button" aria-label="Đóng" id="practice-finish-close")
            .practice-finish-modal__icon
                i.fas.fa-trophy
            h3.practice-finish-modal__title Chúc mừng bạn đã hoàn thành bài luyện tập!
            p.practice-finish-modal__subtitle Kĩ năng của bạn đã tiến bộ hơn 1 chút rồi đấy. Tiếp tục cố gắng và phát huy nhé.
            .practice-finish-modal__actions
                button#practice-finish-stay.btn.btn-outline-secondary(type="button") Ở lại
                button#practice-finish-next.btn.btn-primary(type="button") Chọn bài học tiếp theo

    .practice-reset-modal#practice-reset-modal
        .practice-reset-modal__dialog
            h4.practice-reset-modal__title Xác nhận xoá lịch sử luyện tập?
            p.practice-reset-modal__subtitle Xác nhận xoá lịch sử luyện tập của danh sách này và luyện tập lại từ đầu.
            .practice-reset-modal__actions
                button#practice-reset-cancel.btn.btn-outline-secondary(type="button") Hủy
                button#practice-reset-confirm.btn.btn-danger(type="button") Đồng ý

block scripts
    script(type="module").
        import { ApiBreakpoint } from '/js/api_breakpoint.js'

        document.addEventListener('DOMContentLoaded', function () {
            const SESSION_STORAGE_KEY = 'preview-ss-data';
            const HISTORY_STORAGE_KEY = 'preview-ss-history';

            const sidebar = document.getElementById('sentence-sidebar');
            const toggleBtn = document.getElementById('sidebar-toggle');
            const sidebarListEl = document.getElementById('practice-sidebar-list');
            const practiceTextEl = document.getElementById('practice-sentence-text');
            const practicePhoneticEl = document.getElementById('practice-sentence-phonetic');
            const practiceTranslationEl = document.getElementById('practice-sentence-translation');
            const practiceAudioSampleEl = document.getElementById('practice-audio-sample');
            const practiceTimeEl = document.getElementById('practice-preview-time');
            const listenBtn = document.getElementById('practice-listen-btn');
            const submitBtn = document.getElementById('practice-submit-btn');
            const aiIntroEl = document.getElementById('ai-intro');
            const aiTranscriptEl = document.getElementById('ai-transcript');
            const aiPhoneticEl = document.getElementById('ai-phonetic');
            const aiSuggestionsEl = document.getElementById('ai-suggestions');
            const aiGeneralFeedbackEl = document.getElementById('ai-general-feedback');
            const aiLoadingEl = document.getElementById('ai-loading');
            const aiResultBadge = document.getElementById('ai-result-badge');
            const aiResultIcon = document.getElementById('ai-result-icon');
            const aiResultText = document.getElementById('ai-result-text');
            const aiRecordingSection = document.querySelector('.practice-recording');
            const aiSuggestionsSection = document.getElementById('ai-suggestion-section');
            const aiCommentSection = document.querySelector('.practice-feedback__comment');
            const feedbackSection = document.getElementById('feedback-section');
            const progressCompletedEl = document.getElementById('progress-completed');
            const progressTotalEl = document.getElementById('progress-total');
            const progressFillEl = document.getElementById('progress-fill');
            const prevBtn = document.getElementById('practice-prev');
            const nextBtn = document.getElementById('practice-next');
            const quitBtn = document.getElementById('practice-quit-btn');
            const completionModalEl = document.getElementById('practice-finish-modal');
            const completionCloseBtn = document.getElementById('practice-finish-close');
            const completionStayBtn = document.getElementById('practice-finish-stay');
            const completionNextBtn = document.getElementById('practice-finish-next');
            const resetBtn = document.getElementById('practice-reset-btn');
            const resetModalEl = document.getElementById('practice-reset-modal');
            const resetCancelBtn = document.getElementById('practice-reset-cancel');
            const resetConfirmBtn = document.getElementById('practice-reset-confirm');
            const practiceTitleEl = document.getElementById('practice-title');

            let dataSS = null;
            let dataHisSS = [];

            const loadDataFromSession = () => {
                try {
                    const rawSS = sessionStorage.getItem(SESSION_STORAGE_KEY);
                    if (!rawSS) {
                        console.warn('Không tìm thấy dữ liệu trong sessionStorage');
                        if (practiceTextEl) {
                            practiceTextEl.textContent = 'Không tìm thấy dữ liệu luyện tập. Vui lòng quay lại trang chọn bài.';
                        }
                        return false;
                    }

                    dataSS = JSON.parse(rawSS);
                    
                    const rawHisSS = sessionStorage.getItem(HISTORY_STORAGE_KEY);
                    if (rawHisSS) {
                        try {
                            const parsed = JSON.parse(rawHisSS);
                            dataHisSS = Array.isArray(parsed) ? parsed : [];
                        } catch (error) {
                            console.warn('Lỗi khi đọc lịch sử từ sessionStorage:', error);
                            dataHisSS = [];
                        }
                    }

                    if (practiceTitleEl && dataSS.title) {
                        practiceTitleEl.textContent = dataSS.title || 'Luyện nói câu - Chủ đề tùy chỉnh';
                    }

                    return true;
                } catch (error) {
                    console.error('Lỗi khi đọc dữ liệu từ sessionStorage:', error);
                    if (practiceTextEl) {
                        practiceTextEl.textContent = 'Lỗi khi tải dữ liệu. Vui lòng thử lại.';
                    }
                    return false;
                }
            };

            const saveHistoryToSession = () => {
                try {
                    const historyJson = JSON.stringify(dataHisSS);
                    sessionStorage.setItem(HISTORY_STORAGE_KEY, historyJson);
                    console.log('Đã lưu lịch sử vào sessionStorage:', dataHisSS);
                    console.log('Key:', HISTORY_STORAGE_KEY);
                } catch (error) {
                    console.error('Lỗi khi lưu lịch sử vào sessionStorage:', error);
                }
            };

            if (!loadDataFromSession()) {
                if (quitBtn) {
                    quitBtn.addEventListener('click', function () {
                        window.location.href = '/speaking-sentence';
                    });
                }
                return;
            }

            if (dataSS && Array.isArray(dataSS.list)) {
                const historySentences = Array.isArray(dataHisSS) ? dataHisSS : [];
                let countCompleted = 0;

                dataSS.list = dataSS.list.map((sentence) => {
                    const matchedHistory = historySentences.find((hisSentence) => hisSentence.enSentence === sentence.enSentence);

                    if (!matchedHistory) {
                        return { ...sentence, status: 'not_started' };
                    }

                    if (matchedHistory.passed) {
                        countCompleted += 1;
                    }

                    return {
                        ...sentence,
                        status: matchedHistory.passed ? 'completed' : 'need_repair',
                        evaluate: {
                            passed: matchedHistory.passed,
                            enSentence: matchedHistory.enSentence,
                            user_transcript: matchedHistory.user_transcript,
                            user_phonetics: matchedHistory.user_phonetics,
                            user_suggestions: matchedHistory.user_suggestions || [],
                            general_feedback: matchedHistory.general_feedback || ''
                        }
                    };
                });

                if (progressCompletedEl) progressCompletedEl.textContent = countCompleted;
                if (progressTotalEl) progressTotalEl.textContent = dataSS.list.length;
                if (progressFillEl) progressFillEl.style.width = `${(countCompleted / dataSS.list.length) * 100}%`;
            }

            const state = {
                sentences: Array.isArray(dataSS?.list) ? dataSS.list : [],
                currentIndex: 0
            };
            const completionState = {
                wasFullyCompleted:
                    Array.isArray(state.sentences) &&
                    state.sentences.length > 0 &&
                    state.sentences.every((sentence) => sentence.status === 'completed')
            };

            const audioCache = new Map();
            const wordAudioCache = new Map();
            let audioRequestId = 0;
            const bodyScrollState = {
                locked: false,
                overflow: '',
                paddingRight: ''
            };

            const statusConfig = {
                not_started: { label: 'Chưa luyện tập' },
                completed: { label: 'Hoàn thành', itemClass: 'practice-sidebar__item--completed', statusClass: 'practice-sidebar__item-status--completed' },
                need_repair: { label: 'Cần chỉnh sửa', itemClass: 'practice-sidebar__item--error', statusClass: 'practice-sidebar__item-status--error' },
                in_progress: { label: 'Đang luyện tập', statusClass: 'practice-sidebar__item-status--in-progress' }
            };

            const getSentenceKey = (sentence) => {
                if (!sentence) return '';
                return sentence._id || sentence.enSentence || '';
            };

            const setListenBtnLoading = (isLoading) => {
                if (!listenBtn) return;
                listenBtn.disabled = isLoading;
            };

            const setPracticeAudioSource = (src) => {
                if (!practiceAudioSampleEl || !src) return;
                practiceAudioSampleEl.src = src;
                practiceAudioSampleEl.load();
                practiceAudioSampleEl.addEventListener('loadedmetadata', function() {
                    if (practiceTimeEl) {
                        const duration = Math.floor(practiceAudioSampleEl.duration);
                        practiceTimeEl.textContent = `0:00 / ${formatTime(duration)}`;
                    }
                }, { once: true });
            };

            const requestPracticeAudio = async (text) => {
                if (!text) return null;
                try {
                    const response = await fetch(ApiBreakpoint.POST_PRACTICE_SS_AUDIO, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({ text })
                    });

                    if (!response.ok) {
                        throw new Error('Failed to generate audio');
                    }

                    const payload = await response.json();
                    if (payload?.audio) {
                        const mimeType = payload.contentType || 'audio/mpeg';
                        return `data:${mimeType};base64,${payload.audio}`;
                    }
                    return null;
                } catch (error) {
                    console.error('Không tạo được audio:', error);
                    if (typeof window.alertError === 'function') {
                        window.alertError('Không tạo được audio mẫu, vui lòng thử lại.');
                    }
                    return null;
                }
            };

            const ensureSentenceAudio = async (sentence) => {
                if (!practiceAudioSampleEl || !sentence) return;

                if (sentence.audioUrl) {
                    setPracticeAudioSource(sentence.audioUrl);
                    return;
                }

                const audioKey = getSentenceKey(sentence);
                if (audioKey && audioCache.has(audioKey)) {
                    setPracticeAudioSource(audioCache.get(audioKey));
                    return;
                }

                const text = sentence.enSentence || '';
                if (!text.trim()) return;

                const currentRequestId = ++audioRequestId;
                setListenBtnLoading(true);
                try {
                    const generatedAudio = await requestPracticeAudio(text.trim());
                    if (!generatedAudio) return;

                    if (audioKey) {
                        audioCache.set(audioKey, generatedAudio);
                    }

                    if (audioRequestId !== currentRequestId) return;
                    if (state.sentences[state.currentIndex] !== sentence) return;

                    setPracticeAudioSource(generatedAudio);
                } finally {
                    setListenBtnLoading(false);
                }
            };

            let wordAudioElement = null;
            const playWordAudio = async (word) => {
                if (!word || !word.trim()) return;

                const normalizedWord = word.trim().toLowerCase();
                
                if (!wordAudioElement) {
                    wordAudioElement = document.createElement('audio');
                    wordAudioElement.style.display = 'none';
                    document.body.appendChild(wordAudioElement);
                }

                if (wordAudioCache.has(normalizedWord)) {
                    wordAudioElement.src = wordAudioCache.get(normalizedWord);
                    wordAudioElement.play().catch(error => {
                        console.error('Không thể phát audio:', error);
                    });
                    return;
                }

                try {
                    const generatedAudio = await requestPracticeAudio(normalizedWord);
                    if (!generatedAudio) {
                        if (typeof window.alertError === 'function') {
                            window.alertError('Không tạo được audio cho từ này.');
                        }
                        return;
                    }

                    wordAudioCache.set(normalizedWord, generatedAudio);
                    wordAudioElement.src = generatedAudio;
                    wordAudioElement.play().catch(error => {
                        console.error('Không thể phát audio:', error);
                    });
                } catch (error) {
                    console.error('Lỗi khi phát audio từ:', error);
                    if (typeof window.alertError === 'function') {
                        window.alertError('Không thể phát âm từ này.');
                    }
                }
            };

            const renderPracticeSentence = () => {
                if (!state.sentences.length) {
                    practiceTextEl.textContent = 'Chưa có câu luyện tập';
                    practicePhoneticEl.textContent = '';
                    practiceTranslationEl.textContent = 'Vui lòng quay lại sau.';
                    if (progressCompletedEl) progressCompletedEl.textContent = 0;
                    if (progressTotalEl) progressTotalEl.textContent = 0;
                    if (progressFillEl) progressFillEl.style.width = '0%';
                    if (prevBtn) prevBtn.disabled = true;
                    if (nextBtn) nextBtn.disabled = true;
                    return;
                }

                const currentSentence = state.sentences[state.currentIndex];
                practiceTextEl.textContent = currentSentence.enSentence;
                practicePhoneticEl.textContent = currentSentence.phonetics || '';
                practiceTranslationEl.textContent = currentSentence.viSentence || '';
                
                if (practiceAudioSampleEl) {
                    practiceAudioSampleEl.pause();
                    practiceAudioSampleEl.currentTime = 0;
                    practiceAudioSampleEl.removeAttribute('src');
                    practiceAudioSampleEl.load();
                    if (practiceTimeEl) {
                        practiceTimeEl.textContent = '0:00 / 0:00';
                    }
                    ensureSentenceAudio(currentSentence);
                }
                
                if (listenBtn) {
                    const icon = listenBtn.querySelector('.practice-sentence__btn-icon');
                    const text = listenBtn.querySelector('.practice-sentence__btn-text');
                    const playing = listenBtn.querySelector('.practice-sentence__btn-playing');
                    
                    if (icon) icon.style.display = 'inline-block';
                    if (text) text.style.display = 'inline';
                    if (playing) playing.style.display = 'none';
                    listenBtn.classList.remove('practice-sentence__btn--playing');
                }

                if (prevBtn) prevBtn.disabled = state.currentIndex === 0;
                if (nextBtn) nextBtn.disabled = state.currentIndex === state.sentences.length - 1;

                if (currentSentence.evaluate) {
                    renderAISuggestions(currentSentence.evaluate);
                } else {
                    resetAIFeedback();
                }
            };

            const renderSidebar = () => {
                if (!sidebarListEl) return;
                sidebarListEl.innerHTML = '';

                if (!state.sentences.length) {
                    const emptyMsg = document.createElement('p');
                    emptyMsg.className = 'mb-0';
                    emptyMsg.textContent = 'Chưa có dữ liệu câu luyện tập';
                    sidebarListEl.appendChild(emptyMsg);
                    return;
                }

                state.sentences.forEach((sentence, index) => {
                    const item = document.createElement('div');
                    item.className = 'practice-sidebar__item';

                    const isActive = index === state.currentIndex;
                    const sentenceStatus = isActive ? 'in_progress' : sentence.status || 'not_started';
                    const statusMeta = statusConfig[sentenceStatus] || statusConfig.not_started;

                    if (isActive) {
                        item.classList.add('practice-sidebar__item--active');
                    } else if (statusMeta.itemClass) {
                        item.classList.add(statusMeta.itemClass);
                    }

                    const numberEl = document.createElement('div');
                    numberEl.className = 'practice-sidebar__item-number';
                    numberEl.textContent = index + 1;

                    const contentEl = document.createElement('div');
                    contentEl.className = 'practice-sidebar__item-content';

                    const textEl = document.createElement('p');
                    textEl.className = 'practice-sidebar__item-text';
                    textEl.textContent = sentence.enSentence;

                    const statusEl = document.createElement('span');
                    statusEl.className = 'practice-sidebar__item-status';
                    if (statusMeta.statusClass) {
                        statusEl.classList.add(statusMeta.statusClass);
                    }
                    statusEl.textContent = statusMeta.label;

                    contentEl.appendChild(textEl);
                    contentEl.appendChild(statusEl);

                    item.appendChild(numberEl);
                    item.appendChild(contentEl);

                    item.addEventListener('click', function () {
                        if (state.currentIndex === index) return;
                        state.currentIndex = index;
                        clearPreviewRecording();
                        renderPracticeSentence();
                        renderSidebar();
                    });

                    sidebarListEl.appendChild(item);
                });
            };

            const updateProgress = () => {
                if (!progressCompletedEl || !progressTotalEl || !progressFillEl) return;
                const completedCount = state.sentences.filter((s) => s.status === 'completed').length;
                const total = state.sentences.length || 1;
                progressCompletedEl.textContent = completedCount;
                progressTotalEl.textContent = total;
                progressFillEl.style.width = `${(completedCount / total) * 100}%`;
            };

            const goToPrevious = () => {
                if (state.currentIndex === 0) return;
                state.currentIndex -= 1;
                clearPreviewRecording();
                renderPracticeSentence();
                renderSidebar();
            };

            const goToNext = () => {
                if (state.currentIndex >= state.sentences.length - 1) return;
                state.currentIndex += 1;
                clearPreviewRecording();
                renderPracticeSentence();
                renderSidebar();
            };

            const lockBodyScroll = () => {
                if (!document.body || bodyScrollState.locked) return;
                const scrollBarWidth = window.innerWidth - document.documentElement.clientWidth;
                bodyScrollState.locked = true;
                bodyScrollState.overflow = document.body.style.overflow || '';
                bodyScrollState.paddingRight = document.body.style.paddingRight || '';
                document.body.style.overflow = 'hidden';
                if (scrollBarWidth > 0) {
                    document.body.style.paddingRight = `${scrollBarWidth}px`;
                }
            };

            const unlockBodyScroll = () => {
                if (!document.body || !bodyScrollState.locked) return;
                document.body.style.overflow = bodyScrollState.overflow;
                document.body.style.paddingRight = bodyScrollState.paddingRight;
                bodyScrollState.locked = false;
            };

            const hideCompletionModal = () => {
                if (!completionModalEl) return;
                completionModalEl.classList.remove('practice-finish-modal--visible');
                unlockBodyScroll();
            };

            const showCompletionModal = () => {
                if (!completionModalEl) return;
                completionModalEl.classList.add('practice-finish-modal--visible');
                lockBodyScroll();
            };

            const showResetModal = () => {
                if (!resetModalEl) return;
                resetModalEl.classList.add('practice-reset-modal--visible');
                lockBodyScroll();
            };

            const hideResetModal = () => {
                if (!resetModalEl) return;
                resetModalEl.classList.remove('practice-reset-modal--visible');
                unlockBodyScroll();
            };

            const checkCompletionAfterEvaluate = () => {
                if (!state.sentences.length) return;
                const isAllCompleted = state.sentences.every((sentence) => sentence.status === 'completed');
                if (!isAllCompleted) {
                    completionState.wasFullyCompleted = false;
                    return;
                }
                if (completionState.wasFullyCompleted) {
                    return;
                }
                completionState.wasFullyCompleted = true;
                showCompletionModal();
            };

            const renderAISuggestions = (evaluate) => {
                console.log('renderAISuggestions được gọi với evaluate:', evaluate);
                
                if (!aiTranscriptEl || !aiSuggestionsEl || !aiGeneralFeedbackEl) {
                    console.warn('Thiếu các element cần thiết để render feedback');
                    return;
                }

                if (feedbackSection) {
                    feedbackSection.classList.remove('practice-feedback--loading');
                }

                if (aiIntroEl) {
                    aiIntroEl.style.display = 'none';
                }

                if (aiLoadingEl) {
                    aiLoadingEl.style.display = 'none';
                }

                if (aiRecordingSection) {
                    aiRecordingSection.style.display = '';
                }

                if (aiResultBadge && aiResultIcon && aiResultText) {
                    if (typeof evaluate?.passed === 'boolean') {
                        aiResultBadge.classList.remove('practice-feedback__result--hidden');
                        aiResultBadge.classList.remove(
                            'practice-feedback__result--success',
                            'practice-feedback__result--fail'
                        );

                        if (evaluate.passed) {
                            aiResultBadge.classList.add('practice-feedback__result--success');
                            aiResultIcon.className = 'fas fa-check-circle';
                            aiResultText.textContent = 'Tuyệt, phát âm tốt!';
                        } else {
                            aiResultBadge.classList.add('practice-feedback__result--fail');
                            aiResultIcon.className = 'fas fa-times-circle';
                            aiResultText.textContent = 'Cần cải thiện';
                        }
                    } else {
                        aiResultBadge.classList.add('practice-feedback__result--hidden');
                    }
                }

                if (aiResultBadge) {
                    aiResultBadge.classList.remove('practice-feedback__result--hidden');
                }

                aiTranscriptEl.textContent = evaluate?.user_transcript || '';

                if (aiPhoneticEl) {
                    aiPhoneticEl.textContent = evaluate?.user_phonetics || '';
                }

                aiSuggestionsEl.innerHTML = '';
                const suggestions = Array.isArray(evaluate?.user_suggestions)
                    ? evaluate.user_suggestions
                    : [];

                if (aiSuggestionsSection) {
                    aiSuggestionsSection.style.display = suggestions.length ? '' : 'none';
                }

                if (suggestions.length) {
                    suggestions.forEach((s) => {
                        const item = document.createElement('div');
                        item.className = 'practice-feedback__item';

                        const word = document.createElement('div');
                        word.className = 'practice-feedback__word';
                        const icon = document.createElement('i');
                        icon.className = 'fas fa-times practice-feedback__icon practice-feedback__icon--error';
                        const wordText = document.createElement('span');
                        wordText.className = 'practice-feedback__word-text';
                        wordText.textContent = s.word || '';
                        const speaker = document.createElement('i');
                        speaker.className = 'fas fa-volume-up practice-feedback__speaker';
                        speaker.style.cursor = 'pointer';
                        speaker.addEventListener('click', async function() {
                            const wordToPlay = s.word || '';
                            if (!wordToPlay.trim()) return;
                            
                            await playWordAudio(wordToPlay.trim());
                        });

                        word.appendChild(icon);
                        word.appendChild(wordText);
                        word.appendChild(speaker);

                        const details = document.createElement('div');
                        details.className = 'practice-feedback__details';

                        if (s.feedback_issue) {
                            const issue = document.createElement('div');
                            issue.className = 'practice-feedback__issue';
                            const warnIcon = document.createElement('i');
                            warnIcon.className = 'fas fa-exclamation-triangle practice-feedback__warning';
                            const p = document.createElement('p');
                            p.textContent = s.feedback_issue;
                            issue.appendChild(warnIcon);
                            issue.appendChild(p);
                            details.appendChild(issue);
                        }

                        if (s.feedback_tip) {
                            const tip = document.createElement('div');
                            tip.className = 'practice-feedback__tip';
                            const checkIcon = document.createElement('i');
                            checkIcon.className = 'fas fa-check practice-feedback__check';
                            const p = document.createElement('p');
                            p.textContent = s.feedback_tip;
                            tip.appendChild(checkIcon);
                            tip.appendChild(p);
                            details.appendChild(tip);
                        }

                        item.appendChild(word);
                        item.appendChild(details);
                        aiSuggestionsEl.appendChild(item);
                    });
                }

                const generalFeedback = (evaluate?.general_feedback || '').trim();
                aiGeneralFeedbackEl.textContent = generalFeedback;

                if (aiCommentSection) {
                    aiCommentSection.classList.remove(
                        'practice-feedback__comment--success',
                        'practice-feedback__comment--fail'
                    );

                    if (generalFeedback) {
                        const isPassed = evaluate?.passed !== false;
                        aiCommentSection.style.display = '';
                        aiCommentSection.classList.add(
                            isPassed
                                ? 'practice-feedback__comment--success'
                                : 'practice-feedback__comment--fail'
                        );
                    } else {
                        aiCommentSection.style.display = 'none';
                    }
                }
            };

            const resetAIFeedback = () => {
                if (feedbackSection) {
                    feedbackSection.classList.remove('practice-feedback--loading');
                }
                if (aiIntroEl) {
                    aiIntroEl.style.display = '';
                }
                if (aiLoadingEl) {
                    aiLoadingEl.style.display = 'none';
                }
                if (aiRecordingSection) {
                    aiRecordingSection.style.display = 'none';
                }
                if (aiResultBadge) {
                    aiResultBadge.classList.add('practice-feedback__result--hidden');
                }
                if (aiSuggestionsSection) {
                    aiSuggestionsSection.style.display = 'none';
                }
                if (aiCommentSection) {
                    aiCommentSection.style.display = 'none';
                }
                if (aiTranscriptEl) {
                    aiTranscriptEl.textContent = '';
                }
                if (aiPhoneticEl) {
                    aiPhoneticEl.textContent = '';
                }
                if (aiSuggestionsEl) {
                    aiSuggestionsEl.innerHTML = '';
                }
                if (aiGeneralFeedbackEl) {
                    aiGeneralFeedbackEl.textContent = '';
                }
            };

            const updateHisSSUser = (evaluate) => {
                console.log('updateHisSSUser được gọi với evaluate:', evaluate);
                console.log('state.sentences:', state.sentences);
                console.log('state.currentIndex:', state.currentIndex);
                
                if (!evaluate || !state.sentences.length) {
                    console.warn('updateHisSSUser: Thiếu evaluate hoặc sentences');
                    return;
                }
                const currentSentence = state.sentences[state.currentIndex];
                if (!currentSentence) {
                    console.warn('updateHisSSUser: Không tìm thấy currentSentence');
                    return;
                }
                
                console.log('currentSentence:', currentSentence);

                const evaluateData = {
                    passed: evaluate.passed,
                    enSentence: currentSentence.enSentence,
                    user_transcript: evaluate.user_transcript || '',
                    user_phonetics: evaluate.user_phonetics || '',
                    user_suggestions: Array.isArray(evaluate.user_suggestions)
                        ? evaluate.user_suggestions
                        : [],
                    general_feedback: evaluate.general_feedback || ''
                };

                const updatedSentence = {
                    ...currentSentence,
                    status: evaluate.passed ? 'completed' : 'need_repair',
                    evaluate: evaluateData
                };

                state.sentences[state.currentIndex] = updatedSentence;

                if (!Array.isArray(dataHisSS)) {
                    dataHisSS = [];
                }

                const existingIndex = dataHisSS.findIndex(
                    (s) => s.enSentence === currentSentence.enSentence
                );

                if (existingIndex >= 0) {
                    dataHisSS[existingIndex] = evaluateData;
                    console.log('Cập nhật lịch sử cho câu:', currentSentence.enSentence);
                } else {
                    dataHisSS.push(evaluateData);
                    console.log('Thêm mới lịch sử cho câu:', currentSentence.enSentence);
                }

                console.log('Lịch sử trước khi lưu:', dataHisSS);
                saveHistoryToSession();
                
                const savedHistory = sessionStorage.getItem(HISTORY_STORAGE_KEY);
                console.log('Lịch sử đã lưu trong sessionStorage:', savedHistory);
                
                renderSidebar();
                updateProgress();
                checkCompletionAfterEvaluate();
            };

            if (prevBtn) {
                prevBtn.addEventListener('click', goToPrevious);
            }

            if (nextBtn) {
                nextBtn.addEventListener('click', goToNext);
            }

            if (quitBtn) {
                quitBtn.addEventListener('click', function () {
                    window.location.href = '/speaking-sentence';
                });
            }

            renderPracticeSentence();
            renderSidebar();

            if (!sidebar || !toggleBtn) return;
            toggleBtn.addEventListener('click', function () {
                sidebar.classList.toggle('practice-sidebar--collapsed');
                const icon = toggleBtn.querySelector('i');
                if (!icon) return;
                if (sidebar.classList.contains('practice-sidebar--collapsed')) {
                    icon.classList.remove('fa-chevron-down');
                    icon.classList.add('fa-chevron-up');
                } else {
                    icon.classList.remove('fa-chevron-up');
                    icon.classList.add('fa-chevron-down');
                }
            });

            const recordBtn = document.getElementById('practice-record-btn');
            const previewAudio = document.getElementById('practice-preview-audio');
            const previewPlayBtn = document.getElementById('practice-preview-play');
            const previewTimeEl = document.getElementById('practice-preview-time');
            const previewProgress = document.getElementById('practice-preview-progress');
            const previewVolumeBtn = document.getElementById('practice-preview-volume-btn');
            const previewVolumeControl = document.querySelector('.practice-recording__volume-control');
            const previewVolumeSlider = document.getElementById('practice-preview-volume');
            const previewClearBtn = document.getElementById('practice-preview-clear');
            if (completionCloseBtn) {
                completionCloseBtn.addEventListener('click', hideCompletionModal);
            }
            if (completionStayBtn) {
                completionStayBtn.addEventListener('click', hideCompletionModal);
            }
            if (completionNextBtn) {
                completionNextBtn.addEventListener('click', function () {
                    window.location.href = '/speaking-sentence';
                });
            }
            if (completionModalEl) {
                completionModalEl.addEventListener('click', function (event) {
                    if (event.target === completionModalEl) {
                        hideCompletionModal();
                    }
                });
            }
            if (resetBtn) {
                resetBtn.addEventListener('click', function () {
                    showResetModal();
                });
            }
            if (resetCancelBtn) {
                resetCancelBtn.addEventListener('click', hideResetModal);
            }
            if (resetModalEl) {
                resetModalEl.addEventListener('click', function (event) {
                    if (event.target === resetModalEl) {
                        hideResetModal();
                    }
                });
            }
            if (resetConfirmBtn) {
                resetConfirmBtn.addEventListener('click', function () {
                    try {
                        sessionStorage.removeItem(HISTORY_STORAGE_KEY);
                        dataHisSS = [];
                        
                        state.sentences = state.sentences.map((sentence) => ({
                            ...sentence,
                            status: 'not_started',
                            evaluate: undefined
                        }));

                        state.currentIndex = 0;
                        renderPracticeSentence();
                        renderSidebar();
                        updateProgress();
                        hideResetModal();
                    } catch (error) {
                        console.error('Không thể xoá lịch sử luyện tập:', error);
                        if (typeof window.alertError === 'function') {
                            window.alertError('Không thể xoá lịch sử. Vui lòng thử lại.');
                        } else {
                            alert('Không thể xoá lịch sử. Vui lòng thử lại.');
                        }
                    }
                });
            }
            
            let mediaRecorder = null;
            let audioChunks = [];
            let isRecording = false;
            let recordedAudioBlob = null;
            let recordingStartTime = null;
            let recordingTimer = null;

            function clearPreviewRecording() {
                recordedAudioBlob = null;

                if (previewAudio) {
                    previewAudio.pause();
                    previewAudio.currentTime = 0;
                    previewAudio.removeAttribute('src');
                    previewAudio.load();
                }

                if (previewTimeEl) {
                    previewTimeEl.textContent = '0:00 / 0:00';
                }

                if (previewProgress) {
                    previewProgress.value = 0;
                    previewProgress.max = 100;
                }

                if (previewPlayBtn) {
                    const icon = previewPlayBtn.querySelector('i');
                    if (icon) {
                        icon.classList.remove('fa-pause');
                        icon.classList.add('fa-play');
                    }
                }

                if (submitBtn) {
                    submitBtn.disabled = true;
                }
            }

            clearPreviewRecording();

            if (submitBtn) {
                submitBtn.disabled = true;
            }

            if (recordBtn) {
                recordBtn.addEventListener('click', async function () {
                    if (!isRecording) {
                        try {
                            const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
                            mediaRecorder = new MediaRecorder(stream);
                            audioChunks = [];
                            
                            mediaRecorder.ondataavailable = function(event) {
                                if (event.data.size > 0) {
                                    audioChunks.push(event.data);
                                }
                            };
                            
                            mediaRecorder.onstop = function() {
                                recordedAudioBlob = new Blob(audioChunks, { type: 'audio/webm' });
                                const audioUrl = URL.createObjectURL(recordedAudioBlob);
                                
                                stream.getTracks().forEach(track => track.stop());
                                
                                if (previewAudio) {
                                    previewAudio.src = audioUrl;
                                    previewAudio.load();
                                    
                                    previewAudio.addEventListener('loadedmetadata', function() {
                                        if (previewTimeEl) {
                                            const duration = Math.floor(previewAudio.duration);
                                            previewTimeEl.textContent = `0:00 / ${formatTime(duration)}`;
                                        }
                                    }, { once: true });
                                }
                                if (submitBtn) {
                                    submitBtn.disabled = false;
                                }
                            };
                            
                            mediaRecorder.start();
                            isRecording = true;
                            recordingStartTime = Date.now();
                            
                            const icon = recordBtn.querySelector('.practice-sentence__btn-icon');
                            const text = recordBtn.querySelector('.practice-sentence__btn-text');
                            const recording = recordBtn.querySelector('.practice-sentence__btn-recording');
                            
                            if (icon) icon.style.display = 'none';
                            if (text) text.style.display = 'none';
                            if (recording) recording.style.display = 'flex';
                            recordBtn.classList.add('practice-sentence__btn--recording');
                            
                            if (recording) {
                                const timeSpan = recording.querySelector('span');
                                if (timeSpan) {
                                    recordingTimer = setInterval(() => {
                                        const elapsed = Math.floor((Date.now() - recordingStartTime) / 1000);
                                        timeSpan.textContent = `Dừng thu (${formatTime(elapsed)})`;
                                    }, 1000);
                                }
                            }
                        } catch (error) {
                            console.error('Lỗi khi truy cập microphone:', error);
                            alert('Không thể truy cập microphone. Vui lòng kiểm tra quyền truy cập.');
                        }
                    } else {
                        if (mediaRecorder && mediaRecorder.state !== 'inactive') {
                            mediaRecorder.stop();
                        }
                        
                        if (recordingTimer) {
                            clearInterval(recordingTimer);
                            recordingTimer = null;
                        }
                        
                        isRecording = false;
                        const icon = recordBtn.querySelector('.practice-sentence__btn-icon');
                        const text = recordBtn.querySelector('.practice-sentence__btn-text');
                        const recording = recordBtn.querySelector('.practice-sentence__btn-recording');
                        
                        if (icon) icon.style.display = 'inline-block';
                        if (text) text.style.display = 'inline';
                        if (recording) {
                            recording.style.display = 'none';
                            const timeSpan = recording.querySelector('span');
                            if (timeSpan) timeSpan.textContent = 'Dừng thu';
                        }
                        recordBtn.classList.remove('practice-sentence__btn--recording');
                    }
                });
            }

            function formatTime(seconds) {
                const mins = Math.floor(seconds / 60);
                const secs = seconds % 60;
                return `${mins}:${secs.toString().padStart(2, '0')}`;
            }

            if (previewAudio && previewPlayBtn) {
                previewPlayBtn.addEventListener('click', function() {
                    if (previewAudio.paused) {
                        previewAudio.play();
                        previewPlayBtn.querySelector('i').classList.remove('fa-play');
                        previewPlayBtn.querySelector('i').classList.add('fa-pause');
                    } else {
                        previewAudio.pause();
                        previewPlayBtn.querySelector('i').classList.remove('fa-pause');
                        previewPlayBtn.querySelector('i').classList.add('fa-play');
                    }
                });

                previewAudio.addEventListener('loadedmetadata', function() {
                    if (previewProgress && previewAudio.duration) {
                        previewProgress.max = previewAudio.duration;
                    }
                });

                previewAudio.addEventListener('timeupdate', function() {
                    if (!previewAudio.src || !previewAudio.duration || isNaN(previewAudio.duration)) {
                        if (previewTimeEl) {
                            previewTimeEl.textContent = '0:00 / 0:00';
                        }
                        if (previewProgress && !previewProgress.isSeeking) {
                            previewProgress.value = 0;
                        }
                        return;
                    }

                    if (previewTimeEl) {
                        const current = Math.floor(previewAudio.currentTime);
                        const duration = Math.floor(previewAudio.duration || 0);
                        previewTimeEl.textContent = `${formatTime(current)} / ${formatTime(duration)}`;
                    }
                    if (previewProgress && previewAudio.duration && !previewProgress.isSeeking) {
                        previewProgress.value = previewAudio.currentTime;
                    }
                });

                previewAudio.addEventListener('ended', function() {
                    previewPlayBtn.querySelector('i').classList.remove('fa-pause');
                    previewPlayBtn.querySelector('i').classList.add('fa-play');
                    previewAudio.currentTime = 0;
                    if (previewProgress) {
                        previewProgress.value = 0;
                    }
                });
            }

            if (previewProgress && previewAudio) {
                previewProgress.isSeeking = false;
                
                previewProgress.addEventListener('mousedown', function() {
                    this.isSeeking = true;
                });
                
                previewProgress.addEventListener('mouseup', function() {
                    this.isSeeking = false;
                    if (previewAudio.duration) {
                        previewAudio.currentTime = parseFloat(this.value);
                    }
                });
                
                previewProgress.addEventListener('input', function() {
                    if (this.isSeeking && previewAudio.duration) {
                        previewAudio.currentTime = parseFloat(this.value);
                    }
                });
            }

            if (previewVolumeBtn && previewVolumeControl) {
                previewVolumeBtn.addEventListener('click', function(e) {
                    e.stopPropagation();
                    const isVisible = previewVolumeControl.style.display === 'flex';
                    previewVolumeControl.style.display = isVisible ? 'none' : 'flex';
                });

                document.addEventListener('click', function(e) {
                    if (previewVolumeControl && previewVolumeBtn) {
                        if (!previewVolumeControl.contains(e.target) && !previewVolumeBtn.contains(e.target)) {
                            previewVolumeControl.style.display = 'none';
                        }
                    }
                });
            }

            if (previewVolumeSlider && previewAudio) {
                previewVolumeSlider.addEventListener('input', function() {
                    previewAudio.volume = this.value / 100;
                    const icon = previewVolumeBtn.querySelector('i');
                    if (icon) {
                        if (this.value == 0) {
                            icon.classList.remove('fa-volume-up', 'fa-volume-down');
                            icon.classList.add('fa-volume-mute');
                        } else if (this.value < 50) {
                            icon.classList.remove('fa-volume-up', 'fa-volume-mute');
                            icon.classList.add('fa-volume-down');
                        } else {
                            icon.classList.remove('fa-volume-down', 'fa-volume-mute');
                            icon.classList.add('fa-volume-up');
                        }
                    }
                });
            }

            if (previewClearBtn) {
                previewClearBtn.addEventListener('click', function () {
                    recordedAudioBlob = null;

                    if (previewAudio) {
                        previewAudio.pause();
                        previewAudio.removeAttribute('src');
                        previewAudio.load();
                    }

                    if (previewTimeEl) {
                        previewTimeEl.textContent = '0:00 / 0:00';
                    }

                    if (previewProgress) {
                        previewProgress.value = 0;
                        previewProgress.max = 100;
                    }

                    if (previewPlayBtn) {
                        const icon = previewPlayBtn.querySelector('i');
                        if (icon) {
                            icon.classList.remove('fa-pause');
                            icon.classList.add('fa-play');
                        }
                    }

                    if (submitBtn) {
                        submitBtn.disabled = true;
                    }
                });
            }

            if (listenBtn && practiceAudioSampleEl) {
                let isPlaying = false;
                const updateListenVisual = (playing) => {
                    const icon = listenBtn.querySelector('.practice-sentence__btn-icon');
                    const text = listenBtn.querySelector('.practice-sentence__btn-text');
                    const playingEl = listenBtn.querySelector('.practice-sentence__btn-playing');
                    
                    if (playing) {
                        if (icon) icon.style.display = 'none';
                        if (text) text.style.display = 'none';
                        if (playingEl) playingEl.style.display = 'flex';
                        listenBtn.classList.add('practice-sentence__btn--playing');
                    } else {
                        if (icon) icon.style.display = 'inline-block';
                        if (text) text.style.display = 'inline';
                        if (playingEl) playingEl.style.display = 'none';
                        listenBtn.classList.remove('practice-sentence__btn--playing');
                    }
                };
                
                listenBtn.addEventListener('click', async function () {
                    if (!practiceAudioSampleEl.src) {
                        const currentSentence = state.sentences[state.currentIndex];
                        await ensureSentenceAudio(currentSentence);
                        if (!practiceAudioSampleEl.src) {
                            console.warn('Không có audio để phát');
                            return;
                        }
                    }
                    
                    isPlaying = !isPlaying;
                    updateListenVisual(isPlaying);
                    
                    if (isPlaying) {
                        practiceAudioSampleEl.play();
                    } else {
                        practiceAudioSampleEl.pause();
                        practiceAudioSampleEl.currentTime = 0;
                    }
                });
                
                practiceAudioSampleEl.addEventListener('ended', function() {
                    isPlaying = false;
                    updateListenVisual(false);
                });
                
                practiceAudioSampleEl.addEventListener('pause', function() {
                    if (practiceAudioSampleEl.currentTime === 0 || practiceAudioSampleEl.ended) {
                        isPlaying = false;
                        updateListenVisual(false);
                    }
                });
            }

            if (submitBtn) {
                submitBtn.addEventListener('click', async function () {
                    if (!recordedAudioBlob) {
                        alert('Vui lòng thu âm trước khi nộp.');
                        return;
                    }
                    const currentSentence = state.sentences[state.currentIndex];
                    if (!currentSentence || !currentSentence.enSentence) {
                        console.warn('Không xác định được câu hiện tại.');
                        return;
                    }
                    submitBtn.disabled = true;
                    if (aiLoadingEl) {
                        aiLoadingEl.style.display = 'flex';
                    }
                    if (feedbackSection) {
                        feedbackSection.classList.add('practice-feedback--loading');
                    }
                    if (feedbackSection) {
                        const targetTop =
                            feedbackSection.getBoundingClientRect().top +
                            window.pageYOffset -
                            120;
                        window.scrollTo({
                            top: Math.max(targetTop, 0),
                            behavior: 'smooth'
                        });
                    }
                    try {
                        const endpoint = ApiBreakpoint.POST_EVALUATE_SS_CUSTOM_TOPIC;
                        const formData = new FormData();
                        formData.append(
                            'audio',
                            recordedAudioBlob,
                            `practice-${Date.now()}.webm`
                        );
                        formData.append('enSentence', currentSentence.enSentence);
                        const response = await fetch(endpoint, {
                            method: 'POST',
                            body: formData
                        });
                        
                        if (!response.ok) {
                            const errorData = await response.json().catch(() => ({ message: 'Lỗi không xác định' }));
                            console.error('Lỗi từ server:', errorData);
                            if (typeof window.alertError === 'function') {
                                window.alertError(errorData.message || 'Không thể đánh giá phát âm. Vui lòng thử lại.');
                            } else {
                                alert(errorData.message || 'Không thể đánh giá phát âm. Vui lòng thử lại.');
                            }
                            return;
                        }
                        
                        const payload = await response.json();
                        console.log('Kết quả đánh giá speaking:', payload);
                        
                        if (payload && payload.evaluate) {
                            console.log('Nhận được evaluate từ server:', payload.evaluate);
                            renderAISuggestions(payload.evaluate);
                            updateHisSSUser(payload.evaluate);
                        } else {
                            console.warn('Không nhận được dữ liệu đánh giá từ server. Payload:', payload);
                            if (typeof window.alertError === 'function') {
                                window.alertError('Không nhận được phản hồi đánh giá từ server.');
                            } else {
                                alert('Không nhận được phản hồi đánh giá từ server.');
                            }
                        }
                    } catch (error) {
                        console.error('Không thể gửi đánh giá speaking:', error);
                        if (typeof window.alertError === 'function') {
                            window.alertError('Lỗi khi gửi đánh giá. Vui lòng thử lại.');
                        } else {
                            alert('Lỗi khi gửi đánh giá. Vui lòng thử lại.');
                        }
                    } finally {
                        submitBtn.disabled = false;
                        if (aiLoadingEl) {
                            aiLoadingEl.style.display = 'none';
                        }
                        if (feedbackSection) {
                            feedbackSection.classList.remove('practice-feedback--loading');
                        }
                    }
                });
            }
        });

