extend ../../layouts/auth.pug

block card-body 
    div(class="text-center mb-4")
        img(src="/img/logo.jpeg" alt="FluentAI" class="login-logo mb-2 w-50")

    h1(class="text-center fw-bold mb-3" style="font-size: 1.5rem;") Quên mật khẩu
    p(class="text-center text-muted mb-4") Nhập email của bạn để nhận liên kết đặt lại mật khẩu.

    form(id="forgotForm", novalidate)
        div(class="mb-3")
            label(for="forgotEmail" class="form-label fw-semibold fs-6") Email
            input(type="email" id="forgotEmail" class="form-control form-control-lg fs-6" placeholder="Nhập email của bạn" min="3", required)
            div(class="invalid-feedback" error="email") Vui lòng nhập email hợp lệ.

        div(class="d-grid mb-2")
            button(type="submit" class="btn btn-primary btn-lg fs-6" btn-submit-email) Tiếp tục

    div(class="text-center mt-3 small")
        a(href="/users/login" class="text-decoration-none") Quay lại trang đăng nhập