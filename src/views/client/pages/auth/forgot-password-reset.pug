extend ../../layouts/auth.pug

block card-body
    div(class="text-center mb-4")
        a(href="/" class="text-decoration-none")
          img(src="/img/logo.jpeg" alt="FluentAI" class="login-logo mb-2 w-50")

    h1(class="text-center fw-bold mb-3" style="font-size: 1.5rem;") Đặt lại mật khẩu
    p(class="text-center text-muted mb-4") Nhập mật khẩu mới của bạn bên dưới.

    form(id="resetForm", novalidate)
        div(class="mb-3")
            label(for="newPassword" class="form-label fw-semibold fs-6") Mật khẩu mới
            div(class="input-group input-group-lg")
                input(type="password" id="newPassword" class="form-control fs-6" placeholder="Nhập mật khẩu mới" minlength="6" autocomplete="new-password", required)
                button(type="button" class="btn btn-outline-secondary" aria-label="Ẩn/Hiện mật khẩu" data-toggle="password-visibility" data-target="#newPassword")
                    i(class="bi bi-eye")
            div(class="invalid-feedback" error="password") Mật khẩu tối thiểu 6 ký tự.
        div(class="mb-1")
            label(for="confirmNewPassword" class="form-label fw-semibold fs-6") Nhập lại mật khẩu mới
            div(class="input-group input-group-lg")
                input(type="password" id="confirmNewPassword" class="form-control fs-6" placeholder="Nhập lại mật khẩu mới" minlength="6" autocomplete="new-password", required)
                button(type="button" class="btn btn-outline-secondary" aria-label="Ẩn/Hiện mật khẩu" data-toggle="password-visibility" data-target="#confirmNewPassword")
                    i(class="bi bi-eye")
            div(class="invalid-feedback" error="passwordConfirm") Mật khẩu nhập lại chưa khớp.

        div(class="d-grid mb-2 mt-3")
            button(type="submit" class="btn btn-primary btn-lg fs-6" btn-submit-reset-password) Xác nhận

        div(class="text-center mt-3 small")
            a(href="/users/login" class="text-decoration-none") Quay lại trang đăng nhập