extends ../../layouts/default.pug

block head
    link(rel="stylesheet" href="/css/style.css")

block main-content
    div(class="container")
        div(class="ws-setup row justify-content-center" id="ws-setup")
            div(class="col-12 col-xl-10")
                div(class="ws-setup__card card border-0 shadow-sm")
                    div(class="ws-setup__header card-body text-center")
                        h1(class="ws-setup__title mb-2") Luyện dịch câu
                        p(class="ws-setup__subtitle mb-0") Chọn mức độ và chủ đề để bắt đầu luyện tập

                    div(class="ws-setup__divider")

                    div(class="ws-setup__section card-body")
                        h5(class="ws-setup__section-title") Cấp độ của bạn
                        div(class="row g-3 g-md-4")
                            each level in levels
                                div(class="col-12 col-md-4")
                                    label(class="h-100 ws-setup__option ws-setup__option--level" level=level.slug)
                                        span(class="ws-setup__option-icon")
                                            i(class=level.fa_class_icon)
                                        div(class="ws-setup__option-content")
                                            span(class="ws-setup__option-text") #{level.title}
                                            span(class="ws-setup__option-description") #{level.description}

                    div(class="ws-setup__section card-body")
                        h5(class="ws-setup__section-title") Chủ đề
                        div(class="ws-setup__topics-container")
                            div(class="row g-3 g-md-4 pt-1")
                                div(class="col-12 col-md-6")
                                    button(class="ws-setup__topic" source-topic="system")
                                        i(class="fa-solid fa-filter ws-setup__topic-icon")
                                        span(class="ws-setup__topic-text") Chọn lọc từ hệ thống
                                div(class="col-12 col-md-6")
                                    button(class="ws-setup__topic" source-topic="custom")
                                        i(class="fa-solid fa-robot ws-setup__topic-icon")
                                        input(type="text" class="ws-setup__custom-input w-75" placeholder="Nhập chủ đề tùy chỉnh, tạo câu bằng AI")

                    div(class="ws-setup__footer card-body text-center pt-5 pb-4")
                        a(href="#" class="ws-setup__start btn btn-primary px-4 py-2")
                            | Tiếp tục 
                            i(class="fa-solid fa-arrow-right")


        //- Model preview custom topic
        div(class="modal fade" id="wsPreviewModal" tabindex="-1" aria-hidden="true")
            div(class="modal-dialog modal-lg modal-dialog-centered")
                div(class="modal-content")
                    div(class="modal-header")
                        h5(class="modal-title") Xem trước chủ đề
                        button(type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close")
                    div(class="modal-body")
                        div(class="d-flex justify-content-between align-items-center mb-2")
                            span(class="fw-semibold") Đánh giá chủ đề
                            span(id="wsPreviewStatus" class="badge")
                        p(id="wsPreviewDescription" class="mb-3")
                        div(class="d-flex justify-content-between align-items-center mb-2")
                            span(class="fw-semibold") Số lượng câu tạo
                            span(id="wsPreviewCount")
                        ul(id="wsPreviewList" class="list-group")
                    div(class="modal-footer")
                        button(type="button" id="wsPreviewRegenerate" class="btn btn-outline-secondary") Tạo lại
                        button(type="button" id="wsPreviewStart" class="btn btn-primary") Bắt đầu luyện tập

    script(src="/js/writing-sentence.js" type="module")