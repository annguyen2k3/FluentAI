doctype html
html(lang="vi")
    head
        meta(charset="UTF-8")
        meta(name="viewport" content="width=device-width, initial-scale=1.0")
        title #{pageTitle}
        link(rel="apple-touch-icon" sizes="180x180" href="/img/favicon_io/apple-touch-icon.png")
        link(rel="icon" type="image/png" sizes="32x32" href="/img/favicon_io/favicon-32x32.png")
        link(rel="icon" type="image/png" sizes="16x16" href="/img/favicon_io/favicon-16x16.png")
        link(rel="manifest" href="/img/favicon_io/site.webmanifest")
        link(rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css")
        link(rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css")
        link(rel="stylesheet" href="/css/layout.css")
        link(rel="stylesheet" href="/css/responsive.css")
        block head
    body(class="bg-gradient-light")
        // Header
        include ../partials/header.pug

        div(class="container-fluid main-body")
            block main-content

        // Footer
        include ../partials/footer.pug

        // Dictionary Widget
        include ../mixins/plugin.pug
        div(class="dictionary-widget")
            div(class="dictionary-widget__container" id="dictionaryWidgetContainer")
                +pluginLabanDictionary()
            button(class="dictionary-widget__toggle" id="dictionaryWidgetToggle" type="button" aria-label="Mở từ điển")
                i(class="fas fa-book dictionary-widget__toggle-icon dictionary-widget__toggle-icon--book")
                i(class="fas fa-times dictionary-widget__toggle-icon dictionary-widget__toggle-icon--close")

        script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js")
        script(src="https://cdn.jsdelivr.net/npm/popper.js@2.11.8/dist/umd/popper.min.js")
        script(src="/js/main.js")
        block scripts
