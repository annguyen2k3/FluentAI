%%{init: {'theme': 'neutral', 'themeVariables': { 'background': '#ffffff' }}}%%
sequenceDiagram
    participant User as Người dùng
    participant RegisterUI as Giao diện đăng ký
    participant VerifyUI as Giao diện xác thực email
    participant Backend as Backend
    participant DB as CSDL
    participant Mail as Email Service

    %% 1. Truy cập trang đăng ký
    User->>RegisterUI: 1. Truy cập /users/register
    RegisterUI->>Backend: GET /users/register
    Backend-->>RegisterUI: Render form đăng ký
    RegisterUI-->>User: 2. Hiển thị form đăng ký

    %% 2. Nhập và gửi thông tin đăng ký
    User->>RegisterUI: 3. Nhập Email, Password, PasswordConfirm
    User->>RegisterUI: 4. Nhấn nút Đăng ký
    RegisterUI->>Backend: POST /users/register (email, password, passwordConfirm)

    %% 3. Validation
    Note over Backend: registerValidator kiểm tra:<br/>- Định dạng email<br/>- Email chưa tồn tại<br/>- Password mạnh (6+ ký tự, có chữ hoa, thường, số, ký tự đặc biệt)<br/>- PasswordConfirm khớp
    Backend->>DB: 5. Kiểm tra email đã tồn tại?
    DB-->>Backend: Trả về kết quả

    %% 4. Xử lý kết quả validation
    rect rgb(255, 240, 240)
        Note over User,DB: Trường hợp lỗi
        alt [ Thông tin không hợp lệ ]
            Backend-->>RegisterUI: 6. 422 JSON lỗi validation
            RegisterUI-->>User: 7. Hiển thị thông báo lỗi
        end
    end

    rect rgb(240, 248, 255)
        Note over User,DB: Luồng xử lý chính
        alt [ Thông tin hợp lệ ]
            Note over Backend: Lưu email, password vào cookies
            Backend-->>RegisterUI: 6. 200 JSON { INFORM_SUCCESS }
            RegisterUI->>VerifyUI: Redirect /users/verify-email
            RegisterUI-->>User: 8. Chuyển đến trang xác thực email

            %% 5. Xác thực email
            VerifyUI->>Backend: GET /users/verify-email
            Note over Backend: Sinh OTP 4 chữ số<br/>Gửi email qua Nodemailer
            Backend->>Mail: 9. Gửi email chứa mã OTP
            Mail-->>User: Email xác thực
            Backend->>DB: 10. Lưu OTP (email, otp, type: REGISTER, expires_at: +15 phút)
            DB-->>Backend: Lưu thành công
            Backend-->>VerifyUI: Render verify-email.pug
            VerifyUI-->>User: 11. Hiển thị form nhập OTP

            %% 6. Nhập và xác thực OTP
            User->>VerifyUI: 12. Nhập OTP & nhấn Xác thực
            VerifyUI->>Backend: POST /users/verify-email (otp)

            Note over Backend: verifyEmailValidator kiểm tra OTP
            Backend->>DB: 13. Tìm OTP theo email, otp, type
            DB-->>Backend: Trả về kết quả

            rect rgb(255, 240, 240)
                Note over User,DB: Trường hợp lỗi
                alt [ OTP không hợp lệ ]
                    Backend-->>VerifyUI: 14. 422 JSON lỗi validation
                    VerifyUI-->>User: 15. Hiển thị thông báo lỗi OTP
                end
            end

            rect rgb(240, 255, 240)
                Note over User,DB: Trường hợp thành công
                alt [ OTP hợp lệ ]
                    Note over Backend: Hash password (MD5)<br/>Tạo user mới<br/>Sinh access_token (5M) & refresh_token (30D)
                    Backend->>DB: 14. Insert user mới
                    Backend->>DB: 15. Lưu refresh_token
                    DB-->>Backend: Thành công
                    Note over Backend: Set cookies HttpOnly<br/>(refresh_token, access_token)<br/>Xóa cookies emailRegister, passwordRegister
                    Backend-->>VerifyUI: 16. 200 JSON { REGISTER_SUCCESS }
                    VerifyUI->>VerifyUI: Redirect /
                    VerifyUI-->>User: 17. Hiển thị trang chủ FluentAI (đã đăng nhập)
                end
            end
        end
    end

