%%{init: {'theme': 'neutral', 'themeVariables': { 'background': '#ffffff' }}}%%
sequenceDiagram
    participant User as Người dùng
    participant ForgotPasswordUI as Giao diện quên mật khẩu
    participant OTPUI as Giao diện nhập OTP
    participant ResetUI as Giao diện đặt lại mật khẩu
    participant Backend as Backend
    participant DB as CSDL
    participant Mail as Email Service

    %% 1. Truy cập trang quên mật khẩu
    User->>ForgotPasswordUI: 1. Truy cập /users/forgot-password
    ForgotPasswordUI->>Backend: GET /users/forgot-password
    Backend-->>ForgotPasswordUI: Render form quên mật khẩu
    ForgotPasswordUI-->>User: 2. Hiển thị form nhập email

    %% 2. Nhập và gửi email
    User->>ForgotPasswordUI: 3. Nhập Email
    User->>ForgotPasswordUI: 4. Nhấn nút Gửi
    ForgotPasswordUI->>Backend: POST /users/forgot-password/email (email)

    %% 3. Validation email
    Note over Backend: forgotPasswordEmailValidator kiểm tra:<br/>- Định dạng email<br/>- Email tồn tại trong hệ thống
    Backend->>DB: 5. Kiểm tra email đã tồn tại?
    DB-->>Backend: Trả về kết quả

    %% 4. Xử lý kết quả validation
    rect rgb(255, 240, 240)
        Note over User,DB: Trường hợp lỗi
        alt [ Email không hợp lệ hoặc không tồn tại ]
            Backend-->>ForgotPasswordUI: 6. 422 JSON lỗi validation
            ForgotPasswordUI-->>User: 7. Hiển thị thông báo lỗi
        end
    end

    rect rgb(240, 248, 255)
        Note over User,DB: Luồng xử lý chính
        alt [ Email hợp lệ và tồn tại ]
            Note over Backend: Lưu email vào cookie (emailForgotPassword)
            Backend-->>ForgotPasswordUI: 6. 200 JSON { INFORM_SUCCESS }
            ForgotPasswordUI->>OTPUI: Redirect /users/forgot-password/otp
            ForgotPasswordUI-->>User: 8. Chuyển đến trang nhập OTP

            %% 5. Gửi OTP qua email
            OTPUI->>Backend: GET /users/forgot-password/otp
            Note over Backend: Kiểm tra cookie emailForgotPassword
            alt [ Không có email trong cookie ]
                Backend->>Backend: Redirect /users/forgot-password
                Backend-->>OTPUI: Redirect /users/forgot-password
                OTPUI-->>User: 9. Chuyển về trang quên mật khẩu
            end

            rect rgb(240, 248, 255)
                Note over User,DB: Luồng xử lý chính
                alt [ Có email trong cookie ]
                    Note over Backend: Sinh OTP 4 chữ số<br/>Gửi email qua Nodemailer
                    Backend->>Mail: 9. Gửi email chứa mã OTP
                    Mail-->>User: Email xác thực
                    Backend->>DB: 10. Lưu OTP (email, otp, type: FORGOT_PASSWORD, expires_at: +15 phút)
                    DB-->>Backend: Lưu thành công
                    Backend-->>OTPUI: Render forgot-password-otp.pug
                    OTPUI-->>User: 11. Hiển thị form nhập OTP

                    %% 6. Nhập và xác thực OTP
                    User->>OTPUI: 12. Nhập OTP & nhấn Xác thực
                    OTPUI->>Backend: POST /users/forgot-password/otp (otp)

                    Note over Backend: forgotPasswordOTPValidator kiểm tra:<br/>- OTP 4 chữ số<br/>- OTP tồn tại trong DB (email, otp, type)
                    Backend->>DB: 13. Tìm OTP theo email, otp, type
                    DB-->>Backend: Trả về kết quả

                    rect rgb(255, 240, 240)
                        Note over User,DB: Trường hợp lỗi
                        alt [ OTP không hợp lệ ]
                            Backend-->>OTPUI: 14. 422 JSON lỗi validation
                            OTPUI-->>User: 15. Hiển thị thông báo lỗi OTP
                        end
                    end

                    rect rgb(240, 255, 240)
                        Note over User,DB: Trường hợp thành công
                        alt [ OTP hợp lệ ]
                            Note over Backend: Lưu OTP vào cookie (otpForgotPassword)
                            Backend-->>OTPUI: 14. 200 JSON { INFORM_SUCCESS }
                            OTPUI->>ResetUI: Redirect /users/forgot-password/reset
                            OTPUI-->>User: 16. Chuyển đến trang đặt lại mật khẩu

                            %% 7. Đặt lại mật khẩu
                            ResetUI->>Backend: GET /users/forgot-password/reset
                            Note over Backend: Kiểm tra cookies (emailForgotPassword, otpForgotPassword)
                            Backend->>DB: 15. Kiểm tra OTP hợp lệ (email, otp, type)
                            DB-->>Backend: Trả về kết quả

                            rect rgb(255, 240, 240)
                                Note over User,DB: Trường hợp lỗi
                                alt [ OTP không hợp lệ hoặc hết hạn ]
                                    Backend->>Backend: Redirect /users/forgot-password
                                    Backend-->>ResetUI: Redirect /users/forgot-password
                                    ResetUI-->>User: 16. Chuyển về trang quên mật khẩu
                                end
                            end

                            rect rgb(240, 255, 240)
                                Note over User,DB: Trường hợp thành công
                                alt [ OTP hợp lệ ]
                                    Backend-->>ResetUI: Render forgot-password-reset.pug
                                    ResetUI-->>User: 17. Hiển thị form đặt lại mật khẩu

                                    %% 8. Nhập và xác nhận mật khẩu mới
                                    User->>ResetUI: 18. Nhập Password và PasswordConfirm
                                    User->>ResetUI: 19. Nhấn nút Xác nhận
                                    ResetUI->>Backend: POST /users/forgot-password/reset (password, passwordConfirm)

                                    Note over Backend: forgotPasswordResetValidator kiểm tra:<br/>- Password mạnh (6+ ký tự, có chữ hoa, thường, số, ký tự đặc biệt)<br/>- PasswordConfirm khớp
                                    
                                    rect rgb(255, 240, 240)
                                        Note over User,DB: Trường hợp lỗi
                                        alt [ Mật khẩu không hợp lệ ]
                                            Backend-->>ResetUI: 20. 422 JSON lỗi validation
                                            ResetUI-->>User: 21. Hiển thị thông báo lỗi
                                        end
                                    end

                                    rect rgb(240, 255, 240)
                                        Note over User,DB: Trường hợp thành công
                                        alt [ Mật khẩu hợp lệ ]
                                            Note over Backend: Hash password (MD5)<br/>Cập nhật mật khẩu mới
                                            Backend->>DB: 20. Cập nhật password theo email
                                            DB-->>Backend: Cập nhật thành công
                                            Note over Backend: Xóa cookies<br/>(emailForgotPassword, otpForgotPassword)
                                            Backend-->>ResetUI: 21. 200 JSON { RESET_PASSWORD_SUCCESS }
                                            ResetUI->>ResetUI: Redirect /users/login
                                            ResetUI-->>User: 22. Chuyển đến trang đăng nhập
                                        end
                                    end
                                end
                            end
                        end
                    end
                end
            end
        end
    end

